// Pure-arche numeric/string helpers (no FFI). A func may call these; it can't call externs, so
// libc's atoi/atof/strlen are reimplemented here to keep type-directed CSV cell parsing pure.
func strlen(s: char[]) -> int {
  i := 0;
  for (; s[i] != 0; i += 1) {
  }
  return i;
}
// Copy C-string `src` (through its NUL) into `dst`, NUL-terminate, return the filled buffer.
// Pure; the own/move contract makes the in-place fill explicit: `b := strcopy(move b, s)`.
func strcopy(own dst: char[], src: char[]) -> char[] {
  i := 0;
  for (; src[i] != 0; i += 1) {
    dst[i] = src[i];
  }
  dst[i] = 0;
  return dst;
}
// Parse a leading (optionally signed) integer; stops at the first non-digit, like libc atoi.
func atoi(s: char[]) -> int {
  i := 0;
  sign := 1;
  if (s[0] == '-') {
    sign = 0 - 1;
    i = 1;
  }
  n := 0;
  for (; s[i] != 0; i += 1) {
    if (s[i] < '0') {
      break;
    }
    if (s[i] > '9') {
      break;
    }
    n = n * 10 + (s[i] - '0');
  }
  return sign * n;
}
// Parse a leading (optionally signed) decimal: integer part then optional fraction, like libc atof.
func atof(s: char[]) -> float {
  i := 0;
  sign := 1.0;
  if (s[0] == '-') {
    sign = 0.0 - 1.0;
    i = 1;
  }
  whole := 0.0;
  for (; s[i] != 0; i += 1) {
    if (s[i] == '.') {
      i += 1;
      break;
    }
    if (s[i] < '0') {
      break;
    }
    if (s[i] > '9') {
      break;
    }
    whole = whole * 10.0 + (s[i] - '0');
  }
  frac := 0.0;
  scale := 1.0;
  for (; s[i] != 0; i += 1) {
    if (s[i] < '0') {
      break;
    }
    if (s[i] > '9') {
      break;
    }
    frac = frac * 10.0 + (s[i] - '0');
    scale = scale * 10.0;
  }
  return sign * (whole + frac / scale);
}
