arche Particle {
  pos: float,
  vel: float,
  mass: float,
}
arche Body {
  pos: float,
  vel: float,
  density: float,
}
static Particle(1000);
static Body(100);
sys move(pos, vel) {
  pos = pos + vel;
}
sys dampen(vel) {
  vel = vel * 0.99;
}
proc main() {
  insert(Particle, 1.0, 0.1, 5.0);
  insert(Particle, 2.0, 0.2, 10.0);
  insert(Particle, 3.0, 0.3, 15.0);
  insert(Body, 5.0, 0.5, 1.0);
  insert(Body, 6.0, 0.6, 2.0);
  run move;
  run dampen;
  print("simulation completed\n");
}
