arche Particle {
  pos: (x: float, y: float),
  vel: (vx: float, vy: float),
  mass: float
}

arche Body {
  pos: (x: float, y: float),
  vel: (vx: float, vy: float),
  density: float
}

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

world Simulation()

proc main() {
  let particles = alloc Particle(1000);
  let bodies = alloc Body(100);
  run move in Simulation;
  run dampen in Simulation;
  let msg = "simulation completed\n";
  write(1, msg, msg.length);
}
