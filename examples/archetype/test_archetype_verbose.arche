arche Particle {
  pos: float,
  vel: float,
  mass: float
}

arche Body {
  pos: float,
  vel: float,
  density: float
}

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

world Simulation()

proc main() {
  let particles = Particle.alloc((null): 1000);
  let bodies = Body.alloc((null): 100);
  let msg = "simulation completed\n";
  write(1, msg, msg.length);
}

