#import { fmt }
Particle :: arche { pos :: float, vel :: float, mass :: float }
Body :: arche { pos, vel, density :: float }
Particle[1000]
Body[100]
integrate :: sys (pos, vel) {
  pos = pos + vel;
}
dampen :: sys (vel) {
  vel = vel * 0.99;
}
main :: proc() {
  insert(Particle, 1.0, 0.1, 5.0);
  insert(Particle, 2.0, 0.2, 10.0);
  insert(Particle, 3.0, 0.3, 15.0);
  insert(Body, 5.0, 0.5, 1.0);
  insert(Body, 6.0, 0.6, 2.0);
  run integrate;
  run dampen;
  fmt.print("simulation completed\n");
}
