arche Particle {
  pos: float,
  vel: float,
  mass: float
}

arche Body {
  pos: float,
  vel: float,
  density: float
}

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

proc main() {
  let particles = alloc Particle(1000);
  let bodies = alloc Body(100);
  insert(particles, 1.0, 0.1, 5.0);
  insert(particles, 2.0, 0.2, 10.0);
  insert(particles, 3.0, 0.3, 15.0);
  insert(bodies, 5.0, 0.5, 1.0);
  insert(bodies, 6.0, 0.6, 2.0);
  run move in (null);
  run dampen in (null);
  let msg = "simulation completed\n";
  write(1, msg, msg.length);
}

