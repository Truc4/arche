#import { fmt }
Particle :: arche { pos :: float, vel :: float, mass :: float }
Body     :: arche { pos, vel, density :: float }
[1000]Particle;
[100]Body;
integrate :: map (pos, vel) {
  pos = pos + vel;
}
dampen :: map (vel) {
  vel = vel * 0.99;
}
main :: proc() {
  insert(Particle, 1.0, 0.1, 5.0)(_:, _:);
  insert(Particle, 2.0, 0.2, 10.0)(_:, _:);
  insert(Particle, 3.0, 0.3, 15.0)(_:, _:);
  insert(Body, 5.0, 0.5, 1.0)(_:, _:);
  insert(Body, 6.0, 0.6, 2.0)(_:, _:);
  run integrate;
  run dampen;
  fmt.print("simulation completed\n");
}
