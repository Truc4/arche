arche Particle {
  pos: float,
  vel: float
}

arche Body {
  pos: float,
  vel: float,
  mass: float
}

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

proc write() {
}

proc main() {
  let particles = alloc Particle(100);
  let bodies = alloc Body(50);
  let msg = "systems executed\n";
  write(1, msg, msg.length);
}

