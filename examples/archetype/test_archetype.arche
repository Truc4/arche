Particle :: arche {
  pos :: float, vel :: float,
}
Body :: arche {
  pos :: float, vel :: float, mass :: float,
}
static pool<Particle> (100)
static pool<Body> (50)
integrate :: sys (pos, vel) {
  pos = pos + vel;
}
dampen :: sys (vel) {
  vel = vel * 0.99;
}
main :: proc () {
  insert(Particle, 1.0, 0.1);
  insert(Particle, 2.0, 0.2);
  insert(Particle, 3.0, 0.3);
  insert(Body, 5.0, 0.5, 10.0);
  insert(Body, 6.0, 0.6, 20.0);
  run integrate;
  run dampen;
  print("systems executed\n");
}
