arche Particle {
  pos: (x: float, y: float),
  vel: (vx: float, vy: float)
}

arche Body {
  pos: (x: float, y: float),
  vel: (vx: float, vy: float)
}

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

world Simulation()

proc main() {
  let particles = alloc Particle(100);
  let bodies = alloc Body(50);
  run move in Simulation;
  run dampen in Simulation;
  let msg = "systems executed\n";
  write(1, msg, msg.length);
}
