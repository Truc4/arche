arche Particle {
  pos :: float,
  vel :: float,
}
arche Body {
  pos :: float,
  vel :: float,
  mass :: float,
}
static table<Particle>(100);
static table<Body>(50);
sys move(pos, vel) {
  pos = pos + vel;
}
sys dampen(vel) {
  vel = vel * 0.99;
}
proc main() {
  insert(table<Particle>, 1.0, 0.1);
  insert(table<Particle>, 2.0, 0.2);
  insert(table<Particle>, 3.0, 0.3);
  insert(table<Body>, 5.0, 0.5, 10.0);
  insert(table<Body>, 6.0, 0.6, 20.0);
  run move;
  run dampen;
  print("systems executed\n");
}
