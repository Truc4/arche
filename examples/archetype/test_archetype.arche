#import { fmt }
Particle :: arche { pos :: float, vel :: float }
Body     :: arche { pos, vel, mass :: float }
[100]Particle;
[50]Body;
integrate :: map (query { pos, vel }) {
  pos = pos + vel;
}
dampen :: map (query { vel }) {
  vel = vel * 0.99;
}
main :: proc() {
  insert(Particle { pos: 1.0, vel: 0.1 })(_:, _:);
  insert(Particle { pos: 2.0, vel: 0.2 })(_:, _:);
  insert(Particle { pos: 3.0, vel: 0.3 })(_:, _:);
  insert(Body { pos: 5.0, vel: 0.5, mass: 10.0 })(_:, _:);
  insert(Body { pos: 6.0, vel: 0.6, mass: 20.0 })(_:, _:);
  run integrate;
  run dampen;
  fmt.print("systems executed\n");
}
