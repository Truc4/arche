arche Particle {
  pos: float,
  vel: float
}

arche Body {
  pos: float,
  vel: float
}

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

proc main() {
  let particles = Particle.alloc((null): 100);
  let bodies = Body.alloc((null): 50);
  let msg = "systems executed\n";
  write(1, msg, msg.length);
}

