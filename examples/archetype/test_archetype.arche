arche Particle {
  pos: float,
  vel: float
}

arche Body {
  pos: float,
  vel: float,
  mass: float
}

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

proc main() {
  let particles = alloc Particle(100);
  let bodies = alloc Body(50);
  insert(particles, 1.0, 0.1);
  insert(particles, 2.0, 0.2);
  insert(particles, 3.0, 0.3);
  insert(bodies, 5.0, 0.5, 10.0);
  insert(bodies, 6.0, 0.6, 20.0);
  run move;
  run dampen;
  let msg = "systems executed\n";
  print(msg);
}

