#import { fmt }
Particle :: arche { pos :: float, vel :: float }
Body     :: arche { pos, vel, mass :: float }
Particle[100]
Body[50]
integrate :: sys (pos, vel) {
  pos = pos + vel;
}
dampen :: sys (vel) {
  vel = vel * 0.99;
}
main :: proc() {
  insert(Particle, 1.0, 0.1)(_:, _:);
  insert(Particle, 2.0, 0.2)(_:, _:);
  insert(Particle, 3.0, 0.3)(_:, _:);
  insert(Body, 5.0, 0.5, 10.0)(_:, _:);
  insert(Body, 6.0, 0.6, 20.0)(_:, _:);
  run integrate;
  run dampen;
  fmt.print("systems executed\n");
}
