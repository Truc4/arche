arche Particle {
  pos: float,
  vel: float,
}

arche Body {
  pos: float,
  vel: float,
  mass: float,
}

static Particle(100);

static Body(50);

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

proc main() {
  insert(Particle, 1.0, 0.1);
  insert(Particle, 2.0, 0.2);
  insert(Particle, 3.0, 0.3);
  insert(Body, 5.0, 0.5, 10.0);
  insert(Body, 6.0, 0.6, 20.0);
  run move;
  run dampen;
  print("systems executed\n");
}

