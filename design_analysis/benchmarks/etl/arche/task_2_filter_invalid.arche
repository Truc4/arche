// RUN: %arche -o %t %s && %t
// Task 2: Filter invalid rows
// Keep only rows where quantity > 0

arche Transaction {
  timestamp: int,
  price: float,
  quantity: int,
  region: char[16],
  flags: int,
  valid: int,
}



sys mark_valid(quantity, valid) {
  valid = quantity > 0;
}



extern proc load_transaction_csv();


proc main() {
  alloc Transaction(1000000);
  load_transaction_csv();
  run mark_valid;
}

