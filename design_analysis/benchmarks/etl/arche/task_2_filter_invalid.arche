// RUN: %arche -o %t %s && %t
// Task 2: Filter invalid rows
// Keep only rows where quantity > 0

arche Transaction {
  timestamp: int,
  price: float,
  quantity: int,
  region: char[16],
  flags: int,
  valid: int,
}


sys mark_valid(quantity, valid) {
  valid = quantity > 0;
}


proc main() {
  Transaction.alloc((null): 1, quantity: 5);
  run mark_valid;
  assert(Transaction.valid[0] == 1, "valid[0] != 1\n");
  printf("ok\n");
}

