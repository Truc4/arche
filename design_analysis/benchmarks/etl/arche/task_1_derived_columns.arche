// Task 1: Compute derived columns
// Compute revenue = price * quantity for all rows

arche Transaction {
  timestamp: int,
  price: float,
  quantity: int,
  region: char[16],
  flags: int,
  revenue: float,
}



sys compute_revenue(price, quantity, revenue) {
  revenue = price * quantity;
}



extern proc load_transaction_csv();


proc main() {
  alloc Transaction(1000000);
  load_transaction_csv();
  run compute_revenue;
}

