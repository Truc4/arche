// Task 1: Compute derived columns
// Compute revenue = price * quantity for all rows

use csv;

arche Transaction {
  price: float,
  quantity: int,
  revenue: float,
}

static Transaction(1000, 1000) {
  price: 0.0,
  quantity: 0
};

proc main() {
  load_transactions();
  Transaction.revenue = Transaction.price * Transaction.quantity;
  printf("✓ Task 1 complete\n");
}
