#import { os fmt }

v :: float;

T :: arche { v }

[100000000]T(100000000) {
  v: 1.0
}

main :: proc() {

  os.now_ms()(t0:);
  red := reduce(+, T.v);
  os.now_ms()(t1:);

  total := 0.0;
  for (m := 0; m < 100000000; m += 1) {
    total = total + T.v[m];
  }
  os.now_ms()(t2:);

  reduce_ms := t1 - t0;
  loop_ms   := t2 - t1;
  fmt.printf(
    "fold_n=100000000 reduce_ms=%lld loop_ms=%lld reduce_sum=%g loop_sum=%g\n",
    reduce_ms,
    loop_ms,
    red,
    total,
  );
}
