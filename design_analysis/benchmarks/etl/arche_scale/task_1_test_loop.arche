arche Transaction {
  price :: float,
  quantity :: int,
  revenue :: float,
}
static table<Transaction>(100, 100) {
  price: 0.0,
  quantity: 0,
  revenue: 0.0,
};
proc main() {
  fd := arche_fopen_read("design_analysis/benchmarks/etl/data/data.csv");
  line: char[128];
  price_str: char[32];
  qty_str: char[32];
  arche_fread_line(fd, line, 128);
  idx := 0;
  for (;idx < 100;) {
    n := arche_fread_line(fd, line, 128);
    if (n <= 0) {
      break;
    }
    line_pos := 0;
    field_idx := 0;
    c1 := 0;
    c2 := 0;
    c3 := 0;
    for (;line_pos < n;) {
      if (line[line_pos] == ',') {
        field_idx = field_idx + 1;
        if (field_idx == 1) {
          c1 = line_pos;
        }
        if (field_idx == 2) {
          c2 = line_pos;
        }
        if (field_idx == 3) {
          c3 = line_pos;
        }
        line_pos = line_pos + 1;
      } else {
        line_pos = line_pos + 1;
      }
    }
    idx = idx + 1;
  }
  arche_fclose(fd);
  printf("ok\n");
}
