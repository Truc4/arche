#import { io fmt }

Transaction :: arche { price :: float, quantity :: int, revenue :: float }
Transaction[100](100) {
  price: 0.0, quantity: 0, revenue: 0.0,
}

main :: proc() {
  io.fopen_read("design_analysis/benchmarks/etl/data/data.csv")(fd:);
  hdr: char[128];
  io.fread_line(fd, move hdr, 128)(_hdr:);
  idx := 0;
  for (; idx < 100;) {
    line: char[128];
    io.fread_line(fd, move line, 128)(view:);
    n := view.length;
    if (n <= 0) {
      break;
    }
    line_pos  := 0;
    field_idx := 0;
    c1        := 0;
    c2        := 0;
    c3        := 0;
    for (; line_pos < n;) {
      if (view[line_pos] == ',') {
        field_idx = field_idx + 1;
        if (field_idx == 1) {
          c1 = line_pos;
        }
        if (field_idx == 2) {
          c2 = line_pos;
        }
        if (field_idx == 3) {
          c3 = line_pos;
        }
        line_pos = line_pos + 1;
      }
      else {
        line_pos = line_pos + 1;
      }
    }
    idx = idx + 1;
  }
  io.fclose(move fd);
  fmt.printf("ok\n");
}
