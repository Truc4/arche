arche Transaction {
  price :: float,
  quantity :: int,
  revenue :: float,
}
static table<Transaction>(100, 100) {
  price: 0.0,
  quantity: 0,
  revenue: 0.0,
};
proc main() {
  fd := arche_fopen_read("design_analysis/benchmarks/etl/data/data.csv");
  line: char[128];
  arche_fread_line(fd, line, 128);
  arche_fclose(fd);
  printf("ok\n");
}
