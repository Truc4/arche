Transaction :: arche {
  price :: float, quantity :: int, revenue :: float,
}
static pool<Transaction> (100, 100) {
  price: 0.0, quantity: 0, revenue: 0.0,
}

main :: proc () {
  arche_fopen_read("design_analysis/benchmarks/etl/data/data.csv")(fd:);
  line: char[128];
  arche_fread_line(fd, line, 128);
  idx := 0;
  for (; idx < 100;) {
    arche_fread_line(fd, line, 128)(n:);
    if (n <= 0) {
      break;
    }
    idx = idx + 1;
  }
  arche_fclose(fd);
  printf("ok\n");
}
