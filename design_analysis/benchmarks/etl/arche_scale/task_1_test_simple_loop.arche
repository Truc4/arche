arche Transaction {
  price :: float,
  quantity :: int,
  revenue :: float,
}
static pool<Transaction> (100, 100) {
  price: 0.0, quantity: 0, revenue: 0.0,
}
;
proc main() {
  fd := arche_fopen_read("design_analysis/benchmarks/etl/data/data.csv");
  line: char[128];
  arche_fread_line(fd, line, 128);
  idx := 0;
  for (;
  idx < 100;
  ) {
    n := arche_fread_line(fd, line, 128);
    if (n <= 0) {
      break;
    }
    idx = idx + 1;
  }
  arche_fclose(fd);
  printf("ok\n");
}
