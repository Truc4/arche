#import { fmt }
k :: int;
a :: int;
b :: int;
c :: int;
N :: arche { k, a, b, c }
[20000]N(20000) {
  k: 1, a: 1, b: 1, c: 1
}
negk :: map (query { k }) {
  k = 0 - k;
}
main :: proc() {
  scan(+, N.k);
  scan(+, N.a);
  scan(+, N.b);
  scan(+, N.c);
  run negk;
  sort(N.k);
  chk := reduce(+, N.a);
  fmt.assert(N.a[0] == 20000, "rev\n");
  fmt.printf("ok chk=%d\n", chk);
}
