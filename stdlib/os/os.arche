// The `os` module — process/system services (C-backed in runtime/io.c, term.c).
// `#import { os }` then call `os.now_sec()`, `os.sleep_ms(...)`, `os.argc()`, `os.argv(i)`.
// Access is qualified-only: a bare `now_sec()` does not resolve.
#foreign {
  os_now_sec :: proc()(t: float)
  os_sleep_ms :: proc(ms: int)
  os_argc :: proc()(n: int)
  os_argv :: proc(i: int)(s: char[])
}
