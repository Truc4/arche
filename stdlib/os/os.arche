// The `os` module — process/system services (C-backed in runtime/io.c, term.c).
// `#import os;` then `sys.arche_now_sec`, `sys.arche_argc`, … (bare names also resolve).
extern proc arche_now_sec()(t: float);
extern proc arche_sleep_ms(ms: int);
extern proc arche_argc()(n: int);
extern proc arche_argv(i: int)(s: char[]);
