raw_enable :: func() -> Eff() {
  return term_raw_enable();
}
raw_restore :: func() -> Eff() {
  return term_raw_restore();
}
read_key :: func() -> Eff(int) {
  return term_read_key();
}

#module
#foreign {
  term_raw_enable  :: proc();
  term_raw_restore :: proc();
  term_read_key    :: proc()(k: int);
}
