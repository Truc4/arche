arche Particle {
  pos: (x: float, y: float),
  vel: (x: float, y: float),
}

proc main() {
  let p = alloc Particle(2);
  insert(p, 1.0, 2.0, 0.5, 0.1);
  insert(p, 3.0, 4.0, 0.2, 0.3);
  p.pos = p.vel;
  print(p.pos.x[0]);
  print(" ");
  print(p.pos.y[0]);
  print(" ");
  print(p.pos.x[1]);
  print(" ");
  print(p.pos.y[1]);
  print("\n");
}

