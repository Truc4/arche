arche Particle {
  pos_x: float,
  pos_y: float,
  vel_x: float,
  vel_y: float,
}

proc main() {
  alloc Particle(1);
  insert(Particle, 1.0, 2.0, 0.5, 0.1);
  Particle.pos.x = Particle.pos.x + Particle.vel.x;
  Particle.pos.y = Particle.pos.y + Particle.vel.y;
  let msg = "dot syntax works\n";
  print(msg);
}

