arche Particle {
  pos: float,
  vel: float,
}

arche Body {
  pos: float,
  vel: float,
  mass: float,
}

sys move(pos, vel) {
  pos = pos + vel;
}

proc main() {
  alloc Particle(5);
  let bodies = alloc Body(5);
  insert(Particle, 1.0, 0.1);
  insert(bodies, 2.0, 0.2);
  run move;
  print("multi-archetype dispatch works\n");
}

