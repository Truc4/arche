arche Particle {
  pos: (x: float, y: float),
  vel: (dx: float, dy: float),
  acc: (i: float, j: float),
}

proc main() {
  let p = alloc Particle(2);
  insert(p, 0.0, 0.0, 1.0, 2.0, 0.1, 0.2);
  insert(p, 5.0, 5.0, 0.5, 0.5, 0.05, 0.05);
  p.vel = p.acc;
  p.pos = p.vel;
  print(p.pos.x[0]);
  print(" ");
  print(p.pos.y[0]);
  print(" ");
  print(p.pos.x[1]);
  print(" ");
  print(p.pos.y[1]);
  print("\n");
}

