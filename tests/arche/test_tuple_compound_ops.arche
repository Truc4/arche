arche Particle {
  pos_x: float,
  pos_y: float,
  vel_dx: float,
  vel_dy: float,
  acc_i: float,
  acc_j: float
}

proc main() {
  let p = alloc Particle(2);
  insert(p, 0.0, 0.0, 1.0, 2.0, 0.1, 0.2);
  insert(p, 5.0, 5.0, 0.5, 0.5, 0.05, 0.05);
  p.vel = p.acc;
  p.pos = p.vel;
  let msg = "compound tuple ops done\n";
  print(msg);
}

