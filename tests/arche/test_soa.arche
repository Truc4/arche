arche Particle {
  pos: float,
  vel: float,
}

sys move(pos, vel) {
  pos = pos + vel;
}

proc main() {
  alloc Particle(1000);
  insert(Particle, 1.0, 0.1);
  insert(Particle, 2.0, 0.2);
  insert(Particle, 3.0, 0.3);
  insert(Particle, 4.0, 0.4);
  insert(Particle, 5.0, 0.5);
  insert(Particle, 6.0, 0.6);
  insert(Particle, 7.0, 0.7);
  insert(Particle, 8.0, 0.8);
  insert(Particle, 9.0, 0.9);
  insert(Particle, 10.0, 1.0);
  Particle.pos = Particle.pos + Particle.vel;
  let msg = "test passed\n";
  print(msg);
}

