arche Particle {
  pos: float,
  vel: float,
}

sys move(pos, vel) {
  pos = pos + vel;
}

proc main() {
  let particles = alloc Particle(10);
  insert(particles, 1.0, 0.1);
  insert(particles, 2.0, 0.2);
  insert(particles, 3.0, 0.3);
  run move;
  dealloc(particles);
  let msg = "dealloc test passed\n";
  print(msg);
}

