arche Particle {
  pos: float,
  vel: float,
}

sys move(pos, vel) {
  pos = pos + vel;
}

proc main() {
  alloc Particle(10);
  insert(Particle, 1.0, 0.1);
  insert(Particle, 2.0, 0.2);
  insert(Particle, 3.0, 0.3);
  run move;
  dealloc(Particle);
  let msg = "dealloc test passed\n";
  print(msg);
}

