arche Particle {
  pos: float,
  vel: float,
}

sys move(pos, vel) {
  pos = pos + vel;
}

proc main() {
  alloc Particle(10);
  insert(Particle, 1.0, 0.1);
  insert(Particle, 2.0, 0.2);
  insert(Particle, 3.0, 0.3);
  run move;
  let p0 = Particle.pos[0];
  let p1 = Particle.pos[1];
  let p0i = p0 * 10.0;
  let p1i = p1 * 10.0;
  assert(p0i == 11, "pos[0] != 1.1\n");
  assert(p1i == 22, "pos[1] != 2.2\n");
  dealloc(Particle);
}

