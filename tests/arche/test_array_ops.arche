arche Particle {
  pos: float,
  vel: float,
}

proc main() {
  alloc Particle(1000);
  insert(Particle, 1.0, 0.1);
  insert(Particle, 2.0, 0.2);
  insert(Particle, 3.0, 0.3);
  insert(Particle, 4.0, 0.4);
  insert(Particle, 5.0, 0.5);
  Particle.pos = Particle.pos + Particle.vel;
  let msg = "array ops done\n";
  print(msg);
}

