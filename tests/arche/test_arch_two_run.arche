arche Particle {
  pos: float,
  vel: float,
}

arche Body {
  pos: float,
  vel: float,
  mass: float,
}

sys move(pos, vel) {
  pos = pos + vel;
}

proc main() {
  alloc Particle(100);
  let bodies = alloc Body(50);
  insert(Particle, 1.0, 0.1);
  insert(bodies, 5.0, 0.5, 10.0);
  run move;
  print("ran system\n");
}

