arche Entity {
  x: float,
  y: float
}

proc main() {
  let ent = alloc Entity(100);
  insert(ent, 1.0, 2.0);
  insert(ent, 3.0, 4.0);
  insert(ent, 5.0, 6.0);
  insert(ent, 7.0, 8.0);
  insert(ent, 9.0, 10.0);
  ent.x = ent.x + 1.0;
  ent.y = ent.y * 2.0;
  delete(ent, 1);
  insert(ent, 11.0, 12.0);
  let msg = "pooling test passed\n";
  print(msg);
}

