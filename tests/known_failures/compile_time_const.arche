// KNOWN FAILURE — compile-time function evaluation (CTFE) is not implemented yet.
//
// A pure `func` should be usable in a value/size position — a const, an array size, a pool
// capacity, a field default — and evaluated at compile time. That is the eventual `func`
// superpower that makes "func = value" undeniable (funcs are the compile-time/schema layer; procs
// the runtime layer). Today the compiler can't fold `area(3, 4)` into the constant 12, so the pool
// capacity below does not compile. See design_analysis/compile_time_constants.md.
//
// (This directory is excluded from the lit run via tests/lit.cfg. Move this test out once CTFE
// lands and it passes.)
// RUN: %arche build -o %t %s && %t | grep "ok"
area :: func (w: int, h: int) -> int {
  return w * h;
}
Grid :: arche {
  cell :: int,
}
static pool<Grid> (area(3, 4)) {
  cell: 0,
}
;

main :: proc () {
  assert(Grid.cell[11] == 0, "last cell should exist (capacity 12)\n");
  printf("ok\n");
}
