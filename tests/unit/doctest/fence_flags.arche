// Fence info-string flags (Rust-style): no_run, compile_fail, should_panic,
// ignore. All four examples below must be treated correctly and the run passes.
// RUN: %arche test %s
#import { fmt }

/// `no_run`: compiles but is not executed (so the wrong assertion never runs).
///
/// ```arche,no_run
/// fmt.assert(val() == 999, "would fail if run, but no_run\n")();
/// ```
///
/// `compile_fail`: must fail to compile (documents a misuse), so the run passes.
///
/// ```arche,compile_fail
/// x := no_such_symbol(1);
/// ```
///
/// `should_panic`: must exit non-zero (the assertion fails on purpose).
///
/// ```arche,should_panic
/// fmt.assert(val() == 0, "intentional panic\n")();
/// ```
///
/// `ignore`: never compiled or run, even though it is nonsense.
///
/// ```arche,ignore
/// this is not even valid arche
/// ```
val :: func() -> int {
  return 42;
}
