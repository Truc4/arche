// RUN: %arche test %s
#import { fmt }

/// Squares a value. The example body is bare statements with no `proc main`;
/// the runner must wrap them in a main automatically.
///
/// # Example
/// ```arche
/// x := sq(4);
/// fmt.assert(x == 16, "sq broken\n");
/// ```
sq :: func(a: int) -> int {
  return a * a;
}
