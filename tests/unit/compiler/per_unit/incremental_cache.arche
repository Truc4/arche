// Incremental separate compilation: with per-unit codegen, each unit (driver + each imported device)
// is compiled to its OWN content-hash-keyed object. Building twice with a warm cache reuses the
// unchanged units' objects verbatim — the "compile this part, leave that alone" guarantee. The first
// build populates the cache; the second must report a NONZERO reuse count and still run correctly.
// RUN: rm -rf %t.cache && env ARCHE_PER_UNIT=1 ARCHE_CACHE_DIR=%t.cache %arche build -o %t %s >/dev/null && env ARCHE_PER_UNIT=1 ARCHE_CACHE_DIR=%t.cache %arche build -o %t %s | grep -qE "[1-9][0-9]* reused from cache"
// RUN: %t | grep -qF "inc_ok"
#import { fmt }
main :: proc() {
  fmt.print("inc_ok\n")();
}
