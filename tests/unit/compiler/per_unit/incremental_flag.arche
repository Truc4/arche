// The first-class `--incremental` build flag is the idiomatic trigger for device-granular separate
// compilation (equivalent to the ARCHE_PER_UNIT env). A warm-cache rebuild under the flag must reuse
// the unchanged units' objects verbatim and still produce a correct executable.
// RUN: rm -rf %t.cache && env ARCHE_CACHE_DIR=%t.cache %arche build --incremental -o %t %s >/dev/null && env ARCHE_CACHE_DIR=%t.cache %arche build --incremental -o %t %s | grep -qE "[1-9][0-9]* reused from cache"
// RUN: %t | grep -qF "flag_ok"
#import { fmt }
main :: proc() {
  fmt.print("flag_ok\n")();
}
