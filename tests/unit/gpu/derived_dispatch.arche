// REGRESSION (derived placement): a pure map with NO `@gpu` annotation. The placer alone decides GPU.
// The bug: a derived GPU placement emitted the `arche_gpu_dispatch` call but never EMBEDDED the shader
// (shader-embed was gated on the `@gpu` flag, which a derived map doesn't carry) — so at runtime the
// dispatch found no shader and SILENTLY fell back to the CPU. The placement said GPU; the win never ran.
// `make test-derived-gpu` forces this map onto the GPU (ARCHE_FORCE_PLACE=gpu) and asserts a real
// `gpu dispatch` happens (when a device is present) — pre-fix it never did. Output stays correct either way.
// RUN: %arche build -o %t %s && %t | grep -qF "x0=0 x3=30"
#import { fmt }
x :: float;
P :: arche { x }
[4]P(4);

// no @gpu here — placement is DERIVED.
scale :: map (query { x }) (x) {
  x = x * 10.0;
}

seed :: system {
  P.x = { 0.0, 1.0, 2.0, 3.0 };
}

verify :: system eff {
  fmt.printf("x0=%.0f x3=%.0f\n", P.x[0] * 1.0, P.x[3] * 1.0);
}

#run seq({ seed, scale, verify })
