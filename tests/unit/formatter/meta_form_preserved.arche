// The formatter must PRESERVE what was written — a CST is faithful to concrete syntax. The explicit
// meta-type longhand `name : type : T` round-trips as itself (it is NOT canonicalized to `::`), at
// top level, in an archetype component, and as a local. The inferred `::` forms round-trip too.
// RUN: %arche fmt %s | grep -F "alias_top : type : int"
// RUN: %arche fmt %s | grep -F "mass : type : int"
// RUN: %arche fmt %s | grep -F "loc : type : int"
// RUN: %arche fmt %s | grep -F "short_top :: int"
#import { fmt }
alias_top: type: int
short_top :: int
Body :: arche { mass: type: int }

main :: proc() {
  loc: type: int;
  p: loc = 1;
  q: alias_top = 2;
  r: short_top = 3;
  m: mass = 4;
  fmt.printf("%d\n", p + q + r + m);
}
