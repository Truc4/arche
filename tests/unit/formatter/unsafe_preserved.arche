// The formatter must preserve the `unsafe` qualifier on proc and func
// declarations. Regression: `is_unsafe` was set in the CST but never emitted,
// so `make format` silently stripped `unsafe` (breaking syscall gating).
// RUN: %build/arche-fmt %s | grep "unsafe proc foo"
// RUN: %build/arche-fmt %s | grep "unsafe func bar"
unsafe proc foo() {
}
unsafe func bar() -> i32 {
  return 0;
}
