// Local constants round-trip through the formatter: inferred `k :: e`, typed `j : T : e`, and a
// local type alias `m :: T`.
// RUN: %arche fmt %s | grep -F "k :: 10"
// RUN: %arche fmt %s | grep -F "j : int : 7"
// RUN: %arche fmt %s | grep -F "m :: int"
#import { fmt }
entry :: system eff {
  k :: 10;
  j: int: 7;
  m :: int;
  d: m = 5;
  fmt.printf("%d\n", k + j + d);
}

#run entry
