// FEATURE: an opaque-with-`@drop` handle stored into a `#file`-private mutable global (`slot = h`) is
// MOVED — the source local is consumed, so its `@drop` does not fire at scope exit and the handle stays
// live (`obj_live` == 1). Mirrors opaque_into_column, but for a plain global instead of a pool column —
// this is what makes the rpg's `#file`-private `win : window` global safe. The global is `#file` (not
// exported), so W0022 does not fire (an exported mutable global would be banned, in any file).
// RUN: %arche build -o %t --link %S/runtime/dropcount.c %s && %t | grep -qF "live=1"
#import { fmt }
H :: opaque;
#foreign {
  obj_open :: proc()(h: H);
  @drop(H)
  obj_close :: proc(own h: H);
  obj_live  :: proc()(n: int);
}

#file
slot: H;

boot :: system {
  obj_open()(h:);
  slot = h;
}

check :: system {
  obj_live()(n:);
  fmt.printf("live=%d\n", n);
}

#run seq({ run (boot), run (check) })
