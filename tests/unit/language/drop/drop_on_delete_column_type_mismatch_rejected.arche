// A pool-row `@drop` destructor's parameter type must match the column it names — `delete` reads the
// column's storage and hands it over, so a type mismatch would reinterpret the bytes. Reject it.
// RUN: not %arche build -o %t %s 2>&1 | grep -qi "type must match the column"
#import { fmt }

File :: arche { fd :: i64 }
[4]File;

@drop(File)
close_file :: proc(fd: char) { // column `fd` is i64, not char
  fmt.printf("%d\n", fd);
}

main :: proc() {
  insert(File { fd: 7 })(h:, _:);
  delete(h)(_:);
}
