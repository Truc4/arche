// With a registered destructor (`@drop(file) fclose` in stdlib/io), an opaque local that is
// never explicitly closed is NOT an error — it is auto-dropped at scope exit. (Old rule: this was
// `opaque value 'f' not consumed before scope end`.)
// RUN: %arche build -o %t %s
#import { io }
entry :: system eff {
  io.fopen_read("/dev/null")(f:);
}

#run entry
