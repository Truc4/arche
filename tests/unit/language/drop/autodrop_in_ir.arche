// The auto-drop is a real call to the registered destructor, inserted at scope exit: the IR for a
// function that opens a file and never closes it must contain a call to `io_fclose`.
// RUN: %arche build --emit llvm-ir -o %t.ll %s ; grep -q "io_fclose" %t.ll
#import { io }
main :: proc() {
  io.fopen_read("/dev/null")(f:);
}
