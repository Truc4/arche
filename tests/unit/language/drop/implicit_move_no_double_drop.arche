// The file must be closed EXACTLY ONCE. `io.fclose` is now a `func → Eff` that fuses to the close
// `syscall(3, fd, …)`, so the close shows up as exactly one `syscall` whose first operand is `i64 3`
// (the open is `i64 2`). One explicit `io.fclose(f)(_:)` → exactly one close syscall, no double.
// RUN: %arche build --emit llvm-ir -o %t.ll %s ; test $(awk '/define .*@main_user/{f=1} f&&/\(i64 3, i64/{c++} f&&/^}/{print c+0;exit}' %t.ll) -eq 1
#import { io }
main :: proc() {
  io.fopen_read("/dev/null")(f:);
  io.fclose(f)(_:);
}
