// Idiomatic if/else where every path closes the handle exactly once: valid (no false "use of
// consumed handle" in the else, no double-drop). Consumed on all paths → no auto-drop.
// RUN: %arche build -o %t %s
#import { io }
main :: proc() {
  io.fopen_read("/dev/null")(f:);
  e := 0;
  if (e == 1) {
    io.fclose(move f);
  }
  else {
    io.fclose(move f);
  }
}
