proc main() {
  let line: char[256];
  let i := 0;
  line[0] = '1';
  line[1] = '0';
  line[2] = '.';
  line[3] = '5';
  line[4] = ',';
  line[5] = '1';
  line[6] = '0';
  line[7] = '0';
  line[8] = 0;

  let pos := 0;
  let field_count := 0;
  let comma_pos := 0;

  for (;pos < 8;) {
    if (line[pos] == ',') {
      field_count = field_count + 1;
      if (field_count == 1) {
        comma_pos = pos;
      }
    }
    pos = pos + 1;
  }

  if (comma_pos == 4) {
    printf("PASS: found comma at position 4\n");
  } else {
    printf("FAIL: expected comma at 4, got %d\n", comma_pos);
  }
}
