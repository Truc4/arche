// RED until entities ship: tuple-group columns stay GROUPED in an entity literal — `pos: (1,2)` not four
// flat positional values. This is the whole point: the entity matches the SHAPE as written, no flatten footgun.
// RUN: %arche build -o %t %s && %t | grep -qF "p=1 2 v=3 4"
#import { fmt }
pos(x, y) :: float;
vel(x, y) :: float;
Mover     :: arche { pos, vel }
[2]Mover ?abort;

entry :: system {
  insert(Mover { pos: (1.0, 2.0), vel: (3.0, 4.0) })(_:, _:);
  fmt.printf(
    "p=%.0f %.0f v=%.0f %.0f\n",
    Mover.pos.x[0] * 1.0,
    Mover.pos.y[0] * 1.0,
    Mover.vel.x[0] * 1.0,
    Mover.vel.y[0] * 1.0,
  );
}

#run entry
