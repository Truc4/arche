// RUN: %arche build -o %t %s && %t | grep "copied=ok commas=2"
// Branchless byte-column passes over a buffer (copy + classify). These shapes
// vectorize (data pointer hoisted once at entry, not reloaded per iteration).
// The written buffer is moved in by reference and returned; the read-only source
// is passed by value (copied in, no side effect).
#import { fmt }
copy_bytes :: func(own dst: []char, src: []char, n: i64) -> []char {
  for (i: i64 = 0; i < n; i = i + 1) {
    if (i >= dst.length) {
      break;
    }
    if (i >= src.length) {
      break;
    }
    dst[i] = src[i];
  }
  return dst;
}
classify_commas :: func(data: []char, own mask: []char, n: i64) -> []char {
  for (i: i64 = 0; i < n; i = i + 1) {
    if (i >= mask.length) {
      break;
    }
    if (i >= data.length) {
      break;
    }
    mask[i] = data[i] == 44;
  }
  return mask;
}
entry :: system {
  src: [8]char;
  src[0] = 'a';
  src[1] = ',';
  src[2] = 'b';
  src[3] = ',';
  src[4] = 'c';
  src[5] = 'd';
  src[6] = 'e';
  src[7] = 'f';
  dst: [8]char;
  dst := copy_bytes(move dst, src, 8);
  mask: [8]char;
  mask := classify_commas(src, move mask, 8);
  commas: i64 = 0;
  for (i: i64 = 0; i < 8; i = i + 1) {
    commas = commas + mask[i];
  }
  ok := 0;
  if (dst[1] == src[1]) {
    if (dst[7] == src[7]) {
      ok = 1;
    }
  }
  if (ok == 1) {
    fmt.printf("copied=ok commas=%ld\n", commas);
  }
  else {
    fmt.printf("copied=FAIL\n");
  }
}

#run entry
