// RUN: %arche -o %t %s && %t | grep "copied=ok commas=2"
// Branchless byte-column passes over a buffer (copy + classify). These shapes
// vectorize (data pointer hoisted once at entry, not reloaded per iteration).
proc copy_bytes(dst: char[], src: char[], n: i64) {
  for (i: i64 = 0; i < n; i = i + 1) {
    dst[i] = src[i];
  }
}
proc classify_commas(data: char[], mask: char[], n: i64) {
  for (i: i64 = 0; i < n; i = i + 1) {
    mask[i] = data[i] == 44;
  }
}
proc main() {
  src: char[8];
  src[0] = 'a';
  src[1] = ',';
  src[2] = 'b';
  src[3] = ',';
  src[4] = 'c';
  src[5] = 'd';
  src[6] = 'e';
  src[7] = 'f';
  dst: char[8];
  copy_bytes(dst, src, 8);
  mask: char[8];
  classify_commas(src, mask, 8);
  commas: i64 = 0;
  for (i: i64 = 0; i < 8; i = i + 1) {
    commas = commas + mask[i];
  }
  ok := 0;
  if (dst[1] == src[1]) {
    if (dst[7] == src[7]) {
      ok = 1;
    }
  }
  if (ok == 1) {
    printf("copied=ok commas=%ld\n", commas);
  } else {
    printf("copied=FAIL\n");
  }
}
