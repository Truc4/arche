// RUN: %arche build -o %t %s && %t
#import { str fmt }
check_buf :: func(buf: [32]char) -> int {
  return str.strlen(buf);
}

entry :: system eff {
  n1 := str.strlen("hello");
  fmt.printf("direct strlen: %d\n", n1);
  n2 := check_buf("hello");
  fmt.printf("function strlen: %d\n", n2);
}

#run entry
