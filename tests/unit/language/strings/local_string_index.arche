// A string literal bound to a local (`s := "hi"`) must be indexable in an int context
// (printf %d, comparisons): the char load has to promote i8 -> i32, exactly like indexing
// a `char[]` parameter does. Regression: the general index path only zero-extended when the
// base was a type-6 char slice, so a local string-literal element stayed i8 and the verifier
// rejected `i32 %v` ("defined with type 'i8' but expected 'i32'").
// RUN: %arche -o %t %s && %t | grep "c0=104 c1=105 eq=1"
proc main() {
  s := "hi";
  eq := 0;
  if (s[0] == 104) {
    eq = 1;
  }
  printf("c0=%d c1=%d eq=%d\n", s[0], s[1], eq);
}
