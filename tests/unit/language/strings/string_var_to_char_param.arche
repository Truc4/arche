// RUN: %arche build -o %t %s && %t | grep "lit=5 var=5 mid=2"
// A char[] param is a fat-pointer slice `(ptr, len)`. `str.strlen` is the real C strlen (scans to NUL).
#import { str fmt }
slen :: func(s: []char) -> int {
  return str.strlen(s);
}

entry :: system {
  lit := slen("hello");
  x   := "hello";
  var := slen(x);
  buf: [8]char;
  buf[0] = 'h';
  buf[1] = 'i';
  buf[2] = 0;
  mid := slen(buf);
  fmt.printf("lit=%d var=%d mid=%d\n", lit, var, mid);
}

#run entry
