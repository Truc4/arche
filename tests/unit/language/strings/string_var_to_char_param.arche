// RUN: %arche build -o %t %s && %t | grep "lit=5 var=5 mid=8"
// A char[] param is a fat-pointer slice `(ptr, len)`. Three sources thread their length through it:
// a literal directly, a literal-bound variable, and a fixed char[N] buffer. `strlen` is `.length`,
// so the literal forms report content length 5, and the whole `char[8]` buffer reports its size 8
// (a fixed array is N elements — content shorter than N would be a sub-slice `buf[0:n]`).
#import { str }
slen :: proc(s: char[])(r: int) {
  r = str.strlen(s);
}

main :: proc() {
  slen("hello")(lit:); // literal passed directly → length 5

  x := "hello";
  slen(x)(var:); // literal-bound variable → length 5

  buf: char[8];
  buf[0] = 'h';
  buf[1] = 'i';
  slen(buf)(mid:); // whole char[8] buffer → length 8

  printf("lit=%d var=%d mid=%d\n", lit, var, mid);
}
