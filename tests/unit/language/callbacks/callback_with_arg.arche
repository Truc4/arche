// A callback threaded through nested higher-order procs (`outer` → `inner` → `cb`),
// each monomorphized per call site; the callback arg is erased from the ABI.
// Callbacks use the (deprecated) proc-callback feature, so relax W0030 for the leaf proc callbacks.
// RUN: %arche build --proc-not-primitive=allow -o %t %s && %t | grep "hello"
#import { fmt }
h :: proc()();

hello :: proc()() {
  fmt.printf("hello\n");
}

inner :: proc(cb: h)() {
  cb()();
}

outer :: proc(cb: h)() {
  inner(cb)();
}

entry :: system eff {
  outer(hello)();
}

#run entry
