// A func (value-returning) callback: the bound func is called directly and its
// result used. Distinct funcs produce distinct specializations of `apply`.
// Callbacks use the (deprecated) proc-callback feature, so relax W0030 for the leaf proc callbacks.
// RUN: %arche build --proc-not-primitive=allow -o %t %s && %t | grep "20"
#import { fmt }
unary :: func(x: int) -> int;

dbl :: func(x: int) -> int {
  return x * 2;
}

inc :: func(x: int) -> int {
  return x + 1;
}

apply :: proc(v: int, op: unary)() {
  r := op(v);
  fmt.printf("%d\n", r);
}

entry :: system eff {
  apply(10, dbl)();
  apply(10, inc)();
}

#run entry
