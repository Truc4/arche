// Compile-time callback: a proc-typed param bound per call site, monomorphized to
// a direct call (no fn-pointer). The same `run_task` skeleton specializes for each
// continuation; the callback arg is erased from the ABI.
// Callbacks use the (deprecated) proc-callback feature, so relax W0030 for the leaf proc callbacks.
// RUN: %arche build --proc-not-primitive=allow -o %t %s && %t | grep -A1 "work=9" | grep "cleanup"
#import { fmt }
done_handler :: proc()();

finish :: proc()() {
  fmt.printf("finish\n");
}

cleanup :: proc()() {
  fmt.printf("cleanup\n");
}

run_task :: proc(work: int, on_done: done_handler)() {
  fmt.printf("work=%d\n", work);
  on_done()();
}

entry :: system eff {
  run_task(5, finish)();
  run_task(9, cleanup)();
}

#run entry
