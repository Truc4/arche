// i64 key, n>=32 → radix with 8 passes (the widest radix path) + the i64 signed-key transform. Negated
// 1..40 reverses on ascending sort.
// RUN: %arche build -o %t %s && %t | grep -qF "PASS"
#import { fmt }
k   :: i64;
tag :: int;
N   :: arche { k, tag }
[40]N(40) {
  k: 1, tag: 1
}
negk :: map (k) {
  k = 0 - k;
}
main :: proc() {
  scan(+, N.k); // 1..40 (i64)
  scan(+, N.tag); // 1..40
  run negk; // k = -1..-40
  sort(N.k); // ascending → reversal
  fmt.assert(N.tag[0] == 40, "t0\n");
  fmt.assert(N.tag[39] == 1, "t39\n");
  fmt.printf("PASS\n");
}
