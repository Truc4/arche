// Several columns of differing widths (i32 key, i32, i64, float → GEP strides 4 and 8) must all be
// permuted consistently by the cycle-following apply (catches per-column stride bugs). n=40 → radix path.
// Negated i32 key reverses the pool; each column's value at a row equals that row's ordinal, so post-sort
// they stay aligned. (Narrow i8/i16 columns share the same cycle-apply code path; their permutation is
// covered by sort_by_key-style small-n fixtures and sort_i8_key.)
// RUN: %arche build -o %t %s && %t | grep -qF "PASS"
#import { fmt }
k :: int;
a :: int;
b :: i64;
c :: float;
N :: arche { k, a, b, c }
[40]N(40) { k: 1, a: 1, b: 1, c: 1.0 }
negk :: map (k) { k = 0 - k; }
main :: proc() {
  scan(+, N.k); // 1..40
  scan(+, N.a); // 1..40
  scan(+, N.b); // 1..40 (i64)
  scan(+, N.c); // 1.0..40.0
  run negk;     // k = -1..-40
  sort(N.k);    // reversal; original row 39 → position 0
  b0 := N.b[0];
  fmt.assert(N.a[0] == 40, "a0\n");
  fmt.assert(b0 == 40, "b0\n");
  fmt.assert(N.a[39] == 1, "a39\n");
  fmt.assert(N.c[0] > N.c[39], "c\n"); // 40.0 > 1.0
  fmt.printf("PASS\n");
}
