// CTFE folds nested pure-func calls and `const` arguments, and a `const` whose value is itself a
// func of constants. `add(area(SZ,4), 0)` → add(12,0) → 12.
// RUN: %arche build -o %t %s && %t | grep "ok"
#import { fmt }
SZ   :: 3;
area :: func(w: int, h: int) -> int {
  return w * h;
}
add :: func(a: int, b: int) -> int {
  return a + b;
}
MAX  :: area(SZ, 4);
Grid :: arche { cell :: int }
[add(area(SZ, 4), 0)]Grid(MAX) {
  cell: 0,
}
entry :: system eff {
  fmt.assert(Grid.cell[11] == 0, "capacity should fold to 12\n")();
  fmt.printf("ok MAX=%d\n", MAX);
}

#run entry
