proc main() {
  let fd := arche_fopen_read("design_analysis/benchmarks/etl/data/data_10m.csv");

  if (fd > 0) {
    let line: char[256];
    let qty_str: char[32];

    arche_fread_line(fd, line, 256);

    let idx := 0;
    for (;idx < 20;) {
      let n := arche_fread_line(fd, line, 256);
      if (n <= 0) {
        break;
      }

      let line_pos := 0;
      let field_idx := 0;
      let c2 := 0;
      let c3 := 0;

      for (;line_pos < n;) {
        if (line[line_pos] == ',') {
          field_idx = field_idx + 1;
          if (field_idx == 2) { c2 = line_pos; }
          if (field_idx == 3) { c3 = line_pos; }
        }
        line_pos = line_pos + 1;
      }

      let j := 0;
      let i := 0;
      for (;i < c3 - c2 - 1;) {
        qty_str[j] = line[c2 + 1 + i];
        j = j + 1;
        i = i + 1;
      }
      qty_str[j] = 0;

      let qty := atoi(qty_str);
      printf("Line %d: qty_str='%s' qty=%d c2=%d c3=%d n=%d\n", idx, qty_str, qty, c2, c3, n);

      idx = idx + 1;
    }

    arche_fclose(fd);
  }
}
