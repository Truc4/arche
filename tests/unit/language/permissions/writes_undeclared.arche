// Writing a bound column the `(writes)` list omits is a hard error (E0227): here the body writes both `a`
// and `b` but declares only `(a)`.
// RUN: not %arche build -o %t %s 2>&1 | grep -qF "omits"
a :: float;
b :: float;
R :: arche { a, b }
[4]R(4);
k :: map (query { a, b }) (a) { a = a + 1.0; b = b + 1.0; }
#run seq({ k })
