// A run-once `system` (no selector) writing a pool column directly by whole-column init (`R.v = { … }`) is
// bulk initialization, NOT a selector-bound per-element write — it needs no `(writes)` permission.
// RUN: %arche build -o %t %s && %t | grep -qF "v3=4"
#import { fmt }
v :: float;
R :: arche { v }
[4]R(4);
seed :: system { R.v = { 1.0, 2.0, 3.0, 4.0 }; }
show :: system eff { fmt.printf("v3=%.0f\n", R.v[3] * 1.0); }
#run seq({ seed, show })
