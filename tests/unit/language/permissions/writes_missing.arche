// A selector kernel that assigns a bound column but declares no `(writes)` permission is a hard error
// (E0227 write_set_mismatch); the message names the inferred write-set.
// RUN: not %arche build -o %t %s 2>&1 | grep -qF "declares no"
v :: float;
R :: arche { v }
[4]R(4);
bump :: map (query { v }) { v = v + 1.0; }
#run seq({ bump })
