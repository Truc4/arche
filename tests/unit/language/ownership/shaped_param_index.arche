// A sized char[N] parameter indexes like an unbounded char[], readable inside a func.
// RUN: %arche build -o %t %s && %t | grep "head=72 sum=105"
#import { fmt }
head :: func(buf: [8]char) -> int {
  return buf[0];
}

entry :: system eff {
  b: [8]char;
  b[0] = 72;
  b[1] = 33;
  fmt.printf("head=%d ", head(b));
  total := 0;
  for (i := 0; i < 2; i = i + 1) {
    total = total + b[i];
  }
  fmt.printf("sum=%d\n", total);
}

#run entry
