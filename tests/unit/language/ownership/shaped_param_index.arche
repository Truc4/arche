// A sized char[N] parameter indexes like an unbounded char[] — readable inside both a
// func and a proc. (Passed plainly it is copied in; mutations would not leak without `move`.)
// RUN: %arche build -o %t %s && %t | grep "head=72 sum=105"
#import { fmt }
head :: func(buf: char[8]) -> int {
  return buf[0];
}
dump :: proc(buf: char[8]) {
  total := 0;
  for (i := 0; i < 2; i = i + 1) {
    total = total + buf[i];
  }
  fmt.printf("sum=%d\n", total);
}

main :: proc() {
  b: char[8];
  b[0] = 72;
  b[1] = 33;
  fmt.printf("head=%d ", head(b));
  dump(b);
}
