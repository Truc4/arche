// `buf := foo(move buf)`: `move` kills the old binding; `:=` rebinds a fresh `buf` (a shadow)
// to the returned buffer. Works for a string fill and for in-place mutation, and the rebound
// name indexes correctly afterward.
// RUN: %arche build -o %t %s && %t | grep "a=hi b0=11"
fill :: func (own buf: char[16]) -> char[16] {
  return strcopy(move buf, "hi");
}
bump :: func (own buf: char[16]) -> char[16] {
  buf[0] = buf[0] + 1;
  return buf;
}

main :: proc () {
  a: char[16];
  a := fill(move a);
  b: char[16];
  b[0] = 10;
  b := bump(move b);
  printf("a=%s b0=%d\n", a, b[0]);
}
