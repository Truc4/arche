// A static global buffer filled directly in a system (was a proc in-out param).
// RUN: %arche build --exported-mutable=allow -o %t %s && %t | grep "b0=88 b1=89 n=2"
#import { fmt }
sbuf: [16]char;

entry :: system {
  sbuf[0] = 88;
  sbuf[1] = 89;
  n := 2;
  fmt.printf("b0=%d b1=%d n=%d\n", sbuf[0], sbuf[1], n);
}

#run entry
