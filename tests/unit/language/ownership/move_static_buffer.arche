// A static buffer can be moved into a fill proc by reference (in-out). The *name*'s binding
// dies at the `move` and is revived from the out-arg; the global storage persists the whole
// time (no leak, no copy). Then the revived name indexes the filled bytes.
// RUN: %arche -o %t %s && %t | grep "b0=88 b1=89 n=2"
static sbuf: char[16];

proc fill2(own buf: char[16])(buf: char[16], n: int) {
  buf[0] = 88;
  buf[1] = 89;
  n = 2;
}

proc main() {
  fill2(move sbuf)(sbuf, n:);
  printf("b0=%d b1=%d n=%d\n", sbuf[0], sbuf[1], n);
}
