// A static buffer can be filled by reference through an in-out param (no `own`, no `move`): the
// out occurrence shadows the in-list borrow, so the proc writes the caller's buffer in place and
// hands the same live binding back. The global storage persists the whole time (no leak, no
// copy). Then the name indexes the filled bytes.
// RUN: %arche build -o %t %s && %t | grep "b0=88 b1=89 n=2"
#import { fmt }
sbuf: char[16]

fill2 :: proc(buf: char[16])(buf: char[16], n: int) {
  buf[0] = 88;
  buf[1] = 89;
  n = 2;
}

main :: proc() {
  fill2(sbuf)(sbuf, n:);
  fmt.printf("b0=%d b1=%d n=%d\n", sbuf[0], sbuf[1], n);
}
