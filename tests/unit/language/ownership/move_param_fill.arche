// An in-out array param (same name in both lists) is the by-reference fill contract: the out
// occurrence shadows the in-list borrow, so the proc fills the caller's buffer IN PLACE with no
// `own` and no `move` — the binding is never killed, and the out-arg reuses it. This is the
// canonical fill-buffer / FFI shape.
// RUN: %arche build -o %t %s && %t | grep "filled=hello n=5"
#import { fmt }
fill :: proc(buf: [32]char, s: []char)(buf: [32]char, n: int) {
  i := 0;
  for (; i < s.length; i += 1) {
    if (i >= 32) {
      break;
    }
    buf[i] = s[i];
  }
  if (i >= 0 && i < 32) {
    buf[i] = 0; // NUL-terminate the filled buffer for the `%s` fmt.print (an FFI convenience the user writes)
  }
  n = i;
}

entry :: system {
  b: [32]char;
  fill(b, "hello")(b, n:);
  fmt.printf("filled=%s n=%d\n", b, n);
}

#run entry
