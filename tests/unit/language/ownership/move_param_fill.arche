// A `move` param is the by-reference fill contract: the caller MUST pass `move buf`
// (no silent copy), the function fills it in place, and hands it back through the return.
// This is the canonical fill-buffer / FFI shape.
// RUN: %arche -o %t %s && %t | grep "filled=hello n=5"
func fill(own buf: char[32], s: char[]) -> (char[32], int) {
  i := 0;
  for (;
  s[i] != 0;
  ) {
    buf[i] = s[i];
    i = i + 1;
  }
  buf[i] = 0;
  return buf, i;
}

proc main() {
  b: char[32];
  b, n := fill(move b, "hello");
  printf("filled=%s n=%d\n", b, n);
}
