// A buffer filled via a func `own` param (was a proc in-out param / FFI fill shape).
// RUN: %arche build -o %t %s && %t | grep "filled=hello n=5"
#import { fmt str }
fill :: func(own buf: [32]char, s: []char) -> [32]char {
  i := 0;
  for (; i < s.length; i += 1) {
    if (i >= 32) {
      break;
    }
    buf[i] = s[i];
  }
  if (i >= 0 && i < 32) {
    buf[i] = 0;
  }
  return buf;
}

entry :: system {
  b: [32]char;
  r := fill(move b, "hello");
  n := str.strlen(r);
  fmt.printf("filled=%s n=%d\n", r, n);
}

#run entry
