// `copy x` hands the function an owned duplicate; the caller keeps its original unchanged.
// (Contrast `move`, which donates the buffer by reference with no copy.) `strcopy` returns the
// filled prefix as a `char[]` content slice — a normal `(ptr, len)` array, no NUL — read by index.
// RUN: %arche build -o %t %s && %t | grep "src0=104 src1=105 out0=121 out1=111 outlen=2"
#import { str fmt }
fill :: func(own b: [8]char, s: []char) -> []char {
  return str.strcopy(move b, s);
}

entry :: system {
  src: [8]char;
  src[0] = 'h';
  src[1] = 'i';
  out := fill(copy src, "yo"); // copy: src untouched; out is the filled duplicate "yo"
  fmt.printf(
    "src0=%d src1=%d out0=%d out1=%d outlen=%d\n",
    src[0],
    src[1],
    out[0],
    out[1],
    out.length,
  );
}

#run entry
