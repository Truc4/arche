// `copy x` hands the function an owned duplicate; the caller keeps its original unchanged.
// (Contrast `move`, which donates the buffer by reference with no copy.)
// RUN: %arche -o %t %s && %t | grep "src=hi out=yo"
func fill(own b: char[8], s: char[]) -> char[8] {
  i := 0;
  for (;
  s[i] != 0;
  ) {
    b[i] = s[i];
    i = i + 1;
  }
  b[i] = 0;
  return b;
}

proc main() {
  src: char[8];
  sprintf(src, "%s", "hi");
  out := fill(copy src, "yo");
  printf("src=%s out=%s\n", src, out);
}
