// `move buf` transfers ownership of a (non-opaque) buffer and kills the binding:
// using it afterward is a compile error. A moved value comes back only through a
// return value (`buf, n := f(move buf)`).
// RUN: %arche -o %t %s > %t.out 2>&1 ; grep -qi "consumed" %t.out
func take(b: char[8]) -> int {
  return 0;
}

proc main() {
  buf: char[8];
  buf[0] = 'A';
  n := take(move buf);
  printf("%d\n", buf[0]);
}
