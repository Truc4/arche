// A by-value (non-move) array argument is COPIED at the call site: the callee's
// mutations do NOT leak back to the caller. Functions have no side effects unless
// you `move`. (arche -> arche call.)
// RUN: %arche -o %t %s && %t | grep "ok"
func clobber(b: char[8]) -> int {
  b[0] = 'X';
  return 0;
}

proc main() {
  buf: char[8];
  buf[0] = 'A';
  clobber(buf);
  assert(buf[0] == 'A', "caller buf must be unchanged after by-value call\n");
  printf("ok\n");
}
