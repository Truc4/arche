// Regression: `a = b` (assign, not bind) on array values must MOVE — the target takes over the
// source's storage — not silently store garbage (it used to print an uninitialized scalar). Mirrors
// `a := b`: a gets b's data, b is consumed. Consistency between `=` and `:=` for move-only types.
// RUN: %arche build -o %t %s && %t | grep -q "a0=7"
#import { fmt }
entry :: system {
  a : [3]int;
  b : [3]int;
  b[0] = 7;
  a    = b; // move: a now owns b's storage, b is consumed
  fmt.printf("a0=%d\n", a[0]);
}

#run entry
