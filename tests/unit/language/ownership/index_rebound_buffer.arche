// A buffer filled in place through a proc's in-out param (`f(b)(b, n:)`) must be indexable in
// the caller — the CSV reader fills a buffer then scans it byte by byte.
// RUN: %arche build -o %t %s && %t | grep "c0=72 c1=105 n=2"
fill :: proc(buf: char[32], s: char[])(buf: char[32], n: int) {
  i := 0;
  for (; s[i] != 0; i += 1) {
    buf[i] = s[i];
  }
  buf[i] = 0;
  n = i;
}

main :: proc() {
  b: char[32];
  fill(b, "Hi")(b, n:);
  c0 := b[0];
  c1 := b[1];
  printf("c0=%d c1=%d n=%d\n", c0, c1, n);
}
