// A buffer that comes back through a multi-return (`b, n := f(move b)`) must be
// indexable in the caller — the CSV reader fills a buffer then scans it byte by byte.
// RUN: %arche -o %t %s && %t | grep "c0=72 c1=105 n=2"
func fill(own buf: char[32], s: char[]) -> (char[32], int) {
  i := 0;
  for (;
  s[i] != 0;
  ) {
    buf[i] = s[i];
    i = i + 1;
  }
  buf[i] = 0;
  return buf, i;
}

proc main() {
  b: char[32];
  b, n := fill(move b, "Hi");
  c0 := b[0];
  c1 := b[1];
  printf("c0=%d c1=%d n=%d\n", c0, c1, n);
}
