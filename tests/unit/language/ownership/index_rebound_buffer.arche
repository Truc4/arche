// A buffer filled in place through a proc's in-out param (`f(b)(b, n:)`) must be indexable in
// the caller — the CSV reader fills a buffer then scans it byte by byte.
// RUN: %arche build -o %t %s && %t | grep "c0=72 c1=105 n=2"
#import { fmt }
fill :: proc(buf: [32]char, s: []char)(buf: [32]char, n: int) {
  i := 0;
  for (; i < s.length; i += 1) {
    if (i >= 32) {
      break;
    }
    buf[i] = s[i];
  }
  if (i >= 0 && i < 32) {
    buf[i] = 0;
  }
  n = i;
}

main :: proc() {
  b: [32]char;
  fill(b, "Hi")(b, n:);
  c0 := b[0];
  c1 := b[1];
  fmt.printf("c0=%d c1=%d n=%d\n", c0, c1, n);
}
