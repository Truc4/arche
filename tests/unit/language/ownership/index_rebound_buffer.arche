// A buffer filled in place via a func `own` param, then indexed in the caller (was a proc in-out param).
// RUN: %arche build -o %t %s && %t | grep "c0=72 c1=105 n=2"
#import { fmt str }
fill :: func(own buf: [32]char, s: []char) -> [32]char {
  i := 0;
  for (; i < s.length; i += 1) {
    if (i >= 32) {
      break;
    }
    buf[i] = s[i];
  }
  if (i >= 0 && i < 32) {
    buf[i] = 0;
  }
  return buf;
}

entry :: system {
  b: [32]char;
  r := fill(move b, "Hi");
  n := str.strlen(r);
  fmt.printf("c0=%d c1=%d n=%d\n", r[0], r[1], n);
}

#run entry
