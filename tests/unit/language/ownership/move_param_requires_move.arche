// A `move` parameter is the by-reference contract: the caller MUST write `move`, so the
// hand-off is always visible (no silent copy). Passing a bare name is a compile error.
// Works for any type (this is a plain data buffer, not opaque).
// RUN: %arche -o %t %s > %t.out 2>&1 ; grep -qi "must be moved" %t.out
proc sink(own buf: char[]) {
  buf[0] = 'X';
}

proc main() {
  b: char[8];
  sink(b);
}
