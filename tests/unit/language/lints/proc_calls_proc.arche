// W0028 proc_calls_proc: the flat-effect procâ†’proc ban. A proc body calling another (non-extern) proc
// warns (default) and steers the author to build an Eff in a func instead. Calls to extern/func/map are
// fine, and a `system` calling a proc is fine (only procâ†’proc is banned). `@allow(proc_calls_proc)`
// suppresses; `--proc-leaf=allow` disables; `--proc-leaf=error` promotes to a hard error.
// Exactly one un-suppressed procâ†’proc here (main â†’ leaf); quietâ†’leaf is @allow'd, bootâ†’quiet is systemâ†’proc.
// RUN: %arche check %s 2>&1 | grep -q "proc_calls_proc.*leaf"
// RUN: test "$(%arche check %s 2>&1 | grep -c proc_calls_proc)" -eq 1
// RUN: test "$(%arche check --proc-leaf=allow %s 2>&1 | grep -c proc_calls_proc)" -eq 0
// RUN: test "$(%arche check --proc-leaf=error %s 2>&1 | grep -c "Lint error \[proc_calls_proc\]")" -eq 1
#import { fmt }

helper :: func(x: int) -> int {
  return x + 1;
}

leaf :: proc() {
  fmt.printf("leaf\n"); // proc â†’ extern: fine
}

@allow(proc_calls_proc)
quiet :: proc() {
  leaf(); // proc â†’ proc, but @allow'd â†’ silent
}

boot :: system {
  quiet(); // system â†’ proc: fine
}

main :: proc() {
  v := helper(1); // proc â†’ func: fine
  fmt.printf("%d\n", v);
  leaf(); // proc â†’ proc â†’ the one W0028
}
