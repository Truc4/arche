// RUN: %arche build -o %t %s && %t
#import { io fmt }
entry :: system eff {
  io.fopen_read("../../../../../tests/fixtures/data.csv")(fd:);
  buf: [256]char;
  io.fread(fd, 256)(buf, rd_v:);
  v := buf[0: rd_v];
  io.fclose(move fd)(_:);
  fmt.printf("read 256 returned: %d\n", v.length);
  fmt.assert(v.length == 256, "should read 256 bytes\n")();
}

#run entry
