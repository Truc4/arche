// RUN: %arche build -o %t %s && %t
#import { io fmt }
main :: proc() {
  io.fopen_read("../../../../../tests/fixtures/data.csv")(fd:);
  buf: char[256];
  io.fread(fd, buf, 256)(buf, n:);
  io.fclose(move fd);
  fmt.printf("read 256 returned: %d\n", n);
  fmt.assert(n == 256, "should read 256 bytes\n");
}
