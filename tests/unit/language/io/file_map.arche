// RUN: printf 'a,bb,ccc\n' > /tmp/file_map.txt && %arche build -o %t %s && %t | grep "size=9 commas=2"
// io.file_map mmaps a whole file and returns a raw byte view (char[]) scanned with i64 offsets. The
// public wrapper — io's raw `arche_file_*` C externs are private to the device.
#import { io fmt }
main :: proc() {
  io.file_map("/tmp/file_map.txt")(data:);
  io.file_size()(size: i64);
  commas: i64 = 0;
  for (i: i64 = 0; i < size; i = i + 1) {
    if (data[i] == ',') {
      commas = commas + 1;
    }
  }
  fmt.printf("size=%ld commas=%ld\n", size, commas);
  io.file_unmap(move data, size);
}
