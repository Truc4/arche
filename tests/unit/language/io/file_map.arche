// RUN: printf 'a,bb,ccc\n' > /tmp/file_map.txt && %arche -o %t %s && %t | grep "size=9 commas=2"
// arche_file_map returns a raw byte view (char[]) scanned with i64 offsets.
proc main() {
  data := arche_file_map("/tmp/file_map.txt");
  size: i64 = arche_file_size();
  commas: i64 = 0;
  for (i: i64 = 0; i < size; i = i + 1) {
    if (data[i] == ',') {
      commas = commas + 1;
    }
  }
  printf("size=%ld commas=%ld\n", size, commas);
  arche_file_unmap(data, size);
}
