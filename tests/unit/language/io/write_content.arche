// RUN: %arche build -o %t %s && %t && test -f /tmp/arche_test_write.txt && grep -q "test123" /tmp/arche_test_write.txt && echo "PASS"
#import { io fmt }
main :: proc() {
  io.fopen_write("/tmp/arche_test_write.txt")(fd:);
  buf: [32]char;
  fmt.sprintf(buf, "test123\n")(buf, n:);
  io.fwrite(fd, move buf, n);
  io.fclose(move fd);
  fmt.printf("done\n");
}
