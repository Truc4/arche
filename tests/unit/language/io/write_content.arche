// RUN: %arche -o %t %s && %t && test -f /tmp/arche_test_write.txt && grep -q "test123" /tmp/arche_test_write.txt && echo "PASS"
proc main() {
  fd := arche_fopen_write("/tmp/arche_test_write.txt");
  buf: char[32];
  n := sprintf(buf, "test123\n");
  arche_fwrite(fd, buf, n);
  arche_fclose(move fd);
  printf("done\n");
}
