// RUN: %arche build -o %t %s && %t
#import { io fmt }
cb      :: char;
CharBuf :: arche { cb }
[10000]CharBuf;
entry :: system {
  io.fopen_read("../../../../../tests/fixtures/data.csv")(fd:);
  scratch := CharBuf.cb[0: CharBuf.capacity]; // slice-local OUT (lint-only: column write outside a query)
  io.fread(fd, 10000)(scratch, rd_data:);
  data := CharBuf.cb[0: rd_data];
  io.fclose(move fd)(_:);
  fmt.printf("requested 10000, got: %d\n", data.length);
}

#run entry
