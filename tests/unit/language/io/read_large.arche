// RUN: %arche build -o %t %s && %t
#import { io fmt }
cb      :: char;
CharBuf :: arche { cb }
[10000]CharBuf;
main :: proc() {
  io.fopen_read("../../../../../tests/fixtures/data.csv")(fd:);
  io.fread(fd, CharBuf.cb[0: CharBuf.capacity], 10000)(data:);
  io.fclose(move fd);
  fmt.printf("requested 10000, got: %d\n", data.length);
}
