// WANT: codegen hoists archetype struct-type definitions, so an archetype/pool may be declared
// AFTER the functions that use it (e.g. behind a `#module` banner) — like every other top-level
// name. Today codegen emits the struct type in source order, so def-after-use produces LLVM IR the
// optimizer rejects: `opt: base element of getelementptr must be sized` (the type is still opaque
// where it's GEP'd). This is exactly what breaks stdlib/router once its data model sits behind
// `#module`. A 2-column pool used before its declaration is the minimal repro.
// RUN: %arche build -o %t %s && %t | grep -q "ab=5,7"
#import { fmt }
main :: proc() {
  T.a[0] = 5;
  T.b[0] = 7;
  fmt.printf("ab=%d,%d\n", T.a[0], T.b[0]);
}

#module
T :: arche { a :: int, b :: int }

[4] T(4);
