// An immutable `::` value const is NOT mutable state — it stays legal on the exported surface, so
// W0022 never fires on it (only mutable scalar/buffer globals are banned).
// RUN: %arche build -o %t %s 2>%t.err && %t | grep -q "max=100"
// RUN: test $(grep -c exported_mutable_global %t.err) -eq 0
#import { fmt }
MAX :: 100;

entry :: system eff {
  fmt.printf("max=%d\n", MAX);
}

#run entry
