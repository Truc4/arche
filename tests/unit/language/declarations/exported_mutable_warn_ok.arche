// --exported-mutable=warn demotes W0022 to a warning: the build SUCCEEDS and the program runs, but
// the lint is still reported on stderr.
// RUN: %arche build --exported-mutable=warn -o %t %s 2>%t.err && %t | grep -q "ok"
// RUN: grep -qi "Lint warning \[exported_mutable_global\]" %t.err
#import { fmt }
count := 0;

main :: proc() {
  count = count + 1;
  fmt.print("ok\n");
}
