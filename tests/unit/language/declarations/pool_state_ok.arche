// A pool is the blessed home for global mutable state — W0022 does not fire on a pool (the world's
// columnar storage), only on loose scalar/buffer mutables. The pool here is exported and mutable yet
// clean.
// RUN: %arche build -o %t %s 2>%t.err && %t | grep -q "ok"
// RUN: test $(grep -c exported_mutable_global %t.err) -eq 0
#import { fmt }
val     :: int;
Counter :: arche { val }
[4]Counter(1) {
  val: 7
}

entry :: system eff {
  fmt.print("ok\n")(_:);
}

#run entry
