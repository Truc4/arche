// WANT: a global initializer may be any compile-time-known value — here a value const. The const
// `::` and the mutable `=` interoperate: `limit` is mutable, seeded from the constant MAX.
// RUN: %arche build --exported-mutable=allow -o %t %s && %t | grep -q "limit=100"
#import { fmt }
MAX :: 100;

limit: int = MAX;

entry :: system {
  fmt.printf("limit=%d\n", limit);
}

#run entry
