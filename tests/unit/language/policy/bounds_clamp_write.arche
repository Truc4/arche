// The write-site form `a[i] !clamp = v` attaches the policy to the indexed lvalue (the op that can
// fail), not to the value. An OOB write is remapped into [0, len) and stored there — no abort. Here
// the OOB write a[9] lands in a[3]; the in-bounds reads confirm it.
// RUN: %arche build -o %t %s && %t | grep -qF "a3=99"
#import { fmt }

@policy(bounds) clamp :: policy(len: int, i: int) -> int {
  if (i < 0) { return 0; }
  if (i >= len) { return len - 1; }
  return i;
}

main :: proc() {
  a: int[4];
  a[0] = 1;
  a[9] !clamp = 99; // OOB write -> a[3]
  fmt.printf("a3=%d\n", a[3]);
}
