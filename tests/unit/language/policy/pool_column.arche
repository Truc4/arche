// Failure policies apply to POOL-COLUMN indexing (`Arch.field[i]`), not just value arrays/slices.
// `!undefined` reads raw (no check), `!abort` (the proc default) bounds-checks against the live count,
// `!clamp` remaps an OOB index into [0, count). (`!zero` is divide-only — a bounds site rejects it.)
// An explicit policy also silences the (now default-off) raw_pool_index lint — it IS the acknowledgment.
// (exercises `!undefined` among the policies, so opt into the raw op)
// RUN: %arche build --allow-undefined -o %t %s && %t | grep -qF "undef=20 clamp=20 w1=99"
#import { fmt }
P :: arche { v :: int }
[8]P;
entry :: system eff {
  insert(P { v: 10 })(h0:, ok0:);
  insert(P { v: 20 })(h1:, ok1:); // live count is 2: slots 0,1
  ix  := 1;
  oob := 5;
  u   := P.v[ix] !undefined; // raw, in range -> 20
  c   := P.v[oob] !clamp; // OOB -> clamp into [0,2) -> slot 1 -> 20
  P.v[ix] !clamp = 99; // in range -> slot 1 = 99
  fmt.printf("undef=%d clamp=%d w1=%d\n", u, c, P.v[1] !undefined);
}

#run entry
