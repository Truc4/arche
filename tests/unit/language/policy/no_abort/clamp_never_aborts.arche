// THE GUARANTEE: a program that contains NO `!abort` and deliberately triggers OOB reads through a
// total policy must run to completion (exit 0) — a total policy can never abort. This is the inverse
// of the *_array_oob tests (which assert the default !abort DOES abort). Several wild OOB indices,
// all clamped, program exits cleanly.
// RUN: %arche build -o %t %s && %t
@policy(bounds) clamp :: policy(len: int, i: int) -> int {
  if (i < 0) { return 0; }
  if (i >= len) { return len - 1; }
  return i;
}

main :: proc() {
  a: int[4];
  a[0] = 1;
  a[3] = 4;
  s := 0;
  s = s + a[99] !clamp;  // -> a[3]
  s = s + a[0 - 7] !clamp; // negative -> a[0]
  s = s + a[4] !clamp;   // just past end -> a[3]
}
