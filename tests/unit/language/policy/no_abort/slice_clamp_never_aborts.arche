// THE GUARANTEE: a slice with NO `!abort`, sliced wildly out of range through `!clamp`, runs to
// completion (exit 0) — the clamp nets lo,hi into [0, len], never aborting.
// RUN: %arche build -o %t %s && %t
main :: proc() {
  a: [4]int;
  a[0] = 1;
  lo := 0 - 5;
  hi := 99;
  v  := a[lo: hi] !clamp; // clamps to the full [0,4] view, no abort
}
