// THE GUARANTEE: insert's mandatory `(h:, ok:)` report form is total — inserting into a FULL pool
// sets ok=0 instead of aborting. A program that overflows a pool this way runs to completion (exit
// 0). (This is the `!reject` behavior; the report form is total by construction.)
// RUN: %arche build -o %t %s && %t
Particle :: arche { pos :: float }
[2]Particle;
main :: proc() {
  insert(Particle, 1.0)(h1:, ok1:);
  insert(Particle, 2.0)(h2:, ok2:);
  insert(Particle, 3.0)(h3:, ok3:); // pool full -> ok3 == 0, no abort
  delete(h1)(_:);
}