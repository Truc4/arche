// Handler resolution precedence: per-call `?name` › the pool's declared `?name` › `reject`. Here the
// pool declares `?evict_oldest`, but a call site overrides with `?reject`, so that insert rejects
// (ok=0) instead of evicting — the oldest slot is left untouched.
// (reads results with `!undefined`, so opt into the raw op)
// RUN: %arche build --allow-undefined -o %t %s && %t | grep -qF "ok2=0 v0=10"
#import { fmt }
Foo :: arche { v :: int, ts :: int }
[2]Foo ?evict_oldest;
@policy(pool)
evict_oldest :: policy(count: int, cap: int, ok: int, slot: int) {
  if (count >= cap) {
    oldest := 0;
    for (j := 1; j < count; j = j + 1) {
      if (Foo.ts[j] < Foo.ts[oldest]) {
        oldest = j;
      }
    }
    slot = oldest;
  }
}
entry :: system eff {
  insert(Foo { v: 10, ts: 5 })(h0:, ok0:);
  insert(Foo { v: 20, ts: 9 })(h1:, ok1:);
  insert(Foo { v: 30, ts: 7 }) ?reject(h2:, ok2:); // per-call override: reject, not evict
  fmt.printf("ok2=%d v0=%d\n", ok2, Foo.v[0] !undefined); // slot 0 unchanged
}

#run entry
