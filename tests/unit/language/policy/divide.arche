// Divide/mod failure policy (`n / d !zero`, `n % d !zero`): a macro inlined over (a, b) — `zero`
// sets a=0,b=1 when b==0, so n/0 yields 0 (no UB/trap). In range, normal arithmetic.
// RUN: %arche build -o %t %s && %t | grep -qF "z=0 ok=3 m=0 mok=1"
#import { fmt }
entry :: system eff {
  n  := 10;
  d  := 0;
  d2 := 3;
  fmt.printf("z=%d ok=%d m=%d mok=%d\n", n / d !zero, n / d2 !zero, n % d !zero, n % d2 !zero);
}

#run entry
