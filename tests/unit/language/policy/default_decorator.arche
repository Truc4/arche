// `@default(<kind>, <category>, <policy>)` is a program-wide directive: it sets the failure policy
// that an UNANNOTATED fallible op of that (effect-kind, op-category) cell takes, overriding the
// baseline (here proc/bounds, normally → abort). It names a core policy (`clamp`) by name; one per
// cell program-wide. So an OOB index in a proc clamps into range instead of aborting.
// RUN: %arche build -o %t %s && %t | grep -qF "d=13"
#import { fmt }
@default(proc, bounds, clamp)
hot :: proc() {
  a: int[4];
  a[3] = 13;
  i    := 99;
  fmt.printf("d=%d\n", a[i]); // unannotated -> @default(proc, bounds, clamp) -> a[3]=13, no abort
}
main :: proc() {
  hot();
}
