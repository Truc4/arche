// `@default(name)` sets the failure policy a proc/func's UNANNOTATED fallible ops take, overriding the
// baseline (procâ†’abort, funcâ†’clamp). Here a proc opts into `clamp` so an OOB index doesn't abort.
// RUN: %arche build -o %t %s && %t | grep -qF "d=13"
#import { fmt }
@default(clamp) hot :: proc() {
  a: int[4]; a[3] = 13;
  i := 99;
  fmt.printf("d=%d\n", a[i]);   // unannotated -> @default(clamp) -> a[3]=13, no abort
}
main :: proc() { hot(); }
