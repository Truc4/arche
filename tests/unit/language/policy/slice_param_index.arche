// Indexing a SLICE PARAMETER (`s[i]`) is policy-covered against the fat-pointer `.len`. `!clamp` remaps
// OOB. The OOB write is inlined into the system now that procs are gone.
// RUN: %arche build -o %t %s && %t | grep -qF "read=13 wrote=77"
#import { fmt }
rd :: func(s: []int, i: int) -> int {
  return s[i] !clamp;
}

entry :: system eff {
  a: [4]int;
  a[0] = 10;
  a[1] = 11;
  a[2] = 12;
  a[3] = 13;
  v   := a[0: 4];
  big := 99;
  r   := rd(v, big);
  a[big] !clamp = 77;
  fmt.printf("read=%d wrote=%d\n", r, a[3]);
}

#run entry
