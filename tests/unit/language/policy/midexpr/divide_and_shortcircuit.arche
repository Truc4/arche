// MID-EXPRESSION CONTROL FLOW (divide): a divide policy in the RHS of `&&` must stay inside the
// short-circuit path. `argc < 0` is false, so `10 / d !abort` (d==0) must never evaluate -> exit 0.
// Same path as the bounds case: the inlined `if (b==0) {…_exit…}` prelude is emitted into the `&&`
// RHS block, so it runs only when the LHS is true.
// RUN: %arche build -o %t %s && %t
main :: proc(argc: int) {
  d := argc - argc;                              // 0 at runtime, opaque to the folder
  if (argc < 0 && (10 / d !abort) == 0) { }      // LHS false -> RHS divide must not run
}
