// A fallible index the bounds prover proves in-bounds (guard-exits, or a loop bound) carries NO
// implicit policy, so the analyzer emits NO ghost `!clamp`/`!abort` inlay on it. An unproven index
// still gets one. (Regression for the inlay respecting the prover's verdict.)
// RUN: %build/arche-analyzer --dump %s > %t.out 2>/dev/null
// the bare unproven index DOES get a ghost !clamp:
// RUN: grep -qF "policy !clamp" %t.out
// the guard-proven index on line 18 gets NONE:
// RUN: ! grep -qE "^SYN 18 [0-9]+ 0 0 policy" %t.out
// the loop-proven index on line 23 gets NONE:
// RUN: ! grep -qE "^SYN 23 [0-9]+ 0 0 policy" %t.out
guarded :: func(s: char[], i: int) -> int {
  if (i < 0) {
    return 0;
  }
  if (i >= s.length) {
    return 0;
  }
  return s[i];
}
summed :: func(s: char[]) -> int {
  acc := 0;
  for (i := 0; i < s.length; i = i + 1) {
    acc = acc + s[i];
  }
  return acc;
}
bare :: func(s: char[], i: int) -> int {
  return s[i];
}
