// Eviction correctness falls out of the generation system: overwriting a victim slot bumps its
// generation, so the evicted entity's old handle goes STALE. Using it (here `delete`) aborts, exactly
// like a normal use-after-free. (Companion to pool_evict, which checks the value side.)
// RUN: %arche build -o %t %s && ! %t
Foo :: arche { v :: int, ts :: int }
[2]Foo ?evict_oldest;
@policy(pool)
evict_oldest :: policy (count: int, cap: int, ok: int, slot: int) {
  if (count >= cap) {
    oldest := 0;
    for (j := 1; j < count; j = j + 1) {
      if (Foo.ts[j] < Foo.ts[oldest]) {
        oldest = j;
      }
    }
    slot = oldest;
  }
}
main :: proc() {
  insert(Foo { v: 10, ts: 5 })(h0:, ok0:);
  insert(Foo { v: 20, ts: 9 })(h1:, ok1:);
  insert(Foo { v: 30, ts: 7 })(h2:, ok2:); // evicts slot 0 -> h0 is now stale
  delete(h0)(okd:); // use-after-evict -> abort
}
