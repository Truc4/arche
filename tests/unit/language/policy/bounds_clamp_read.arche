// A `@policy(bounds)` decl provides the failure resolution for an out-of-bounds index. `a[i] !clamp`
// remaps an OOB read into [0, len) using the user policy `clamp`, then the compiler's net guarantees
// the result is in range — so the read NEVER aborts. Here a[9] on a length-4 array clamps to a[3].
// RUN: %arche build -o %t %s && %t | grep -qF "clamped=13"
#import { fmt }

@policy(bounds) clamp :: policy(len: int, i: int) -> int {
  if (i < 0) { return 0; }
  if (i >= len) { return len - 1; }
  return i;
}

main :: proc() {
  a: int[4];
  a[0] = 10;
  a[1] = 11;
  a[2] = 12;
  a[3] = 13;
  x := a[9] !clamp; // OOB -> clamp to index 3
  fmt.printf("clamped=%d\n", x);
}
