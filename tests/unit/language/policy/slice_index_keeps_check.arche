// Bounds-check elision boundary: a CONSTANT index into a sized value-array const is proven in-bounds
// and elided (no `!abort` ghost), but an index into a `[]T` SLICE keeps its check — the prover treats
// a slice's length as runtime even when it came from literal bounds (`buf[1:4]`, statically length 3),
// so `view[0]` cannot yet be proven non-empty. Hence EXACTLY ONE policy ghost here: on the slice index,
// not the const index. (A future prover that tracks static slice lengths could elide `view[0]` too.)
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "policy") -eq 1
// RUN: %build/arche-analyzer --dump %s | grep -qF "policy !abort"
#import { fmt }
XS   :: { 10, 20, 30 }
main :: proc() {
  buf: [5]int;
  view := buf[1: 4];
  fmt.printf("%d %d\n", XS[0], view[0]);
}
