// The divide `abort` policy writes "arche: divide by zero" before `_exit(134)`. Guards the divide
// `abort` policy's diagnostic (explicit `!abort`, since divide has no implicit default yet — D14).
// RUN: %arche build -o %t %s && { %t 2>%t.err ; test $? -eq 134 ; } && grep -qF "arche: divide by zero" %t.err
#import { os }
entry :: system eff {
  os.argc()(argc:);
  d := argc - argc; // 0 at runtime
  x := 10 / d !abort;
  y := x + 0;
}

#run entry
