// `--no-abort` accepts a program where every fallible op is total: it builds AND runs to completion.
// RUN: %arche build --no-abort -o %t %s && %t | grep -qF "ok=13"
#import { fmt }
entry :: system {
  a: [4]int;
  a[3] = 13;
  i := 99;
  fmt.printf("ok=%d\n", a[i] !clamp); // total -> accepted, clamps to a[3]
}

#run entry
