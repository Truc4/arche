// `--no-abort`: an unannotated fallible op in a proc resolves to the implicit `!abort` — rejected
// (E0125). Crash-free builds must annotate a total policy.
// RUN: %arche build --no-abort -o %t %s > %t.out 2>&1 ; grep -qi "no-abort forbids\|E0125" %t.out
main :: proc() {
  a: int[4];
  i := 9;
  x := a[i]; // implicit !abort -> rejected under --no-abort
}
