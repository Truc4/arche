// `!undefined` (the raw, runtime-unsafe opt-out) is rejected BY DEFAULT — no flag needed (E0126).
// `--allow-undefined` opts back in. Use a checked total policy or a provable index instead.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qiF "forbidden by default" %t.out
// the opt-in flag permits it — build succeeds, no E0126:
// RUN: %arche build --allow-undefined -o %t2 %s > %t2.out 2>&1 ; ! grep -qiF "forbidden by default" %t2.out
main :: proc() {
  a: [4]int;
  i  := 9;
  _x := a[i] !undefined; // raw opt-out → rejected by default; allowed under --allow-undefined
}
