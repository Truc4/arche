// RUN: %arche build -o %t %s && %t | grep "result: 99"
// Unbounded char[] buffer filled in place, scalar count returned.
#import { str fmt }
fill_buf :: func(own buf: []char) -> int {
  buf := str.strcopy(move buf, "hello");
  return 99;
}

main :: proc() {
  buf: [32]char;
  result := fill_buf(move buf);
  fmt.printf("result: %d\n", result);
}
