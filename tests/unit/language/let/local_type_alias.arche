// A local type alias `V :: T` inside a proc body — uniform `::` means a type-valued constant is a
// (nominal) type alias here too. It is compile-time only (erased), usable as a type.
// RUN: %arche build -o %t %s && %t | grep "sum: 10"
#import { fmt }
main :: proc() {
  meters :: int;
  d : meters = 4;
  e : meters = 6;
  fmt.printf("sum: %d\n", d + e);
}
