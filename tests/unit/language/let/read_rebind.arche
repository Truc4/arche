// RUN: %arche build -o %t %s && %t
#import { io }
main :: proc() {
  arche_fopen_read("../../../../../tests/fixtures/transactions.csv")(fd:);
  buf: char[256];
  arche_fread(fd, buf, 256)(n1:);
  printf("first read: %d bytes\n", n1);
  arche_fread(fd, buf, 256)(n2:);
  printf("second read: %d bytes\n", n2);
  if (n2 > 0) {
    printf("rebind ok\n");
  }
  arche_fclose(move fd);
}
