// RUN: %arche -o %t %s && %t
proc main() {
  x := 42;
  assert(x == 42, "with int type failed\n");
  y := 3.14;
  assert(y > 3.0, "with float type failed\n");
  z := 10 + 20;
  assert(z == 30, "with expression failed\n");
  a := x + 8;
  assert(a == 50, "with int addition failed\n");
  print("all type syntax tests passed\n");
}
