// RUN: %arche -o %t %s && %t

proc main() {
  let x := 42;
  assert(x == 42, "let with int type failed\n");
  let y := 3.14;
  assert(y > 3.0, "let with float type failed\n");
  let z := 10 + 20;
  assert(z == 30, "let with expression failed\n");
  let a := x + 8;
  assert(a == 50, "let with int addition failed\n");
  print("all let type syntax tests passed\n");
}
