// Several computed results are an out-param list on a `func` — a func that produces multiple results
// (the proc form, now spelled `func`). The `(s:, d:)` bind destructures them at the call site.
// RUN: %arche build -o %t %s && %t | grep "s=13 d=7"
#import { fmt }
sum_diff :: func(a: int, b: int)(s: int, d: int) {
  s = a + b;
  d = a - b;
}

entry :: system {
  sum_diff(10, 3)(s:, d:);
  fmt.printf("s=%d d=%d\n", s, d);
}

#run entry
