// RUN: %arche -o %t %s && %t | grep "x=ab y=cd n=42"
// Two caller buffers filled in place + a scalar count.
func fill_two(buf1: char[32], buf2: char[32]) -> int {
  sprintf(buf1, "ab");
  sprintf(buf2, "cd");
  return 42;
}

proc main() {
  x: char[32];
  y: char[32];
  n := fill_two(x, y);
  printf("x=%s y=%s n=%d\n", x, y, n);
}
