// RUN: %arche -o %t %s && %t | grep "x=test1 y=test2 n=77"
// Two buffers filled in place, scalar count returned.
func fill_two(buf1: char[32], buf2: char[32]) -> int {
  sprintf(buf1, "test1");
  sprintf(buf2, "test2");
  return 77;
}

proc main() {
  x: char[32];
  y: char[32];
  n := fill_two(x, y);
  printf("x=%s y=%s n=%d\n", x, y, n);
}
