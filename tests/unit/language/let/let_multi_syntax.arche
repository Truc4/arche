// RUN: %arche build -o %t %s && %t | grep "x=test1 y=test2 n=77"
// Two buffers moved in (own, consumed) and handed back through fresh out-bindings — the
// `f(move x)(x:)` kill-and-rebind form: `move` kills the in-binding, the `x:` out-arg mints a
// fresh one (you can't reuse a killed binding, so the out-arg must be `x:`, not bare `x`).
#import { str fmt }

fill_two :: proc()(buf1: [32]char, buf2: [32]char, n: int) {
  buf1 := str.strcopy(move buf1, "test1");
  buf2 := str.strcopy(move buf2, "test2");
  n = 77;
}

main :: proc() {
  x : [32]char;
  y : [32]char;
  fill_two()(x:, y:, n:);
  // `strcopy` is length-carried — it writes the 5 content bytes but no NUL, and the fixed `char[32]`
  // buffers are otherwise uninitialized. Terminate at the content length before the libc `%s` (which
  // scans to a NUL); without this, `%s` reads past "test1"/"test2" into stack garbage (CI-dependent).
  x[5] = 0;
  y[5] = 0;
  fmt.printf("x=%s y=%s n=%d\n", x, y, n);
}