// RUN: %arche -o %t %s && %t | grep "x=test1 y=test2 n=77"
// Two buffers moved in by reference, filled, and returned (real multi-return).
func fill_two(own buf1: char[32], own buf2: char[32]) -> (char[32], char[32], int) {
  buf1 := strcopy(move buf1, "test1");
  buf2 := strcopy(move buf2, "test2");
  return buf1, buf2, 77;
}

proc main() {
  x: char[32];
  y: char[32];
  x, y, n := fill_two(move x, move y);
  printf("x=%s y=%s n=%d\n", x, y, n);
}
