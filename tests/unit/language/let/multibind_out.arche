// RUN: %arche build -o %t %s && %t | grep "result: 99"
// A function fills the caller's buffer in place and returns a scalar count.
fill_buf :: func (own buf: char[32]) -> int {
  buf := strcopy(move buf, "hello");
  return 99;
}

main :: proc () {
  buf: char[32];
  result := fill_buf(move buf);
  printf("result: %d\n", result);
}
