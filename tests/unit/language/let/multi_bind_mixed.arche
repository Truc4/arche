// RUN: %arche build -o %t %s && %t | grep -E "test1|test2|test3"
// Buffers moved in (own, consumed) and handed back through fresh out-bindings across several
// calls — the `f(move x)(x:)` kill-and-rebind form (a killed binding can't be reused bare).
#import { str fmt }
fill_two :: func(own buf1: [32]char, own buf2: [32]char)(
  buf1 : [32]char,
  buf2 : [32]char,
  n    : int,
) {
  buf1 := str.strcopy(move buf1, "hello");
  buf2 := str.strcopy(move buf2, "world");
  n = 99;
}

entry :: system {
  x : [32]char;
  y : [32]char;
  fill_two(move x, move y)(x:, y:, n:);
  fmt.printf("test1: x=%s y=%s n=%d\n", x, y, n);

  a : [32]char;
  z : [32]char;
  fill_two(move a, move z)(a:, z:, m:);
  fmt.printf("test2: a=%s z=%s m=%d\n", a, z, m);

  p : [32]char;
  q : [32]char;
  fill_two(move p, move q)(p:, q:, k:);
  fmt.printf("test3: p=%s q=%s k=%d\n", p, q, k);
}

#run entry
