// Reading argv is an effect (arche_argv is an extern), so its result is bound first, then passed
// to the pure callees mylen / atoi. An extern call is an action, not a value — it can't be nested
// directly inside another call's arguments; binding it names and sequences the effect.
// RUN: %arche -o %t %s && %t 42 | grep "len=2"
// RUN: %t 42 | grep "n=42"
func mylen(s: char[]) -> int {
  return strlen(s);
}
proc main() {
  arg := arche_argv(1);
  printf("len=%d\n", mylen(arg));
  printf("n=%d\n", atoi(arg));
}
