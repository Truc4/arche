// RUN: %arche -o %t %s && %t

arche Particle {
  pos: float,
  vel: float,
}



arche Body {
  pos: float,
  vel: float,
  mass: float,
}



proc main() {
  insert(Particle, 1.0, 0.1);
  insert(Body, 5.0, 0.5, 10.0);
  let pp = Particle.pos[0];
  let bp = Body.pos[0];
  let ppi = pp * 10.0;
  let bpi = bp * 10.0;
  assert(ppi == 10, "Particle.pos != 1.0\n");
  assert(bpi == 50, "Body.pos != 5.0\n");
}

