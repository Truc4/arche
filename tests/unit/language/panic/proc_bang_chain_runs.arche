// A `proc!` (panic-capable) may be called from another `proc!` — panic-capability is contagious,
// and marking every link in the chain `proc!` satisfies it. main is itself `proc!` here.
// RUN: %arche build -o %t %s && %t | grep "ok"
#import { fmt }

leaf :: proc!(n: int)(o: int) { o = n + 1; }
mid  :: proc!(n: int)(o: int) { leaf(n)(o:); }

main :: proc!() {
  mid(41)(r:);
  fmt.print("ok\n");
}
