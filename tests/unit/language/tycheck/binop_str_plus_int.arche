// E0200: a typed `str` variable added to an int operand is rejected by tycheck.
// Previously bumped to LLVM ("defined with type 'ptr' but expected 'i32'").
// The lenient binop rule allows numeric mixing (float+int etc.) but rejects
// str↔scalar pairings — the audit's "a" + 1 gap.
// RUN: %build/arche-analyzer --dump %s | grep -qF "error E0200 type_mismatch 0 binary operand: expected 'str', got 'i32'"
#import { fmt }
main :: proc() {
  s: str = "a";
  x := s + 1;
  fmt.printf("%d\n", x);
}
