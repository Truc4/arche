// E0030: `break` outside any loop is a hard error. Previously the codegen
// printed "Error: break statement outside of loop" with no location; now we
// emit at the proper site with the standard registry format.
// RUN: %build/arche-analyzer --dump %s | grep -qF "error E0030 break_outside_loop 0 \`break\` can only appear inside a loop body"
#import { fmt }
main :: proc() {
  break;
  fmt.printf("%d\n", 1);
}
