// E0200: a TYPED variable (declared `: str`) passed where the function expects
// `int` is rejected. Distinct from the literal case — literals are flexible
// (Rust/Go untyped-constant model); typed variables are strict.
// RUN: %build/arche-analyzer --dump %s | grep -qF "error E0200 type_mismatch 0 argument 1 of 'add': expected 'int', got 'str'"
func add(a: int, b: int) -> int {
  return a + b;
}

proc main() {
  s: str = "hi";
  x := add(s, 1);
  print(x);
}
