// printf is declared `extern printf(fmt: char[], ...) -> int;` — variadic. The
// fixed prefix (`fmt`) is still checked, but trailing args are unconstrained, so
// `printf("%d %d %d\n", 1, 2, 3)` is accepted with three extras.
// RUN: %arche build -o %t %s && %t | grep "1 2 3"
#import { fmt }
main :: proc() {
  fmt.printf("%d %d %d\n", 1, 2, 3);
}
