// E0203: passing too few arguments is a tycheck error.
// RUN: %build/arche-analyzer --dump %s | grep -qF "error E0203 wrong_arity 0 'add' expects 2 arguments, got 1"
#import { fmt }
add :: func(a: int, b: int) -> int {
  return a + b;
}

entry :: system eff {
  x := add(1);
  fmt.printf("%d\n", x);
}

#run entry
