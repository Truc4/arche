// E0203: a fixed-arity extern (no `...` in its signature) is arity-checked
// just like any other call. arche_file_unmap takes 2 args; passing 3 fires.
// Tycheck only skips arity when the extern signature ends with `...` (printf etc.).
// RUN: %build/arche-analyzer --dump %s | grep -qF "error E0203 wrong_arity 0 'arche_file_unmap' expects 2 arguments, got 3"
proc main() {
  data : char[] = arche_file_map("/tmp/x.txt");
  size: i64 = arche_file_size();
  arche_file_unmap(data, size, size);
}
