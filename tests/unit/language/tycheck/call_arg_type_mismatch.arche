// E0200: passing the wrong argument type fires a type_mismatch via tycheck.
// RUN: %build/arche-analyzer --dump %s | grep -qF "error E0200 type_mismatch 0 argument 1 of 'double': expected 'i32', got 'str'"
#import { fmt }
double :: func(x: int) -> int {
  return x * 2;
}

entry :: system eff {
  y := double("hello");
  fmt.printf("%d\n", y);
}

#run entry
