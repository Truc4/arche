// Raw syscall intrinsic: getpid() is syscall 39 on x86-64 Linux. Emits the
// `syscall` instruction directly (no libc, no C shim). Also exercises bare-`let`
// inferring the i64 result. A live pid is always > 0.
// RUN: %arche build -o %t %s && %t | grep "ok"
#import { fmt os }
entry :: system {
  os.syscall(39, 0, 0, 0, 0, 0, 0)(pid:);
  if (pid > 0) {
    fmt.printf("ok pid_is_positive\n");
  }
}

#run entry
