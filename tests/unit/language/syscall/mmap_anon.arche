// mmap(0, 4096, PROT_READ|WRITE=3, MAP_PRIVATE|ANON=0x22=34, -1, 0) returns a
// real address (not a small -errno), then munmap returns 0. Uses ALL SIX arg
// registers (len=rsi, prot=rdx, flags=r10, fd=r8, off=r9) — and mmap is the
// syscall the graphics framebuffer will use.
// RUN: %arche build -o %t %s && %t | grep "ok"
proc main() {
  syscall(9, 0, 4096, 3, 34, -1, 0)(p:);
  if (p > 1000000) {
    syscall(11, p, 4096, 0, 0, 0, 0)(un:);
    if (un == 0) {
      printf("ok\n");
    }
  }
}
