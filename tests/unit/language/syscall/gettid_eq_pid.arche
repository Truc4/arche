// A single-threaded process's gettid (186) equals its getpid (39): proves the
// syscall result register is read correctly across two distinct syscalls.
// RUN: %arche build -o %t %s && %t | grep "ok"
#import { fmt os }
entry :: system eff {
  os.syscall(39, 0, 0, 0, 0, 0, 0)(pid:);
  os.syscall(186, 0, 0, 0, 0, 0, 0)(tid:);
  if (pid == tid) {
    fmt.printf("ok\n");
  }
}

#run entry
