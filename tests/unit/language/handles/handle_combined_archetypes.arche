// RUN: %arche build -o %t %s && %t | grep "alive"
#import { fmt }
Player :: arche { pos :: float }

AliveList :: arche { player_ref :: handle<Player> }

[10]Player ?abort;

[10]AliveList ?abort;

entry :: system eff {
  insert(Player { pos: 1.0 })(p1:, _:);
  insert(Player { pos: 2.0 })(p2:, _:);
  insert(AliveList { player_ref: p1 })(_:, _:);
  insert(AliveList { player_ref: p2 })(_:, _:);
  fmt.print("alive list created")(_:);
}

#run entry
