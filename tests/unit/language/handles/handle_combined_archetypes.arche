// RUN: %arche build -o %t %s && %t | grep "alive"
#import { fmt }
Player :: arche { pos :: float }

AliveList :: arche { player_ref :: handle<Player> }

Player[10]

AliveList[10]

main :: proc() {
  insert(Player, 1.0)(p1:, _:);
  insert(Player, 2.0)(p2:, _:);
  insert(AliveList, p1)(_:, _:);
  insert(AliveList, p2)(_:, _:);
  fmt.print("alive list created");
}
