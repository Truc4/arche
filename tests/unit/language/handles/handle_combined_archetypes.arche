// RUN: %arche -o %t %s && %t | grep "alive"
arche Player {
  pos: float,
}


arche AliveList {
  player_ref: handle<Player>,
}


static table<Player>(10);

static table<AliveList>(10);


proc main() {
  let p1 := insert(table<Player>, 1.0);
  let p2 := insert(table<Player>, 2.0);
  insert(table<AliveList>, p1);
  insert(table<AliveList>, p2);
  print("alive list created");
}
