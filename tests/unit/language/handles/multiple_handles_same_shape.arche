// RUN: %arche build -o %t %s && %t
// Multiple handles to same shape is allowed - they're just names/aliases
#import { fmt }
Players :: arche { x :: float, y :: int }

Enemies :: arche { x, y }

[2]Players(2) {
  x: 1.0, y: 10,
}

// Only ONE can be allocated

entry :: system eff {
  fmt.printf("multiple handles ok\n");
}

#run entry
