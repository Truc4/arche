// Imported modules are reached via qualified access: `xmod_b.useit` calls `xmod_a.helper`,
// and main calls `xmod_b.useit`. (Bare cross-module names no longer resolve.)
// RUN: %arche build -o %t %s && %t | grep "RESULT=110"
#import { xmod_a xmod_b fmt }

main :: proc() {
  fmt.printf("RESULT=%d\n", xmod_b.useit(10));
}
