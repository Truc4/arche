// RUN: %arche -o %t %s && cd %repo && %t | grep "PASS"
use csv;

static buf: char[65536];

proc main() {
  fd := csv_open("tests/fixtures/data.csv");
  if (fd > 0) {
    n := csv_read_chunk(fd, buf, 65536);
    csv_close(move fd);
    if (n > 0) {
      printf("PASS: read %d bytes\n", n);
    } else {
      printf("FAIL: no bytes read\n");
    }
  } else {
    printf("FAIL: could not open file\n");
  }
}
