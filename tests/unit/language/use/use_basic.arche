// RUN: %arche build -o %t %s && cd %repo && %t | grep "PASS"
#import { io fmt }

cb      :: char;
CharBuf :: arche { cb }
[65536]CharBuf;

entry :: system eff {
  io.open("tests/fixtures/data.csv")(fd:);
  if (fd > 0) {
    scratch := CharBuf.cb[0: CharBuf.capacity]; // slice-local OUT (lint-only: column write outside a query)
    io.read_chunk(fd, 65536)(scratch, rd_v:);
    v := CharBuf.cb[0: rd_v];
    // RAII: `fd` is auto-dropped (io.close) at scope exit on every path — no explicit close.
    // An explicit close only in this `then` branch would be a 'some paths' consumption error.
    if (v.length > 0) {
      fmt.printf("PASS: read %d bytes\n", v.length);
    }
    else {
      fmt.printf("FAIL: no bytes read\n");
    }
  }
  else {
    fmt.printf("FAIL: could not open file\n");
  }
}

#run entry
