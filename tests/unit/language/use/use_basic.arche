// RUN: %arche -o %t %s && cd %repo && %t | grep "PASS"
use io;

proc main() {
  io_open("tests/fixtures/data.csv")(fd:);
  if (fd > 0) {
    buf: char[65536];
    io_read_chunk(fd, move buf, 65536)(buf, n:);
    io_close(move fd);
    if (n > 0) {
      printf("PASS: read %d bytes\n", n);
    }
    else {
      printf("FAIL: no bytes read\n");
    }
  }
  else {
    printf("FAIL: could not open file\n");
  }
}
