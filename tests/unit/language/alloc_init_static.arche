// RUN: %arche -o %t %s && %t

arche Counter {
  val: int,
  score: float,
}



proc main() {
  assert(Counter.val[0] == 7, "val[0] not 7\n");
  assert(Counter.score[0] == 2.5, "score[0] not 2.5\n");
  assert(Counter.val[4] == 7, "val[4] not 7\n");
  assert(Counter.score[4] == 2.5, "score[4] not 2.5\n");
  printf("static alloc init ok\n");
}

