arche Transaction {
  price: float,
  quantity: int,
  revenue: float,
}

static Transaction(10000000, 10000000) {
  price: 0.0,
  quantity: 0,
  revenue: 0.0,
};

proc load_data() {
  let fd := arche_fopen_read("design_analysis/benchmarks/etl/data/data_10m.csv");
  let line: char[256];
  let price_str: char[32];
  let qty_str: char[32];

  arche_fread_line(fd, line, 256);

  let idx := 0;
  for (;idx < 10000000;) {
    let n := arche_fread_line(fd, line, 256);
    if (n <= 0) { break; }

    let line_pos := 0;
    let field_idx := 0;
    let c1 := 0;
    let c2 := 0;

    for (;line_pos < n;) {
      if (line[line_pos] == ',') {
        field_idx = field_idx + 1;
        if (field_idx == 1) { c1 = line_pos; }
        if (field_idx == 2) { c2 = line_pos; }
      }
      line_pos = line_pos + 1;
    }

    let i := 0;
    let j := 0;
    for (;i < c2 - c1 - 1;) {
      price_str[j] = line[c1 + 1 + i];
      j = j + 1;
      i = i + 1;
    }
    price_str[j] = 0;

    j = 0;
    i = 0;
    for (;i < n - c2 - 2;) {
      qty_str[j] = line[c2 + 1 + i];
      j = j + 1;
      i = i + 1;
    }
    qty_str[j] = 0;

    Transaction.price[idx] = atof(price_str);
    Transaction.quantity[idx] = atoi(qty_str);

    idx = idx + 1;
  }

  arche_fclose(fd);
}

proc main() {
  load_data();

  Transaction.revenue = Transaction.price * Transaction.quantity;

  let sum1 := 0.0;
  let m := 0;
  for (;m < 10000000;) {
    sum1 = sum1 + Transaction.revenue[m];
    m = m + 1;
  }

  let count := 0;
  let i := 0;
  for (;i < 10000000;) {
    if (Transaction.quantity[i] > 0) { count = count + 1; }
    i = i + 1;
  }

  let sum2 := 0.0;
  let j := 0;
  for (;j < 10000000;) {
    sum2 = sum2 + Transaction.price[j] / 10.0;
    j = j + 1;
  }

  let sum3 := 0.0;
  let k := 0;
  for (;k < 10000000;) {
    sum3 = sum3 + Transaction.revenue[k];
    k = k + 1;
  }

  printf("done\n");
}
