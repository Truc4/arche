// A foreign resource as a nominal opaque alias: `resource :: opaque` is distinct in the
// checker but erases to a bare `opaque` cell (an i64 bitcast to the C pointer at the ABI).
// open/set/get/close round-trips by value through C. The close is a terminal `consume`,
// so it linearly retires the resource (must-consume satisfied).
// RUN: %arche build -o %t --link %S/../extern_type/runtime/test_resource.c %s && %t | grep "value=42"
#import { fmt }
resource :: opaque;
#foreign {
  resource_open  :: proc(initial: int)(ret: resource);
  resource_get   :: proc(r: resource)(ret: int);
  resource_set   :: proc(r: resource, v: int);
  resource_close :: proc(own r: resource);
}

entry :: system {
  resource_open(10)(r:);
  resource_set(r, 42);
  resource_get(r)(v:);
  fmt.printf("value=%d\n", v);
  resource_close(move r);
}

#run entry
