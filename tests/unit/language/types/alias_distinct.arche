// `file` and `socket` are distinct nominal types though both back to `opaque`. Passing an
// `file` where a `socket` is expected is a compile error — nominal identity is checked at
// substitution boundaries (here, a call argument), even though both erase to `opaque`. Uses the
// real stdlib opaques — no FFI stub needed.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "socket" %t.out
#import { io net }
main :: proc() {
  io.stdout()(f:);
  buf: char[8];
  // net.send expects a `socket`; handing it an `fd` is the type error.
  net.send(f, buf);
}
