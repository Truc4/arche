// NOTE: repurposed. This file used to assert that top-level `name := value` was REJECTED ("not
// implemented yet"). That form is now SUPPORTED — a mutable global whose initial value is a
// compile-time constant baked into the data section. The variable is reassignable at runtime.
// (Full spec: tests/unit/language/declarations/.)
// RUN: %arche build --exported-mutable=allow -o %t %s && %t | grep -q "count=0 then 3"
#import { fmt }
count := 0;

entry :: system eff {
  fmt.printf("count=%d then ", count);
  count = 3;
  fmt.printf("%d\n", count);
}

#run entry
