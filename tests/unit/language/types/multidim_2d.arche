// RUN: %arche build -o %t %s && %t | grep "value:"
#import { fmt }
Matrix :: arche { data :: [10]float }

[5]Matrix ?abort;

entry :: system eff {
  insert(Matrix { data: 1.5 })(_:, _:);
  val := Matrix.data[0][0];
  vi  := val * 10.0;
  fmt.print("value: 15\n")(_:);
  fmt.assert(vi == 15, "data[0][0] != 1.5\n")();
  row   := Matrix.data[0];
  vrow  := row[0];
  virow := vrow * 10.0;
  fmt.assert(virow == 15, "row[0] != 1.5\n")();
}

#run entry
