// RUN: %arche build -o %t %s && %t | grep "value:"
Matrix :: arche { data :: float[10], }

static pool<Matrix> (5)

main :: proc() {
  insert(Matrix, 1.5);
  val := Matrix.data[0, 0];
  vi := val * 10.0;
  print("value: 15\n");
  assert(vi == 15, "data[0,0] != 1.5\n");
  row := Matrix.data[0];
  vrow := row[0];
  virow := vrow * 10.0;
  assert(virow == 15, "row[0] != 1.5\n");
}
