// Linear must-consume: an opaque local that is never consumed (moved into a consume
// call, returned, or inserted) before its scope ends is a compile error. No silent leak.
// RUN: %arche -o %t %s > %t.out 2>&1 ; grep -qi "not consumed" %t.out
resource :: opaque
extern func resource_open(initial: int) -> resource;
extern proc resource_close(move r: resource);

proc main() {
  r := resource_open(10);
}
