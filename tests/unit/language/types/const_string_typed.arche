// An explicit `[]char` (slice) type on the binding is accepted for a string const.
// (RED until char[] consts + prefix syntax land.)
// RUN: %arche build -o %t %s && %t | grep -x "linux"
#import { os }
name: []char: "linux";
entry :: system eff {
  os.write(1, name, name.length)(_:);
  os.write(1, "\n", 1)(_:);
}

#run entry
