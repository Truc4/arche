// `foo : type : T` is the explicit meta-type longhand for a nominal type alias — equivalent to
// the inferred `foo :: T`. Here `weight` backs `int`. The explicit form must survive the
// formatter (see formatter/meta_alias_preserved), so this file keeps `: type :`.
// RUN: %arche build -o %t %s && %t | grep "ok: 7"
#import { fmt }
weight: type: int;
entry :: system eff {
  w: weight = 7;
  fmt.printf("ok: %d\n", w);
}

#run entry
