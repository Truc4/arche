// A typed value const's explicit declared type now constrains its literal (it is no longer inert):
// an int-typed constant cannot take a float literal.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "declared .i32. but its value is a float literal" %t.out
#import { fmt }
bad: int: 3.5;
main :: proc() {
  fmt.printf("unreachable\n");
}
