// RUN: %arche build -o %t %s && %t | grep "PASS"
#import { fmt }
FloatOps :: arche { val :: float }

[8]FloatOps;

float_multiply :: map (query { val }) {
  val = val * 2.0;
}

main :: proc() {
  insert(FloatOps { val: 1.0 })(_:, _:);
  insert(FloatOps { val: 1.0 })(_:, _:);
  insert(FloatOps { val: 1.0 })(_:, _:);
  insert(FloatOps { val: 1.0 })(_:, _:);
  insert(FloatOps { val: 1.0 })(_:, _:);
  insert(FloatOps { val: 1.0 })(_:, _:);
  insert(FloatOps { val: 1.0 })(_:, _:);
  insert(FloatOps { val: 1.0 })(_:, _:);
  run float_multiply;
  v0          := FloatOps.val[0];
  v1          := FloatOps.val[1];
  v2          := FloatOps.val[2];
  v3          := FloatOps.val[3];
  v4          := FloatOps.val[4];
  v5          := FloatOps.val[5];
  v6          := FloatOps.val[6];
  v7          := FloatOps.val[7];
  all_correct := 1;
  if (v0 != 2.0) {
    all_correct = 0;
  }
  if (v1 != 2.0) {
    all_correct = 0;
  }
  if (v2 != 2.0) {
    all_correct = 0;
  }
  if (v3 != 2.0) {
    all_correct = 0;
  }
  if (v4 != 2.0) {
    all_correct = 0;
  }
  if (v5 != 2.0) {
    all_correct = 0;
  }
  if (v6 != 2.0) {
    all_correct = 0;
  }
  if (v7 != 2.0) {
    all_correct = 0;
  }
  if (all_correct) {
    fmt.printf("PASS\n");
  }
}
