// A char value const works in a char context: the const inlines as its integer code (LLVM has no
// char token). Both the inferred `::` and the explicit `: char :` forms work.
// RUN: %arche build -o %t %s && %t | grep "a=A b=B"
#import { fmt }
A :: 'A';
B: char: 'B';
entry :: system eff {
  fmt.printf("a=%c b=%c\n", A, B);
}

#run entry
