// `move` at the call site marks an ownership transfer; here the resource is moved into
// its close (which consumes it). Runs end to end.
// RUN: %arche build -o %t --link %S/../extern_type/runtime/test_resource.c %s && %t | grep "value=42"
resource :: opaque
resource_open :: extern proc (initial: int)(ret: resource);
resource_set :: extern proc (r: resource, v: int);
resource_get :: extern proc (r: resource)(ret: int);
resource_close :: extern proc (own r: resource);

main :: proc () {
  resource_open(10)(r:);
  resource_set(r, 42);
  resource_get(r)(v:);
  printf("value=%d\n", v);
  resource_close(move r);
}
