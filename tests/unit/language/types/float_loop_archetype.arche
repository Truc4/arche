// RUN: %arche build -o %t %s && %t
Nums :: arche { val :: float }

Nums[4](4) {
  val: 0.0,
}

main :: proc() {
  Nums.val[0] = 1.0;
  Nums.val[1] = 2.0;
  Nums.val[2] = 3.0;
  Nums.val[3] = 4.0;
  total: float = 0.0;
  i := 0;
  for (; i < 4;) {
    v := Nums.val[i];
    total = total + v;
    i = i + 1;
  }
  assert(total == 10.0, "float loop archetype failed\n");
}
