// Set-based archetype identity: a component set is unordered, so {hp, mp} and {mp, hp}
// denote the SAME shape. Allocating a pool for each is therefore a double-allocation of
// one shape — the compiler recognizes the reorder as identical and rejects it.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "already allocated" %t.out
hp :: int
mp :: int
A :: arche {
  hp, mp,
}
B :: arche {
  mp, hp,
}

static pool<A> (4)
static pool<B> (4)

main :: proc() {
}
