// Returning an opaque from a func→Eff moves it out (consumption). Was a proc; now a func builds the
// open-Eff over the extern, and the run binds the handle.
// RUN: %arche build -o %t --link %S/../extern_type/runtime/test_resource.c %s && %t | grep "value=7"
#import { fmt }
resource :: opaque;
#foreign {
  resource_open  :: proc(initial: int)(ret: resource);
  resource_get   :: proc(r: resource)(ret: int);
  resource_close :: proc(own r: resource);
}
make_resource :: func(v: int) -> Eff(resource) {
  return resource_open(v);
}
entry :: system {
  make_resource(7)(r:);
  resource_get(r)(v:);
  fmt.printf("value=%d\n", v);
  resource_close(move r);
}
#run entry
