// A function fills a caller buffer in place and returns a scalar. (Arrays are reached by
// reference; the buffer is the caller's, filled by the callee.)
// RUN: %arche build -o %t %s && %t
#import { fmt }
test_fill_buf :: func(buf: [32]char) -> int {
  return 5;
}

entry :: system {
  buf: [32]char;
  n := test_fill_buf(buf);
  fmt.assert(n > 0, "test_fill_buf returned <= 0\n");
  fmt.printf("out param test ok\n");
}

#run entry
