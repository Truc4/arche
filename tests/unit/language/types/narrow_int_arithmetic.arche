// Arithmetic on a narrow-int column (`i8`/`i16`) must (1) store back at the column width — the op is
// computed at i32 (loads promoted, literals i32), so the result must truncate to the column width before
// the store — and (2) read back sign-extended for a SIGNED column, so a negative value round-trips.
// Regression for both: `k = 0 - k` on a signed i8 and i16 column must yield -5, not 251 / 65531.
// RUN: %arche build -o %t %s && %t | grep -qF "PASS"
#import { fmt }

k8 :: i8;

k16 :: i16;

N :: arche { k8, k16 }

[4]N(4) {
  k8: 5, k16: 5
}

neg :: map (query { k8, k16 }) (k8, k16) {
  k8  = 0 - k8;
  k16 = 0 - k16;
}

verify :: system eff {
  // each: 5 -> -5
  e := -5;
  fmt.assert(N.k8[0] == e, "i8 negate wrong\n")();
  fmt.assert(N.k16[0] == e, "i16 negate wrong\n")();
  fmt.printf("PASS\n");
}

#run seq({ neg, verify })
