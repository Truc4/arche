// RUN: %arche build -o %t %s && %t | grep "commas=2"
// Regression: forwarding a `char[]` parameter into another non-extern that also takes `char[]` must
// pass the arche_array by reference (`%struct.arche_array*`), not the inner i8* data pointer. The
// call-site lowering once extracted field 0 (the C-ABI i8*) for a `char[]` *param* even when the
// callee was a non-extern Arche func, so the callee reinterpreted raw bytes as a {ptr,len,cap}
// struct and dereferenced a bogus pointer (SIGSEGV). Now fixed (same wrap-in-arche_array class as the
// local-buffer / static-array arg cases). Here `outer(data)` forwards `data` to `inner(data)`.

#import { fmt }
inner :: func(data: []char, n: int) -> int {
  cnt := 0;
  for (i := 0; i < n; i += 1) {
    if (i >= data.length) {
      break;
    }
    if (data[i] == ',') {
      cnt += 1;
    }
  }
  return cnt;
}

outer :: func(data: []char, n: int) -> int {
  return inner(data, n);
}

main :: proc() {
  buf: [8]char;
  buf[0] = 'a';
  buf[1] = ',';
  buf[2] = 'b';
  buf[3] = ',';
  fmt.printf("commas=%d\n", outer(buf, 4));
}
