// RUN: %arche build -o %t %s && %t | grep "commas=2"
// BUG: forwarding a `char[]` parameter into another non-extern that also
//      takes `char[]` passes the wrong LLVM type, causing a SIGSEGV at runtime
//      (printed as "stack overflow" by the SIGSEGV handler in runtime/stack_check.c).
//
// Root cause (codegen call-site lowering): when the argument is a `char[]`
// *parameter* (an arche_array value), the call site extracts the inner i8*
// data pointer (field 0) — the C-ABI form — even when the callee is a
// non-extern Arche func that expects `%struct.arche_array*`. The callee then
// reinterprets raw char bytes as a {ptr,len,cap} struct and dereferences the
// bogus "ptr" field.
//
// Observed IR:
//   define i32 @inner(%struct.arche_array* %arg0, i32 %arg1) { ... }
//   define i32 @outer(%struct.arche_array* %arg0, i32 %arg1) {
//     %p = getelementptr %struct.arche_array, %struct.arche_array* %arg0, i32 0, i32 0
//     %d = load i8*, i8** %p
//     %r = call i32 @inner(i8* %d, i32 %arg1)   ; <-- i8* passed where arche_array* expected
//   }
//
// This is the same class as the local-buffer / static-array arg cases that
// were fixed in codegen (wrap-in-arche_array for non-extern callees); the
// "arg is itself a char[] param" path was missed.
//
// Discovered: 2026-05-19 while building the pure-Arche CSV loader, where
// field_at(data: char[], ...) forwards `data` to find_byte(data: char[], ...).

inner :: func(data: char[], n: int) -> int {
  cnt := 0;
  for (i := 0; i < n; i += 1) {
    if (data[i] == ',') {
      cnt += 1;
    }
  }
  return cnt;
}

outer :: func(data: char[], n: int) -> int {
  return inner(data, n);
}

main :: proc() {
  buf: char[8];
  buf[0] = 'a';
  buf[1] = ',';
  buf[2] = 'b';
  buf[3] = ',';
  printf("commas=%d\n", outer(buf, 4));
}
