// RUN: %arche build -o %t %s && %t | grep "comma=1 first=3"

#import { fmt }
find_byte :: func(data: char[], start: int, end: int, ch: int) -> int {
  for (i := start; i < end; i += 1) {
    if (i < 0) {
      return end;
    }
    if (i >= data.length) {
      return end;
    }
    if (data[i] == ch) {
      return i;
    }
  }
  return end;
}

main :: proc() {
  buf: char[8];
  buf[0] = 'a';
  buf[1] = ',';
  buf[2] = 'b';
  buf[3] = 'c';
  comma := find_byte(buf, 0, 8, ',');
  first := find_byte(buf, 2, 8, 'b') + 1;
  fmt.printf("comma=%d first=%d\n", comma, first);
}
