// A `#schedule` entry must be a `system` or a `map`. A `proc` is called by a system, not scheduled
// directly — listing one is E0063.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "is not schedulable" %t.out
v       :: int;
Counter :: arche { v }
[1]Counter;

bump :: proc() {
}

#schedule {
  bump
}

main :: proc() {
  tick();
}
