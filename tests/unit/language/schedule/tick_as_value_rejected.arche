// `tick()` is a pure action: it advances the schedule and produces no value. Binding it (`x := tick()`)
// uses it as a value, which is rejected (E0067) — it is legal only as a bare `tick();` statement.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "produces no value" %t.out
v       :: int;
Counter :: arche { v }
[1]Counter;

step :: map (query { v }) {
  v = v + 1;
}

#schedule {
  step
}

main :: proc() {
  x := tick();
}
