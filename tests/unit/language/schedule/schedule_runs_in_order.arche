// A `system` is the composer: it runs maps and does I/O. `#schedule { frame }` makes `frame` the
// one unit of per-tick work, and `tick()` in the driver advances the schedule once. Three ticks run
// `step` (which increments the `[1]Counter`) then print, so v reads 1, 2, 3 in order.
// RUN: %arche build -o %t %s && %t | grep -qF "v=1 v=2 v=3"
#import { fmt }
v       :: int;
Counter :: arche { v }
[1]Counter;

step :: map (query { v }) {
  v = v + 1;
}

frame :: system {
  run step;
  fmt.printf("v=%d ", Counter.v[0]);
}

#schedule {
  frame
}

main :: proc() {
  insert(Counter { v: 0 })(_:, _:);
  for (i := 0; i < 3; i += 1) {
    tick();
  }
}
