// RUN: %arche -o %t %s && %t | grep "2"

arche Particle {
  pos: (x: float, y: float),
  vel: (x: float, y: float),
}

static Particle(5);



proc main() {
  insert(Particle, 1.0, 2.0, 0.5, 0.1);
  insert(Particle, 3.0, 4.0, 0.2, 0.3);
  Particle.pos = Particle.vel;
  print(Particle.pos.x[0]);
  print(" ");
  print(Particle.pos.y[0]);
  print(" ");
  print(Particle.pos.x[1]);
  print(" ");
  print(Particle.pos.y[1]);
  print("\n");
}

