arche Transaction {
  quantity: int,
}

static Transaction(10, 10) {
  quantity: 0,
};

proc main() {
  printf("Task 2 test\n");

  let fd := arche_fopen_read("tests/unit/language/etl_test_data.csv");
  printf("File open: %d\n", fd);

  if (fd > 0) {
    let line: char[256];
    let qty_str: char[32];

    arche_fread_line(fd, line, 256);

    let idx := 0;
    for (;idx < 10;) {
      let n := arche_fread_line(fd, line, 256);
      printf("Read line %d: %d bytes\n", idx, n);
      if (n <= 0) {
        break;
      }

      let line_pos := 0;
      let field_idx := 0;
      let c2 := 0;

      for (;line_pos < n;) {
        if (line[line_pos] == ',') {
          field_idx = field_idx + 1;
          if (field_idx == 2) { c2 = line_pos; }
        }
        line_pos = line_pos + 1;
      }

      let j := 0;
      let i := 0;
      for (;i < n - c2 - 1;) {
        qty_str[j] = line[c2 + 1 + i];
        j = j + 1;
        i = i + 1;
      }
      qty_str[j] = 0;

      Transaction.quantity[idx] = atoi(qty_str);
      printf("  qty[%d] = %d\n", idx, Transaction.quantity[idx]);

      idx = idx + 1;
    }

    arche_fclose(fd);

    let count := 0;
    let m := 0;
    for (;m < idx;) {
      if (Transaction.quantity[m] > 0) {
        count = count + 1;
      }
      m = m + 1;
    }

    printf("task2_checksum: %d\n", count);
  } else {
    printf("FAIL: could not open file\n");
  }
}
