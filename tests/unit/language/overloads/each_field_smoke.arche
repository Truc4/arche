// RUN: %arche build -o %t %s && %t | grep "col0=11 col1=21"
#import { fmt }
Pair :: arche { a :: int, b :: int }

Pair[3](3) {
  a: 10, b: 20,
}

@allow_pure_proc
bump :: proc(arch: archetype) {
  #each_field f: int in arch {
    f[0] = f[0] + 1;
  }
}

dump :: proc(arch: archetype) {
  #each_field f: int in arch {
    if (f.index == 0) {
      fmt.printf("col0=%d ", f[0]);
    }
    if (f.index == 1) {
      fmt.printf("col1=%d\n", f[0]);
    }
  }
}

main :: proc() {
  bump(Pair);
  dump(Pair);
}
