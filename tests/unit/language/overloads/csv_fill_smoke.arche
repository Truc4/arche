// RUN: printf 'a,b\n1,10\n2,20\n3,30\n' > /tmp/csv_fill_smoke.csv && %arche -o %t %s && %t | grep "a=\[1 2 3\] b=\[10 20 30\]"
use csv;

arche Pair {
  a: int,
  b: int,
}

static Pair(3, 3) {
  a: 0,
  b: 0,
};

proc main() {
  csv_load(Pair, "/tmp/csv_fill_smoke.csv");
  printf("a=[%d %d %d] b=[%d %d %d]\n", Pair.a[0], Pair.a[1], Pair.a[2], Pair.b[0], Pair.b[1], Pair.b[2]);
}
