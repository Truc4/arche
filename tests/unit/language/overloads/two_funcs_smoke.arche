// RUN: %arche build -o %t %s && %t | grep "INT=7 FLOAT=2.5"
pick_int :: func (x: int) -> int {
  return x + 5;
}
pick_float :: func (x: float) -> float {
  return x + 1.5;
}

pick :: func {
  pick_int, pick_float
}

main :: proc () {
  a := pick(2);
  b := pick(1.0);
  printf("INT=%d FLOAT=%g\n", a, b);
}
