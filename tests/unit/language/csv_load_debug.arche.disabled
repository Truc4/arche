// RUN: %arche -o %t %s && %t | grep "row 6"

arche TestData {
  price: float,
  quantity: int,
}

static TestData(1000, 1000) {
  price: 0.0,
  quantity: 0
};



proc load_data() {
  let fd = arche_fopen_read("design_analysis/benchmarks/etl/data/data.csv");
  let buf: char[65536];
  let total_n = arche_fread(fd, buf, 65536);
  arche_fclose(fd);
  let idx = 0;
  let pos = 0;
  let line_start = 0;
  for (; pos < total_n; pos = pos + 1) {
    if (buf[pos] == '\n') {
      line_start = pos + 1;
      break;
    }
  }
  for (; idx < 10; idx = idx + 1) {
    if (line_start >= total_n) {
      break;
    }
    let line_end = line_start;
    for (; line_end < total_n; line_end = line_end + 1) {
      if (buf[line_end] == '\n') {
        break;
      }
    }
    let c1 = line_start;
    for (; c1 < line_end; c1 = c1 + 1) {
      if (buf[c1] == ',') {
        break;
      }
    }
    let c2 = c1 + 1;
    for (; c2 < line_end; c2 = c2 + 1) {
      if (buf[c2] == ',') {
        break;
      }
    }
    let c3 = c2 + 1;
    for (; c3 < line_end; c3 = c3 + 1) {
      if (buf[c3] == ',') {
        break;
      }
    }
    let price_str: char[32];
    let qty_str: char[32];
    let j = 0;
    let i = c1 + 1;
    for (; i < c2; i = i + 1) {
      price_str[j] = buf[i];
      j = j + 1;
    }
    price_str[j] = 0;
    j = 0;
    i = c2 + 1;
    for (; i < c3; i = i + 1) {
      qty_str[j] = buf[i];
      j = j + 1;
    }
    qty_str[j] = 0;
    TestData.price[idx] = atof(price_str);
    TestData.quantity[idx] = atoi(qty_str);
    if (idx == 6) {
      printf("row 6: price=%f, qty=%d, line_start=%d, line_end=%d, c1=%d, c2=%d, c3=%d\n", TestData.price[idx], TestData.quantity[idx], line_start, line_end, c1, c2, c3);
      fflush(0);
    }
    line_start = line_end + 1;
  }
}



proc main() {
  load_data();
}
