// A named query over TUPLE-GROUP columns (`pos`/`vel` each (x,y)). Guards the lowering resolution-timing
// risk: a named query's columns must be resolved BEFORE the `pos.x`->`pos_x` body rewrite, so a whole-
// group `pos = pos + vel` flattens per-component correctly.
// RUN: %arche build -o %t %s && %t | grep -qF "ok"
#import { fmt }
pos(x, y) :: float;
vel(x, y) :: float;
Mover     :: arche { pos, vel }
[1]Mover ?abort;

Movers :: query { pos, vel }

step :: map (Movers) {
  pos = pos + vel;
}

seed :: system {
  insert(Mover { pos_x: 1.0, pos_y: 2.0, vel_x: 3.0, vel_y: 4.0 })(_:, _:);
}

verify :: system {
  px := Mover.pos.x[0] * 1.0;
  py := Mover.pos.y[0] * 1.0;
  fmt.assert(px == 4.0, "pos.x should be 1+3=4\n")();
  fmt.assert(py == 6.0, "pos.y should be 2+4=6\n")();
  fmt.printf("ok\n");
}

#run seq({ seed, step, verify })
