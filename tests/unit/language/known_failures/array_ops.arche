// RUN: %arche build -o %t %s && %t | grep "pos"
#import { fmt }
Particle :: arche { pos :: float, vel :: float }

Particle[1000]

main :: proc() {
  insert(table<Particle>, 1.0, 0.1);
  insert(table<Particle>, 2.0, 0.2);
  insert(table<Particle>, 3.0, 0.3);
  insert(table<Particle>, 4.0, 0.4);
  insert(table<Particle>, 5.0, 0.5);
  Particle.pos = Particle.pos + Particle.vel;
  p0 := Particle.pos[0];
  p1 := Particle.pos[1];
  p0i := p0 * 10.0;
  p1i := p1 * 10.0;
  fmt.assert(p0i == 11, "pos[0] != 1.1\n");
  fmt.assert(p1i == 22, "pos[1] != 2.2\n");
}
