// RUN: %arche -o %t %s && %t | grep "move"
arche Particle {
  pos :: float,
  vel :: float,
}


static table<Particle>(10);


sys move(pos, vel) {
  pos = pos + vel;
}


proc main() {
  insert(table<Particle>, 1.0, 0.1);
  run move;
  p := Particle.pos[0];
  pi := p * 10.0;
  assert(pi == 11, "move failed\n");
}
