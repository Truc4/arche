// RUN: %arche build -o %t %s && %t | grep "move"
#import { fmt }
Particle :: arche {
  pos :: float,
  vel :: float,
}


Particle[10];


move :: sys(pos, vel) {
  pos = pos + vel;
}


main :: proc() {
  insert(table<Particle>, 1.0, 0.1)(_:, _:);
  run move;
  p := Particle.pos[0];
  pi := p * 10.0;
  fmt.assert(pi == 11, "move failed\n");
}
