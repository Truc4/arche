// RUN: %arche build -o %t %s && %t | grep "DEBUG"
Entity :: arche { x :: float, y :: float, }

static table<Entity> (100)

main :: proc() {
  insert(table<Entity>, 1.0, 2.0);
  insert(table<Entity>, 3.0, 4.0);
  insert(table<Entity>, 5.0, 6.0);
  insert(table<Entity>, 7.0, 8.0);
  insert(table<Entity>, 9.0, 10.0);
  Entity.x = Entity.x + 1.0;
  Entity.y = Entity.y * 2.0;
  delete(table<Entity>, 1);
  insert(table<Entity>, 11.0, 12.0);
  x0 := Entity.x[0];
  y4 := Entity.y[4];
  x0i := x0 * 10.0;
  y4i := y4 * 10.0;
  print("DEBUG: entity values checked\n");
  assert(x0i == 20, "x[0] != 2.0\n");
  assert(y4i == 200, "y[4] != 20.0\n");
}
