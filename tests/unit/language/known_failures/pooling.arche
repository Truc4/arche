// RUN: %arche -o %t %s && %t | grep "DEBUG"

arche Entity {
  x: float,
  y: float,
}

static Entity(100);



proc main() {
  insert(Entity, 1.0, 2.0);
  insert(Entity, 3.0, 4.0);
  insert(Entity, 5.0, 6.0);
  insert(Entity, 7.0, 8.0);
  insert(Entity, 9.0, 10.0);
  Entity.x = Entity.x + 1.0;
  Entity.y = Entity.y * 2.0;
  delete(Entity, 1);
  insert(Entity, 11.0, 12.0);
  let x0 := Entity.x[0];
  let y4 := Entity.y[4];
  let x0i := x0 * 10.0;
  let y4i := y4 * 10.0;
  print("DEBUG: entity values checked\n");
  assert(x0i == 20, "x[0] != 2.0\n");
  assert(y4i == 200, "y[4] != 20.0\n");
}

