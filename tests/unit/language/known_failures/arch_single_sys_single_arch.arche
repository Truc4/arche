// RUN: %arche build -o %t %s && %t | grep "move"
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)
Particle :: arche {
  pos :: float,
  vel :: float,
}


static table<Particle>(10);


move :: sys(pos, vel) {
  pos = pos + vel;
}


main :: proc() {
  insert(table<Particle>, 1.0, 0.1);
  run move;
  p := Particle.pos[0];
  pi := p * 10.0;
  assert(pi == 11, "move failed\n");
}
