// RUN: %arche build -o %t %s && %t | grep "DEBUG"
arche Particle {
  pos :: float,
  vel :: float,
}


arche Body {
  pos :: float,
  vel :: float,
  mass :: float,
}


static table<Particle>(100);

static table<Body>(50);


sys move(pos, vel) {
  pos = pos + vel;
}


proc main() {
  insert(table<Particle>, 1.0, 0.1);
  insert(table<Body>, 5.0, 0.5, 10.0);
  run move;
  pp := Particle.pos[0];
  bp := Body.pos[0];
  ppi := pp * 10.0;
  bpi := bp * 10.0;
  print("DEBUG: two archetypes compared\n");
  assert(ppi == 11, "Particle.pos != 1.1\n");
  assert(bpi == 55, "Body.pos != 5.5\n");
}
