// RUN: %arche -o %t %s && %t
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)

arche Particle {
  pos: float,
  vel: float,
}

arche Body {
  pos: float,
  vel: float,
  mass: float,
}

sys move(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

proc main() {
  alloc Particle(10);
  alloc Body(10);
  insert(Particle, 1.0, 0.1);
  insert(Particle, 2.0, 0.2);
  insert(Particle, 3.0, 0.3);
  insert(Body, 5.0, 0.5, 10.0);
  insert(Body, 6.0, 0.6, 20.0);
  run move;
  run dampen;
  let pp = Particle.pos[0];
  let bp = Body.vel[0];
  let ppi = pp * 10.0;
  let bpi = bp * 100.0;
  assert(ppi == 11, "Particle.pos != 1.1\n");
  assert(bpi == 49, "Body.vel != 0.49\n");
}
