// RUN: %arche build -o %t %s && %t | grep "Particle"
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)
Particle :: arche {
  pos :: float,
  vel :: float,
}


Body :: arche {
  pos :: float,
  vel :: float,
  mass :: float,
}


Particle[100];

Body[50];


move :: sys(pos, vel) {
  pos = pos + vel;
}


main :: proc() {
  insert(table<Particle>, 1.0, 0.1);
  insert(table<Body>, 5.0, 0.5, 10.0);
  run move;
  pp := Particle.pos[0];
  bp := Body.pos[0];
  ppi := pp * 10.0;
  bpi := bp * 10.0;
  assert(ppi == 11, "Particle.pos != 1.1\n");
  assert(bpi == 55, "Body.pos != 5.5\n");
}
