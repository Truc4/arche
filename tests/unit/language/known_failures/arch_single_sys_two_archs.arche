// RUN: %arche build -o %t %s && %t | grep "Particle"
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)
arche Particle {
  pos :: float,
  vel :: float,
}


arche Body {
  pos :: float,
  vel :: float,
  mass :: float,
}


static table<Particle>(5);

static table<Body>(5);


sys move(pos, vel) {
  pos = pos + vel;
}


proc main() {
  insert(table<Particle>, 1.0, 0.1);
  insert(table<Body>, 2.0, 0.2, 10.0);
  run move;
  pp := Particle.pos[0];
  bp := Body.pos[0];
  ppi := pp * 10.0;
  bpi := bp * 10.0;
  assert(ppi == 11, "Particle.pos != 1.1\n");
  assert(bpi == 22, "Body.pos != 2.2\n");
}
