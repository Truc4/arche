// RUN: %arche -o %t %s && %t | grep "Particle"
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)

arche Particle {
  pos: float,
  vel: float,
}



arche Body {
  pos: float,
  vel: float,
  mass: float,
}

static Particle(5, 0);

static Body(5, 0);



sys move(pos, vel) {
  pos = pos + vel;
}



proc main() {
  insert(Particle, 1.0, 0.1);
  insert(Body, 2.0, 0.2, 10.0);
  run move;
  let pp = Particle.pos[0];
  let bp = Body.pos[0];
  let ppi = pp * 10.0;
  let bpi = bp * 10.0;
  assert(ppi == 11, "Particle.pos != 1.1\n");
  assert(bpi == 22, "Body.pos != 2.2\n");
}

