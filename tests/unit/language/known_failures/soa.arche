// RUN: %arche build -o %t %s && %t | grep "pos"
#import { fmt }
Particle :: arche {
  pos :: float,
  vel :: float,
}


Particle[1000];


move :: sys(pos, vel) {
  pos = pos + vel;
}


main :: proc() {
  insert(table<Particle>, 1.0, 0.1)(_:, _:);
  insert(table<Particle>, 2.0, 0.2)(_:, _:);
  insert(table<Particle>, 3.0, 0.3)(_:, _:);
  insert(table<Particle>, 4.0, 0.4)(_:, _:);
  insert(table<Particle>, 5.0, 0.5)(_:, _:);
  insert(table<Particle>, 6.0, 0.6)(_:, _:);
  insert(table<Particle>, 7.0, 0.7)(_:, _:);
  insert(table<Particle>, 8.0, 0.8)(_:, _:);
  insert(table<Particle>, 9.0, 0.9)(_:, _:);
  insert(table<Particle>, 10.0, 1.0)(_:, _:);
  Particle.pos = Particle.pos + Particle.vel;
  p0 := Particle.pos[0];
  p9 := Particle.pos[9];
  p0i := p0 * 10.0;
  p9i := p9 * 10.0;
  fmt.print("DEBUG: pos array computed\n");
  fmt.assert(p0i == 11, "pos[0] != 1.1\n");
  fmt.assert(p9i == 110, "pos[9] != 11.0\n");
}
