// RUN: %arche -o %t %s && %t | grep "pos"
arche Particle {
  pos :: float,
  vel :: float,
}


static table<Particle>(1000);


sys move(pos, vel) {
  pos = pos + vel;
}


proc main() {
  insert(table<Particle>, 1.0, 0.1);
  insert(table<Particle>, 2.0, 0.2);
  insert(table<Particle>, 3.0, 0.3);
  insert(table<Particle>, 4.0, 0.4);
  insert(table<Particle>, 5.0, 0.5);
  insert(table<Particle>, 6.0, 0.6);
  insert(table<Particle>, 7.0, 0.7);
  insert(table<Particle>, 8.0, 0.8);
  insert(table<Particle>, 9.0, 0.9);
  insert(table<Particle>, 10.0, 1.0);
  Particle.pos = Particle.pos + Particle.vel;
  p0 := Particle.pos[0];
  p9 := Particle.pos[9];
  p0i := p0 * 10.0;
  p9i := p9 * 10.0;
  print("DEBUG: pos array computed\n");
  assert(p0i == 11, "pos[0] != 1.1\n");
  assert(p9i == 110, "pos[9] != 11.0\n");
}
