// RUN: %arche build -o %t %s && %t | grep "Body"
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)
Particle :: arche {
  pos :: float, vel :: float,
}

Body :: arche {
  pos :: float, vel :: float, mass :: float,
}

static table<Particle> (5)

static table<Body> (5)

gravity :: sys (pos, mass) {
  pos = pos + mass;
}

main :: proc() {
  insert(table<Particle>, 1.0, 0.1);
  insert(table<Body>, 2.0, 0.2, 10.0);
  run gravity;
  pp := Particle.pos[0];
  bp := Body.pos[0];
  ppi := pp * 10.0;
  bpi := bp * 10.0;
  assert(ppi == 10, "Particle.pos != 1.0\n");
  assert(bpi == 120, "Body.pos != 12.0\n");
}
