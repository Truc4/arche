arche Transaction {
  price: float,
  hour_bucket: int,
  price_bucket: float,
}

static Transaction(10000000, 10000000) {
  price: 0.0,
  hour_bucket: 0,
  price_bucket: 0.0,
};

proc main() {
  let fd := arche_fopen_read("design_analysis/benchmarks/etl/data/data_10m.csv");

  if (fd > 0) {
    let line: char[256];
    let price_str: char[32];
    let ts_str: char[32];

    arche_fread_line(fd, line, 256);

    let idx := 0;
    for (;idx < 10000000;) {
      let n := arche_fread_line(fd, line, 256);
      if (n <= 0) {
        break;
      }

      let line_pos := 0;
      let field_idx := 0;
      let c0 := 0;
      let c1 := 0;

      for (;line_pos < n;) {
        if (line[line_pos] == ',') {
          field_idx = field_idx + 1;
          if (field_idx == 1) { c0 = line_pos; }
          if (field_idx == 2) { c1 = line_pos; }
        }
        line_pos = line_pos + 1;
      }

      let i := 0;
      for (;i < c0;) {
        ts_str[i] = line[i];
        i = i + 1;
      }
      ts_str[i] = 0;

      let j := 0;
      for (;j < c1 - c0 - 1;) {
        price_str[j] = line[c0 + 1 + j];
        j = j + 1;
      }
      price_str[j] = 0;

      let price := atof(price_str);
      let hour := (ts_str[11] - 48) * 10 + (ts_str[12] - 48);

      Transaction.price[idx] = price;
      Transaction.hour_bucket[idx] = hour;

      idx = idx + 1;
    }

    arche_fclose(fd);

    Transaction.price_bucket = Transaction.price / 10.0;

    let price_sum := 0.0;
    let hour_sum := 0;
    let m := 0;
    for (;m < idx;) {
      price_sum = price_sum + Transaction.price_bucket[m];
      hour_sum = hour_sum + Transaction.hour_bucket[m];
      m = m + 1;
    }

    printf("task3_checksum: %g\n", price_sum);
  } else {
    printf("FAIL: could not open file\n");
  }
}
