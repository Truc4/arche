// RUN: %arche build -o %t %s && %t
#import { io fmt }

cb      :: char;
CharBuf :: arche { cb }
[65536]CharBuf;

main :: proc() {
  io.open("tests/fixtures/data.csv")(fd:);
  fmt.printf("fd=%d\n", fd);
  if (fd > 0) {
    fmt.printf("about to call csv_read_chunk\n");
    scratch := CharBuf.cb[0: CharBuf.capacity]; // slice-local OUT (lint-only: column write outside a query)
    io.read_chunk(fd, 65536)(scratch, rd_v:);
    v := CharBuf.cb[0: rd_v];
    fmt.printf("n=%d\n", v.length);
  }
  io.close(move fd)(_:);
}
