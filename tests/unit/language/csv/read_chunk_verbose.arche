// RUN: %arche -o %t %s && %t
use io;

proc main() {
  fd := io_open("tests/fixtures/data.csv");
  printf("fd=%d\n", fd);
  if (fd > 0) {
    printf("about to call csv_read_chunk\n");
    buf: char[65536];
    buf, n := io_read_chunk(fd, move buf, 65536);
    printf("n=%d\n", n);
  }
  io_close(move fd);
}
