// RUN: %arche build -o %t %s && %t
#import io;

main :: proc () {
  io_open("tests/fixtures/data.csv")(fd:);
  printf("fd=%d\n", fd);
  if (fd > 0) {
    printf("calling csv_read_chunk\n");
    buf: char[65536];
    io_read_chunk(fd, buf, 65536)(buf, n:);
    printf("n=%d\n", n);
  }
  io_close(move fd);
}
