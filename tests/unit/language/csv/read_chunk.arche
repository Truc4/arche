// RUN: %arche build -o %t %s && %t
#import { io fmt }

cb      :: char;
CharBuf :: arche { cb }
[65536]CharBuf;

main :: proc() {
  io.open("tests/fixtures/data.csv")(fd:);
  fmt.printf("fd=%d\n", fd);
  if (fd > 0) {
    fmt.printf("calling csv_read_chunk\n");
    io.read_chunk(fd, CharBuf.cb[0: CharBuf.capacity], 65536)(v:);
    fmt.printf("n=%d\n", v.length);
  }
  io.close(move fd);
}
