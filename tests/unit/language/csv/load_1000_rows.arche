// RUN: %arche build -o %t %s && %t | grep "Loaded 1000 rows"
#import { parse io fmt }
Transaction :: arche { price :: float, quantity :: int }

[1000]Transaction(1000) {
  price: 0.0, quantity: 0,
}

cb      :: char;
CharBuf :: arche { cb }
[50000]CharBuf;

entry :: system {
  io.fopen_read("../../../../../tests/fixtures/data.csv")(fd:);
  price_str : [32]char;
  qty_str   : [32]char;
  scratch := CharBuf.cb[0: CharBuf.capacity]; // slice-local OUT (lint-only: column write outside a query)
  io.fread(fd, 50000)(scratch, rd_data:);
  data := CharBuf.cb[0: rd_data];
  io.fclose(move fd)(_:);
  idx        := 0;
  pos        := 0;
  line_start := 0;
  for (; pos < data.length; pos = pos + 1) {
    if (data[pos] == '\n') {
      line_start = pos + 1;
      break;
    }
  }
  for (; idx < 1000; idx = idx + 1) {
    if (line_start >= data.length) {
      break;
    }
    line_end := line_start;
    for (; line_end < data.length; line_end = line_end + 1) {
      if (data[line_end] == '\n') {
        break;
      }
    }
    c1 := line_start;
    for (; c1 < line_end; c1 = c1 + 1) {
      if (data[c1] == ',') {
        break;
      }
    }
    c2 := c1 + 1;
    for (; c2 < line_end; c2 = c2 + 1) {
      if (data[c2] == ',') {
        break;
      }
    }
    j := 0;
    i := c1 + 1;
    for (; i < c2; i = i + 1) {
      price_str[j] = data[i];
      j            = j + 1;
    }
    price_str[j] = 0;
    j            = 0;
    i            = c2 + 1;
    for (; i < line_end; i = i + 1) {
      qty_str[j] = data[i];
      j          = j + 1;
    }
    qty_str[j]                = 0;
    Transaction.price[idx]    = parse.atof(price_str);
    Transaction.quantity[idx] = parse.atoi(qty_str);
    line_start                = line_end + 1;
  }
  fmt.printf("Loaded %d rows\n", idx);
}

#run entry
