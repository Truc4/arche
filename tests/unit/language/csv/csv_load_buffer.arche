// RUN: %arche build -o %t %s && %t
#import { parse fmt os }
Transaction :: arche { price :: float, quantity :: int }

[100]Transaction(100) {
  price: 0.0, quantity: 0,
}

main :: proc() {
  os.open("../../../../../tests/fixtures/transactions.csv", 0)(fd:);
  buf: [256]char;
  os.read(fd, 256)(buf, rd_data:);
  data := buf[0: rd_data];
  os.close(move fd)(_:);
  fmt.printf("data.length=%d\n", data.length);
  idx        := 0;
  pos        := 0;
  line_start := 0;
  for (; pos < data.length;) {
    if (buf[pos] == '\n') {
      line_start = pos + 1;
      pos        = pos + 1;
      break;
    }
    pos = pos + 1;
  }
  price_str : [32]char;
  qty_str   : [32]char;
  for (; idx < 100;) {
    if (line_start >= data.length) {
      break;
    }
    line_end := line_start;
    for (; line_end < data.length;) {
      if (buf[line_end] == '\n') {
        break;
      }
      line_end = line_end + 1;
    }
    comma_pos := line_start;
    for (; comma_pos < line_end;) {
      if (buf[comma_pos] == ',') {
        break;
      }
      comma_pos = comma_pos + 1;
    }
    j := 0;
    i := line_start;
    for (; i < comma_pos;) {
      price_str[j] = buf[i];
      j            = j + 1;
      i            = i + 1;
    }
    price_str[j] = 0;
    j            = 0;
    i            = comma_pos + 1;
    for (; i < line_end;) {
      qty_str[j] = buf[i];
      j          = j + 1;
      i          = i + 1;
    }
    qty_str[j]                = 0;
    Transaction.price[idx]    = parse.atof(price_str);
    Transaction.quantity[idx] = parse.atoi(qty_str);
    idx                       = idx + 1;
    line_start                = line_end + 1;
  }
  fmt.printf("Loaded %d rows from 256-byte buffer\n", idx);
  fmt.assert(idx > 0, "should load at least 1 row\n");
  fmt.assert(Transaction.price[0] == 1.0, "first price should be 1.0\n");
}
