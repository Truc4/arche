// RUN: %arche -o %t %s && %t
arche Transaction {
  price :: float,
  quantity :: int,
}

static pool<Transaction> (100, 100) {
  price: 0.0, quantity: 0,
}
;

proc main() {
  open("../../../../../tests/fixtures/transactions.csv", 0)(fd:);
  buf: char[256];
  read(fd, buf, 256)(total_n:);
  close(move fd);
  printf("total_n=%d\n", total_n);
  idx := 0;
  pos := 0;
  line_start := 0;
  for (; pos < total_n;) {
    if (buf[pos] == '\n') {
      line_start = pos + 1;
      pos = pos + 1;
      break;
    }
    pos = pos + 1;
  }
  price_str: char[32];
  qty_str: char[32];
  for (; idx < 100;) {
    if (line_start >= total_n) {
      break;
    }
    line_end := line_start;
    for (; line_end < total_n;) {
      if (buf[line_end] == '\n') {
        break;
      }
      line_end = line_end + 1;
    }
    comma_pos := line_start;
    for (; comma_pos < line_end;) {
      if (buf[comma_pos] == ',') {
        break;
      }
      comma_pos = comma_pos + 1;
    }
    j := 0;
    i := line_start;
    for (; i < comma_pos;) {
      price_str[j] = buf[i];
      j = j + 1;
      i = i + 1;
    }
    price_str[j] = 0;
    j = 0;
    i = comma_pos + 1;
    for (; i < line_end;) {
      qty_str[j] = buf[i];
      j = j + 1;
      i = i + 1;
    }
    qty_str[j] = 0;
    Transaction.price[idx] = atof(price_str);
    Transaction.quantity[idx] = atoi(qty_str);
    idx = idx + 1;
    line_start = line_end + 1;
  }
  printf("Loaded %d rows from 256-byte buffer\n", idx);
  assert(idx > 0, "should load at least 1 row\n");
  assert(Transaction.price[0] == 1.0, "first price should be 1.0\n");
}
