// RUN: %arche build -o %t %s && cd %repo && %t | grep "rows: 1000"
#import { io fmt }

cb      :: char;
CharBuf :: arche { cb }
[65536]CharBuf;

entry :: system eff {
  io.open("tests/fixtures/data.csv")(fd:);
  rows    := 0;
  scratch := CharBuf.cb[0: CharBuf.capacity]; // slice-local OUT (lint-only: column write outside a query)
  io.read_chunk(fd, 65536)(scratch, rd_v:);
  v   := CharBuf.cb[0: rd_v];
  pos := 0;
  for (; pos < v.length;) {
    if (v[pos] == 10) {
      rows = rows + 1;
    }
    pos = pos + 1;
  }
  io.close(move fd)(_:);
  rows = rows - 1; // io-as-data: bulk-read the whole file + count newlines in a columnar scan; the first line
  // is the CSV header, so a header-skip is just `newlines - 1` — not a per-char read proc.
  fmt.printf("rows: %d\n", rows);
}

#run entry
