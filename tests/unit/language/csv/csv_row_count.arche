// RUN: %arche build -o %t %s && cd %repo && %t | grep "rows: 1000"
#import { io fmt }

main :: proc() {
  io.open("tests/fixtures/data.csv")(fd:);
  io.skip_header(fd);
  rows := 0;
  buf: char[65536];
  io.read_chunk(fd, buf, 65536)(buf, n:);
  pos := 0;
  for (; pos < n;) {
    if (buf[pos] == 10) {
      rows = rows + 1;
    }
    pos = pos + 1;
  }
  io.close(move fd);
  fmt.printf("rows: %d\n", rows);
}
