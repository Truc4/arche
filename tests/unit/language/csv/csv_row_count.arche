// RUN: %arche -o %t %s && %t | grep "rows: 1000"
use csv;

static buf: char[65536];

proc main() {
  let fd := csv_open("/home/curt/Code/arche/tests/fixtures/data.csv");
  csv_skip_header(fd);
  let rows := 0;
  (buf, let n:) = csv_read_chunk(fd, buf, 65536);
  let pos := 0;
  for (;pos < n;) {
    if (buf[pos] == 10) {
      rows = rows + 1;
    }
    pos = pos + 1;
  }
  csv_close(fd);
  printf("rows: %d\n", rows);
}
