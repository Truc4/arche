// RUN: %arche -o %t %s 2>&1 | grep -q "Error.*bounds\|count.*0"
// Uninitialized alloc has count=0, accessing any row should error

arche Counter {
  val: int,
}

alloc Counter(5);  // capacity 5, but count 0 (no rows)

proc main() {
  let x = Counter.val[0];  // ERROR: out of bounds (count is 0)
  printf("should not reach\n");
}
