// RUN: %arche build -o %t %s && %t
#import { fmt }
pos(x, y) :: float;
vel(x, y) :: float;
Particle  :: arche { pos_x, pos_y, vel_x, vel_y }

[5]Particle ?abort;

entry :: system {
  insert(Particle { pos_x: 0.0, pos_y: 1.0, vel_x: 0.5, vel_y: 0.1 })(_:, _:);
  insert(Particle { pos_x: 2.0, pos_y: 3.0, vel_x: 0.2, vel_y: 0.3 })(_:, _:);
  insert(Particle { pos_x: 4.0, pos_y: 5.0, vel_x: 0.1, vel_y: 0.2 })(_:, _:);
  Particle.pos_x = Particle.pos_x + Particle.vel_x;
  Particle.pos_y = Particle.pos_y + Particle.vel_y;
  fmt.print_float(Particle.pos_x[0])();
  fmt.print(" ")(_:);
  fmt.print_float(Particle.pos_y[0])();
  fmt.print(" ")(_:);
  fmt.print_float(Particle.pos_x[1])();
  fmt.print(" ")(_:);
  fmt.print_float(Particle.pos_y[1])();
  fmt.print(" ")(_:);
  fmt.print_float(Particle.pos_x[2])();
  fmt.print(" ")(_:);
  fmt.print_float(Particle.pos_y[2])();
  fmt.print("\n")(_:);
}

#run entry
