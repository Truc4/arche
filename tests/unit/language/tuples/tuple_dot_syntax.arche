// RUN: %arche -o %t %s && %t
pos :: (x: float, y: float)
vel :: (x: float, y: float)

arche Particle { pos_x, pos_y, vel_x, vel_y }

static pool<Particle>(5);

proc main() {
  insert(Particle, 1.0, 2.0, 0.5, 0.1);
  Particle.pos_x = Particle.pos_x + Particle.vel_x;
  Particle.pos_y = Particle.pos_y + Particle.vel_y;
  let x := Particle.pos_x[0];
  let y := Particle.pos_y[0];
  let xi := x * 10.0;
  let yi := y * 10.0;
  assert(xi == 15, "x != 1.5\n");
  assert(yi == 21, "y != 2.1\n");
}
