// A bare archetype component can reference a top-level tuple group; it expands to the
// group's flat columns — `arche Particle { pos, vel }` == `{ pos_x, pos_y, vel_vx, vel_vy }`.
// So you define the shape once and reference it by name, instead of spelling out members.
// RUN: %arche build -o %t %s && %t | grep "px=1.5 py=2.1"
pos(x, y) :: float
vel(vx, vy) :: float
Particle :: arche { pos, vel }

static pool<Particle> (5)

main :: proc() {
  insert(Particle, 1.0, 2.0, 0.5, 0.1);
  Particle.pos_x = Particle.pos_x + Particle.vel_vx;
  Particle.pos_y = Particle.pos_y + Particle.vel_vy;
  printf("px=%g py=%g\n", Particle.pos_x[0], Particle.pos_y[0]);
}
