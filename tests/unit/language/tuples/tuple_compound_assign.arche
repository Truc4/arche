// RUN: %arche build -o %t %s && %t | grep "2"
#import { fmt }
pos(x, y) :: float;
vel(x, y) :: float;
Particle  :: arche { pos_x, pos_y, vel_x, vel_y }

[5] Particle;

main :: proc() {
  insert(Particle, 1.0, 2.0, 0.5, 0.1)(_:, _:);
  insert(Particle, 3.0, 4.0, 0.2, 0.3)(_:, _:);
  Particle.pos_x = Particle.vel_x;
  Particle.pos_y = Particle.vel_y;
  fmt.print_float(Particle.pos_x[0]);
  fmt.print(" ");
  fmt.print_float(Particle.pos_y[0]);
  fmt.print(" ");
  fmt.print_float(Particle.pos_x[1]);
  fmt.print(" ");
  fmt.print_float(Particle.pos_y[1]);
  fmt.print("\n");
}
