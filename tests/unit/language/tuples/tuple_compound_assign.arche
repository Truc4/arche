// RUN: %arche -o %t %s && %t | grep "2"
pos (x, y) :: float
vel (x, y) :: float

arche Particle {
  pos_x,
  pos_y,
  vel_x,
  vel_y,
}

static pool<Particle>(5);

proc main() {
  insert(Particle, 1.0, 2.0, 0.5, 0.1);
  insert(Particle, 3.0, 4.0, 0.2, 0.3);
  Particle.pos_x = Particle.vel_x;
  Particle.pos_y = Particle.vel_y;
  print(Particle.pos_x[0]);
  print(" ");
  print(Particle.pos_y[0]);
  print(" ");
  print(Particle.pos_x[1]);
  print(" ");
  print(Particle.pos_y[1]);
  print("\n");
}
