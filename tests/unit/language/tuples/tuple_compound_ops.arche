// RUN: %arche build -o %t %s && %t | grep 0.05
pos(x, y) :: float
vel(dx, dy) :: float
acc(i, j) :: float
Particle :: arche {
  pos_x, pos_y, vel_dx, vel_dy, acc_i, acc_j,
}

static pool<Particle> (5)

main :: proc () {
  insert(Particle, 0.0, 0.0, 1.0, 2.0, 0.1, 0.2);
  insert(Particle, 5.0, 5.0, 0.5, 0.5, 0.05, 0.05);
  Particle.vel_dx = Particle.acc_i;
  Particle.vel_dy = Particle.acc_j;
  Particle.pos_x = Particle.vel_dx;
  Particle.pos_y = Particle.vel_dy;
  print(Particle.pos_x[0]);
  print(" ");
  print(Particle.pos_y[0]);
  print(" ");
  print(Particle.pos_x[1]);
  print(" ");
  print(Particle.pos_y[1]);
  print("\n");
}
