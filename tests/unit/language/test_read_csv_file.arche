// RUN: %arche -o %t %s && %t

proc main() {
  let fd = open("../../../../design_analysis/benchmarks/etl/data/data.csv", 0);
  let buf: char[4096];
  let buf, total_n = read(fd, buf, 4096);
  close(fd);
  printf("Read %d bytes from CSV file\n", total_n);
  assert(total_n > 0, "should read CSV file\n");
}

