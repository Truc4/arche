// RUN: %arche build -o %t %s && %t | grep "root=0 user=1:42 file=2:css/app.css miss=-1 dispatch=user 7"
// Exercises the radix router: static exact match, :param capture (span), * catchall capture
// (span), and a miss — then a `match handler_id` dispatch with no function pointers. Captured
// params come back as zero-copy spans into the path; the caller slices its own path.
#import { router }

// Copy path[start..start+len) into buf as a NUL-terminated string (caller-side materialization).
slice :: func(own buf: char[], path: char[], start: int, len: int) -> char[] {
  for (i := 0; i < len; i = i + 1) {
    buf[i] = path[start + i];
  }
  buf[len] = 0;
  return buf;
}

main :: proc() {
  route_init();
  route_add("/", 0);
  route_add("/users/:id", 1);
  route_add("/static/*", 2);

  route_resolve("/")(hroot:);

  up := "/users/42";
  route_resolve(up)(huser:);
  route_param(0)(ust:, uln:);
  ubuf: char[64];
  ubuf := slice(move ubuf, up, ust, uln);

  sp := "/static/css/app.css";
  route_resolve(sp)(hfile:);
  route_param(0)(cst:, cln:);
  cbuf: char[64];
  cbuf := slice(move cbuf, sp, cst, cln);

  route_resolve("/nope")(hmiss:);

  printf("root=%d user=%d:%s file=%d:%s miss=%d ", hroot, huser, ubuf, hfile, cbuf, hmiss);

  // Dispatch on the resolved id — the intended caller pattern.
  route_resolve("/users/7")(h:);
  route_param(0)(dst:, dln:);
  dbuf: char[64];
  dbuf := slice(move dbuf, "/users/7", dst, dln);
  match h {
    0: printf("dispatch=home\n");
    1: printf("dispatch=user %s\n", dbuf);
    2: printf("dispatch=file\n");
    _: printf("dispatch=404\n");
  }
}
