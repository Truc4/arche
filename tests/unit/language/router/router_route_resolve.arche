// RUN: %arche build -o %t %s && %t | grep "home user=42 static=css/app.css notfound"
// Flat-table router: the APP owns the data (a `Route` table + a `Req` pool); `router.resolve` is just the
// fan-and-score LOGIC operating on those pools by query. No trie (index-chasing is hand-indexing, forbidden).
#import { router fmt }

handler :: enum { not_found, home, user, static_files }

// Application data shapes (owned here, not by the router device).
Route :: arche { pattern :: [64]char, hid :: int }
Req   :: arche {
  path       :: [64]char,
  out_h      :: int,
  cap0_start :: int,
  cap0_len   :: int,
  best       :: int,
}

[8]Route ?abort;
[8]Req ?abort;

// Copy path[start..start+len) into buf as a NUL-terminated string (caller-side materialization).
slice :: func(own buf: []char, path: []char, start: int, len: int) -> []char {
  for (i := 0; i < len; i = i + 1) {
    if (i >= buf.length) {
      break;
    }
    k := start + i;
    if (k < 0) {
      break;
    }
    if (k >= path.length) {
      break;
    }
    buf[i] = path[k];
  }
  if (len >= 0 && len < buf.length) {
    buf[len] = 0;
  }
  return buf;
}

seed :: system {
  insert(Route { pattern: "/", hid: handler.home })(_:, _:);
  insert(Route { pattern: "/users/:id", hid: handler.user })(_:, _:);
  insert(Route { pattern: "/static/*", hid: handler.static_files })(_:, _:);

  insert(Req { path: "/", out_h: -1, cap0_start: -1, cap0_len: -1, best: 0 })(_:, _:);
  insert(Req { path: "/users/42", out_h: -1, cap0_start: -1, cap0_len: -1, best: 0 })(_:, _:);
  insert(
    Req { path: "/static/css/app.css", out_h: -1, cap0_start: -1, cap0_len: -1, best: 0 },
  )(_:, _:);
  insert(Req { path: "/nope", out_h: -1, cap0_start: -1, cap0_len: -1, best: 0 })(_:, _:);
}

dispatch :: each (query { path, out_h, cap0_start, cap0_len }) {
  h  := out_h;
  st := cap0_start;
  ln := cap0_len;
  if (h < 0) {
    h = handler.not_found; // remap miss to an explicit variant — no `_` in the enum match
  }
  match h {
  handler.not_found : fmt.printf("notfound ");
  handler.home      : fmt.printf("home ");
  handler.user      : {
    idbuf: [32]char;
    idbuf := slice(move idbuf, path, st, ln);
    fmt.printf("user=%s ", idbuf);
  }
  handler.static_files: {
    tail: [64]char;
    tail := slice(move tail, path, st, ln);
    fmt.printf("static=%s ", tail);
  }
  }
}

done :: system {
  fmt.printf("\n");
}

#run seq({ seed, router.resolve, dispatch, done })
