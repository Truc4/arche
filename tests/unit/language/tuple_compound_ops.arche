// RUN: %arche -o %t %s && %t

arche Particle {
  pos: (x: float, y: float),
  vel: (dx: float, dy: float),
  acc: (i: float, j: float),
}


proc main() {
  alloc Particle(2);
  insert(Particle, 0.0, 0.0, 1.0, 2.0, 0.1, 0.2);
  insert(Particle, 5.0, 5.0, 0.5, 0.5, 0.05, 0.05);
  Particle.vel = Particle.acc;
  Particle.pos = Particle.vel;
  print(Particle.pos.x[0]);
  print(" ");
  print(Particle.pos.y[0]);
  print(" ");
  print(Particle.pos.x[1]);
  print(" ");
  print(Particle.pos.y[1]);
  print("\n");
}

