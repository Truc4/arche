// `sound` and `window` are distinct nominal types though both back to `opaque` — so
// passing a `sound` where a `window` is expected is a compile-time type error. (The cells
// are byte-identical i64s at runtime; the nominal name is what the checker rejects.)
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qiE "(type|sound|window|opaque)" %t.out
sound :: opaque
window :: opaque
extern proc sound_open()(ret: sound);
extern proc window_close(own w: window);

proc main() {
  sound_open()(s:);
  window_close(move s);
}
