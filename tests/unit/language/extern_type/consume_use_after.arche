// Using a resource after it's been consumed (closed) is a compile error. `consume`
// ends the value's life; the checker rejects the later use.
// RUN: %arche -o %t %s > %t.out 2>&1 ; grep -qi "consumed" %t.out
resource :: opaque
extern func resource_open(initial: int) -> resource;
extern proc resource_close(move r: resource);
extern func resource_get(r: resource) -> int;

proc main() {
  r := resource_open(10);
  resource_close(move r);  // not moving should be an error
  v := resource_get(r);
}
