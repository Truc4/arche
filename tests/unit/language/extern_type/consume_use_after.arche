// Using a handle after it's been consumed (closed) is a compile error. `move` into a consuming
// `own` parameter ends the value's life; the checker rejects the later use. Uses the real
// `file` opaque — no FFI stub needed.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "consumed" %t.out
#import { io }
entry :: system {
  io.stdout()(f:);
  io.fclose(move f)(_:);
  // using f after it was consumed should be an error
  io.fwrite(f, "x", 1)(_:);
}

#run entry
