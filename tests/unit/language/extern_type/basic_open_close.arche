// A foreign resource is a nominal opaque-backed type: `resource :: opaque` is distinct in
// the checker but erases to a bare opaque cell (an i64 bitcast to the C pointer at the
// ABI). No extern-table, no handle, no marshal. `consume` on close ends the value's life.
// RUN: %arche build -o %t --link %S/runtime/test_resource.c %s && %t | grep "value=42"

resource :: opaque
extern proc resource_open(initial: int)(ret: resource);
extern proc resource_get(r: resource)(ret: int);
extern proc resource_set(r: resource, v: int);
extern proc resource_close(own r: resource);

proc main() {
  resource_open(10)(r:);
  resource_set(r, 42);
  resource_get(r)(v:);
  printf("value=%d\n", v);
  resource_close(move r);
}
