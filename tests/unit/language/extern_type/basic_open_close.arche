// RUN: %arche -o %t --link %S/runtime/test_resource.c %s && %t | grep "value=42"

extern Resource(8);

extern func resource_open(initial: int) -> handle(Resource);
extern func resource_get(r: handle(Resource)) -> int;
extern proc resource_set(r: handle(Resource), v: int);
extern proc resource_close(consume r: handle(Resource));

proc main() {
  let r := resource_open(10);
  resource_set(r, 42);
  let v := resource_get(r);
  printf("value=%d\n", v);
  resource_close(r);
}
