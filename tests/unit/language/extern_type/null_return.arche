// A C open that fails hands back a null opaque cell (0). Arche can null-check it
// (the only inspection allowed on an opaque value). Here the C pool (8) is exhausted,
// so the 9th open returns null.
// RUN: %arche build -o %t --link %S/runtime/test_resource.c %s && %t | grep "ok_null=1"
#import { fmt }
resource :: opaque;
#foreign {
  resource_open  :: proc(initial: int)(ret: resource);
  resource_close :: proc(own r: resource);
}

entry :: system {
  resource_open(1)(r1:);
  resource_open(2)(r2:);
  resource_open(3)(r3:);
  resource_open(4)(r4:);
  resource_open(5)(r5:);
  resource_open(6)(r6:);
  resource_open(7)(r7:);
  resource_open(8)(r8:);
  resource_open(9)(r9:);
  ok := r9 == 0;
  fmt.printf("ok_null=%d\n", ok);
  // Linear retire: each opaque local (incl. the null r9 — close is null-safe) is consumed.
  resource_close(move r1);
  resource_close(move r2);
  resource_close(move r3);
  resource_close(move r4);
  resource_close(move r5);
  resource_close(move r6);
  resource_close(move r7);
  resource_close(move r8);
  resource_close(move r9);
}

#run entry
