// A C open that fails hands back a null opaque cell (0). Arche can null-check it
// (the only inspection allowed on an opaque value). Here the C pool (8) is exhausted,
// so the 9th open returns null.
// RUN: %arche -o %t --link %S/runtime/test_resource.c %s && %t | grep "ok_null=1"
resource :: opaque
extern func resource_open(initial: int) -> resource;
extern proc resource_close(consume r: resource);

proc main() {
  let r1 := resource_open(1);
  let r2 := resource_open(2);
  let r3 := resource_open(3);
  let r4 := resource_open(4);
  let r5 := resource_open(5);
  let r6 := resource_open(6);
  let r7 := resource_open(7);
  let r8 := resource_open(8);
  let r9 := resource_open(9);
  let ok := r9 == 0;
  printf("ok_null=%d\n", ok);
  // Linear retire: each opaque local (incl. the null r9 — close is null-safe) is consumed.
  resource_close(r1);
  resource_close(r2);
  resource_close(r3);
  resource_close(r4);
  resource_close(r5);
  resource_close(r6);
  resource_close(r7);
  resource_close(r8);
  resource_close(r9);
}
