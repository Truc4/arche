// Pooled foreign resources get generation-checked handles: after a row is deleted and its
// slot reused, an old handle to it is stale and any use aborts loudly. Here `alias`
// outlives the delete+reinsert, so deleting through it aborts.
// RUN: %arche build -o %t --link %S/runtime/test_resource.c %s && ! %t
cell     :: opaque
Resource :: arche { cell }
#foreign {
  resource_open :: proc(initial: int)(ret: cell)
}
Resource[8]

main :: proc() {
  resource_open(10)(r1:);
  insert(Resource, r1)(h:, _:);
  alias := h;
  delete(h)(_:);
  resource_open(99)(r2:);
  insert(Resource, r2)(h2:, _:);
  delete(alias)(_:);
}
