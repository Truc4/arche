// Pooled foreign resources get generation-checked handles: after a row is deleted and its
// slot reused, an old handle to it is stale and any use aborts loudly. Here `alias`
// outlives the delete+reinsert, so deleting through it aborts.
// RUN: %arche -o %t --link %S/runtime/test_resource.c %s && ! %t
cell :: opaque arche Resource {
  cell,
}
extern proc resource_open(initial: int)(ret: cell);
static pool<Resource> (8);

proc main() {
  resource_open(10)(r1:);
  h := insert(Resource, r1);
  alias := h;
  delete(h);
  resource_open(99)(r2:);
  h2 := insert(Resource, r2);
  delete(alias);
}
