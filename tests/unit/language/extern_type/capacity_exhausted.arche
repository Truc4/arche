// Foreign resources can be POOLED: an archetype with an opaque `cell` component, stored
// in a fixed-capacity pool with generation-checked handles. A full pool aborts when
// overrun — here capacity 2, the third insert aborts. (Pooled is the opt-in gen-checked
// path; the by-value `resource :: opaque` path is separate.)
// RUN: %arche -o %t --link %S/runtime/test_resource.c %s && ! %t
cell :: opaque arche Resource {
  cell,
}
extern resource_open(initial: int) -> cell;
static pool<Resource> (2);

proc main() {
  r1 := resource_open(1);
  a := insert(Resource, r1);
  r2 := resource_open(2);
  b := insert(Resource, r2);
  r3 := resource_open(3);
  c := insert(Resource, r3);
}
