// Foreign resources can be POOLED in a table<Resource> (the gen-checked path, opt-in).
// A fixed-capacity table aborts when overrun — here capacity 2, third insert aborts.
// (Capacity/stale safety lives on the pooled path, not on by-value opaque<Resource>.)
// RUN: %arche -o %t --link %S/runtime/test_resource.c %s && ! %t
arche Resource { cell: opaque }
extern func resource_open(initial: int) -> opaque<Resource>;
static table<Resource>(2);

proc main() {
  let a := insert(table<Resource>, resource_open(1));
  let b := insert(table<Resource>, resource_open(2));
  let c := insert(table<Resource>, resource_open(3));
}
