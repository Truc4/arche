// RUN: %arche build -o %t %s && %t | grep "ok n=2 first=104"
// TCP loopback round-trip in one process via net's PUBLIC slice-native wrappers
// (listen/connect/accept/send/recv/close — the raw `net_*` externs are module-private
// now). On localhost, connect() completes via the kernel accept-backlog before accept()
// is called, so it all exercises without threads. Proves the `socket` extern type links
// and a byte survives the round trip ('h' == 104); recv hands back a length-carried view.
#import { net fmt }

main :: proc() {
  net.listen(34567)(srv:);
  net.connect("127.0.0.1", 34567)(cli:);
  net.accept(srv)(conn:);
  net.send(cli, "hi");
  buf: char[64];
  net.recv(conn, buf)(out:);
  fmt.printf("ok n=%d first=%d\n", out.length, out[0]);
  net.close(move cli);
  net.close(move conn);
  net.close(move srv);
}
