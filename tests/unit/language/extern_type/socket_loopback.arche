// RUN: %arche -o %t %s && %t | grep "ok n=2 first=104"
// TCP loopback round-trip in one process: on localhost, connect() completes via
// the kernel accept-backlog before accept() is called, so listen/connect/accept/
// send/recv all exercise without threads. Proves the `Socket` extern type links
// and a byte survives the round trip ('h' == 104).
proc main() {
  srv := net_listen(34567);
  cli := net_connect("127.0.0.1", 34567);
  conn := net_accept(srv);
  sent := net_send(cli, "hi", 2);
  buf: char[64];
  buf, n := recv_into(conn, move buf, 64);
  printf("ok n=%d first=%d\n", n, buf[0]);
  net_close(move cli);
  net_close(move conn);
  net_close(move srv);
}
