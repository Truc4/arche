// A foreign resource (nominal `resource :: opaque`) passed alongside a fill buffer. The C
// side reads the cell and fills the buffer; the resource is a plain param. The buffer is a
// leading return of the multi-return signature `-> (char[], int)` — filled in place, bound
// alongside the scalar at the call.
// RUN: %arche -o %t --link %S/runtime/test_resource.c %s && %t | grep "v=42 b=2"
resource :: opaque
extern func resource_open(initial: int) -> resource;
extern func resource_fill(r: resource, buf: char[], n: int) -> int;
extern proc resource_close(consume r: resource);

proc main() {
  r := resource_open(42);
  buf: char[8];
  v := resource_fill(r, buf, 8);
  printf("v=%d b=%s\n", v, buf);
  resource_close(move r);
}
