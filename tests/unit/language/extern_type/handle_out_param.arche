// A foreign resource (opaque<Resource>) passed alongside an `out` array. The C side
// reads the cell and fills the out buffer; the resource is borrowed (plain param), the
// buffer is `out`.
// RUN: %arche -o %t --link %S/runtime/test_resource.c %s && %t | grep "v=42 b=2"
arche Resource { cell: opaque }
extern func resource_open(initial: int) -> opaque<Resource>;
extern func resource_fill(r: opaque<Resource>, out buf: char[], n: int) -> int;
extern proc resource_close(consume r: opaque<Resource>);

proc main() {
  let r := resource_open(42);
  let buf: char[8];
  let buf, v := resource_fill(r, buf, 8);
  printf("v=%d b=%s\n", v, buf);
  resource_close(r);
}
