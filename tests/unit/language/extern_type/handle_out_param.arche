// A foreign resource (nominal `resource :: opaque`) passed alongside a fill buffer. The C
// side reads the cell and fills the buffer; the resource is a plain param. The buffer is a
// leading return of the multi-return signature `-> (char[], int)` — filled in place, bound
// alongside the scalar at the call.
// RUN: %arche build -o %t --link %S/runtime/test_resource.c %s && %t | grep "v=42 b=2"
#import { fmt }
resource :: opaque
// A file carries one `#foreign` region; all FFI decls live together here. `resource_fill`'s `buf`
// is filled by C, so it must be handed back: in-out (its name is also in the out-list).
#foreign {
  resource_open :: proc(initial: int)(ret: resource)
  resource_fill :: proc(r: resource, buf: char[], n: int)(buf: char[], ret: int)
  resource_close :: proc(own r: resource)
}

main :: proc() {
  resource_open(42)(r:);
  buf: char[8];
  resource_fill(r, buf, 8)(buf, v:);
  fmt.printf("v=%d b=%s\n", v, buf);
  resource_close(move r);
}
