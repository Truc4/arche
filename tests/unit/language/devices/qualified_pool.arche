// A driver sizes a plain (path-imported) module's shape and reads it back — the caller picks the
// storage size. `phys` is a plain module → it merges FLAT, so its `Particle` shape is bare (no
// `phys.` prefix); the driver writes `Particle[8]`.
// RUN: %arche build -o %t %s && %t | grep "qualified_pool_ok"
#import { "./phys" fmt }

Particle[8]

main :: proc() {
  insert(Particle, 10.0, 1.0);
  p0  := Particle.pos[0];
  p0i := p0 * 10.0;
  fmt.assert(p0i == 100, "expected pos[0]==10.0\n");
  fmt.printf("qualified_pool_ok\n");
}
