// Both `diskc` and `diskd` declare the SAME opaque type name, `file`. Because datasheet types are
// shared global vocabulary, the two `file`s ARE the same type — no `@implements` bridge is needed.
// A borrowed `file` is accepted by both `diskc.tag` and `diskd.stash` directly. This should just
// work (GREEN). `h` is a borrow param — no handle is ever created.
// RUN: %arche build -o %t %s && %t
#import { diskc diskd }

@allow(unused_function)
relay :: func(h: file) -> int {
  return diskc.tag(h) + diskd.stash(h);
}

main :: proc() {
}
