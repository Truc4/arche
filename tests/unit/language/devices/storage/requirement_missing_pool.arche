// The driver imports the `store` device (which defines its `Node` shape and requires storage for it)
// but provides NO pool. Since the driver owns all storage, a required-but-unprovided shape is a hard
// error pointing the user at `arche fill`.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qiE "no storage" %t.out
#import { store fmt }

// no `Node[N]` pool — the store device's `Node` requirement is unmet

main :: proc() {
  run store.bump;
  fmt.printf("should_not_build\n");
}
