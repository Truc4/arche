// A DEVICE doctest: `widget` defines its `Particle` shape here in the impl (a device that uses a shape
// defines it where it uses it) and its datasheet states the `pos`/`vel` components + a `Particle[4]`
// storage requirement. The doctest drives the device's OWN shape — `arche test` compiles it as a
// generated driver over the whole device folder, so the requirement becomes the real pool with no
// manual sizing in the example.
// RUN: %arche test %s | grep -q "ok"
@default(proc, pool, abort) // fixture: overflow is a test-setup error, not a branch
#import { fmt }

Particle :: arche { pos, vel }

/// ```arche
/// seed :: system eff {
///   insert(Particle{ pos: 10.0, vel: 1.0 })(_:, _:);
/// }
/// check :: system eff {
///   fmt.assert(Particle.pos[0] * 10 == 110, "device doctest did not drive its shape\n")();
///   fmt.printf("widget_doctest_ok\n");
/// }
/// #run seq({ seed, integrate, check })
/// ```
integrate :: map (query { pos, vel }) (pos) {
  pos = pos + vel;
}
