// The driver sizes the `store` device's `Node` pool BELOW the datasheet minimum (4). The compiler
// must reject it: the driver owns sizing, but it must meet the device's stated minimum requirement.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qiE "requires" %t.out
#import { store fmt }

[2]Node; // below the datasheet minimum of 4 — must error (the shape comes from store)

seed :: system eff {
  insert(Node { key: 2.0, val: 3.0 })(_:, _:);
}

verify :: system eff {
  fmt.printf("should_not_build\n");
}

#run seq({ seed, store.bump, verify })
