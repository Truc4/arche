// Pre-defined-component style + sharing: `vstore` and `vcache` both declare the same pre-defined
// components (`a`/`b`) and shape (`Cell`), with minimums 4 and 16. They dedup to one shared shape and
// one driver pool sized to the max (16). The build notes the shared shape; both devices' systems run.
// RUN: %arche build -o %t %s 2> %t.err && %t | grep "predef_shared_ok" && grep -qiE "shared pool|datasheets require" %t.err
#import { vstore vcache fmt }

[16]Cell; // one pool (the shape comes from the devices), sized to max(4, 16)

seed :: system {
  insert(Cell { a: 1.0, b: 2.0 })(_:, _:);
}

verify :: system {
  fmt.assert(Cell.b[0] == 3.0, "vstore.vbump did not run\n");
  fmt.assert(Cell.a[0] == 2.0, "vcache.vtouch did not run\n");
  fmt.printf("predef_shared_ok\n");
}

// vstore.vbump (b 2→3) then vcache.vtouch (a 1→2) over the one shared pool, then verify
#run seq({ seed, vstore.vbump, vcache.vtouch, verify })
