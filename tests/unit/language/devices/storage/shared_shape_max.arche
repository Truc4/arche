// Two devices (`store`, `cache`) require the SAME shared `Node {key, val}` shape with different
// minimums (4 and 16). They fold to ONE driver pool; its size must meet the MAX of the minimums (16).
// The build emits a note that the shape is shared. This driver sizes the one pool at 16 and runs both
// devices' systems over it.
// RUN: %arche build -o %t %s 2> %t.err && %t | grep "shared_ok" && grep -qiE "shared pool|both require|datasheets require" %t.err
#import { store cache fmt }

Node[16] // one pool (the shape comes from the devices), sized to the max of store's 4 and cache's 16

main :: proc() {
  insert(Node, 2.0, 3.0);
  run store.bump; // val: 3 -> 4
  run cache.touch; // key: 2 -> 3
  fmt.assert(Node.val[0] == 4.0, "store.bump did not run\n");
  fmt.assert(Node.key[0] == 3.0, "cache.touch did not run\n");
  fmt.printf("shared_ok\n");
}
