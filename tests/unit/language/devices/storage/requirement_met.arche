// A driver provides a pool for the `store` device's `Node` shape, sized >= the datasheet minimum (4).
// `store` defines the shape (it comes in via the import); the datasheet states the components + the
// storage requirement (no definition); the driver owns the real allocation and the device's system
// drives it.
// RUN: %arche build -o %t %s && %t | grep "req_ok"
#import { store fmt }

Node[8] // driver owns the pool (the shape comes from store), sized above the minimum of 4

main :: proc() {
  insert(Node, 2.0, 3.0)(_:, _:);
  run store.bump;
  fmt.assert(Node.val[0] == 4.0, "store.bump did not run over the driver's pool\n");
  fmt.printf("req_ok\n");
}
