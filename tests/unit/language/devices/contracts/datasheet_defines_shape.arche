// The `dsshape` device's datasheet defines a shape (`Box :: arche { v }`) — illegal. A datasheet
// describes requirements, not definitions, so a build that imports the device must error.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qiE "datasheet describes requirements, not shapes" %t.out
#import { dsshape }

#run seq({ dsshape.poke })
