// RULE: a device's implementation (`.arche`) may not define a TYPE or allocate a pool — types are the
// device's shared vocabulary (they belong in its `.ds.arche` datasheet) and allocation is the driver's
// alone. (A SHAPE, by contrast, MAY be defined in the impl that uses it.) `leakdev`'s impl defines
// `handle :: opaque` — a type in a device impl — so a build that imports leakdev must error.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qiE "error.*(device.*(type|alloc)|defined in a device|datasheet)" %t.out
#import { leakdev }

Thing :: arche { val } // references the datasheet's global `val`

Thing[2]

main :: proc() {
  insert(Thing, 1.0);
  run leakdev.bump;
}
