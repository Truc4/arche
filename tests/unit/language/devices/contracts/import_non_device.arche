// RULE (enforced): you import a DEVICE by name and a plain MODULE by path. A bare name in
//   `#import { … }` must resolve to a device (a unit with a `.ds.arche` datasheet); a non-device
//   imported by bare name is an error telling you to import it by path instead
//   (`#import { "./plainmod" }`). `plainmod` has no datasheet, so importing it by name errors.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qiE "by path|not a device|import .* by path|only devices.*by name" %t.out
#import { plainmod }

entry :: system {
  _v := plainmod.greet();
}

#run entry
