// `diska` behavior: hands out its `file1` handle (forged in-device), inspects it, and releases it.
// The forge (`file1(11)`) is legal here because this is the declaring device's impl. Not a
// standalone test.
// RUN: true
@allow(proc_could_be_func)
acquire :: proc()(h: file1) {
  h = file1(11);
}
tag :: func(h: file1) -> int {
  return 1;
}
@allow(proc_no_effect)
release :: proc(own h: file1) {
  h = file1(0);
}
