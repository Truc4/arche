// END GOAL: one opaque type implements TWO devices' handle types. `file` is declared to implement
// both `diska.file1` and `diskb.file2`, so a single borrowed `file` is accepted by `diska.tag`
// (wants file1) AND `diskb.stash` (wants file2) — the same handle is usable for BOTH devices.
// Without the cross-device `@implements` unification, file1/file2 are distinct opaque siblings and
// `diskb.stash(h)` is a type error (`expected 'file2', got 'file1'`). Compile-success = the types
// unified. No handle is ever created (opaques only come from FFI); `h` is a borrow param.
// RUN: %arche build -o %t %s && %t
#import { diska diskb }

@implements(diska.file1, diskb.file2)
file :: opaque;

@allow(unused_function)
relay :: func(h: file) -> int {
  return diska.tag(h) + diskb.stash(h);
}

entry :: system {
}

#run entry
