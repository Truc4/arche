// clink impl: a pure-Arche wrapper over the C shim. The `#link { "m" }` pulls libm (the shim calls
// pow), and clink_c.c is compiled + linked automatically because it sits in this device folder.
// Not a standalone test.
// RUN: true
#link {
  "m"
}

cube_root :: func(x: float) -> Eff(float) {
  return clink_cbrt(x);
}

#module
#foreign {
  clink_cbrt :: proc(x: float)(r: float);
}
