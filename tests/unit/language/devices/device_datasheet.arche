// Model B: a driver owns the shape under its OWN names, built from a device's datasheet components,
// and the device's system runs over it. `libdev`'s datasheet (`.ds.arche`) declares `pos`/`vel` as
// GLOBAL components; this driver's `Thing` references them by bare name (plus its own `mass`), sizes
// the pool, and `run libdev.integrate` binds to `Thing` by column name — the device owns no storage.
// RUN: %arche build -o %t %s && %t | grep "datasheet_ok"
#import { libdev fmt }

Thing :: arche { pos, vel, mass :: float }

[4] Thing;

main :: proc() {
  insert(Thing, 10.0, 1.0, 5.0)(_:, _:);
  run libdev.integrate; // pos = pos + vel = 11 over the driver's Thing pool
  fmt.assert(Thing.pos[0] * 10 == 110, "device system did not run over the driver's shape\n");
  fmt.printf("datasheet_ok\n");
}
