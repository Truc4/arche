// An entity literal `Foo{…}` populates the named shape's pool, read back through `Foo.x`. (Entities
// replaced the old positional `insert(arche{x,y}, …)` anonymous-literal target.)
// RUN: %arche build -o %t %s && %t | grep "literal_ok"
#import { fmt }
Foo :: arche { x :: float, y :: float }

[4]Foo ?abort;

entry :: system {
  insert(Foo { x: 1.0, y: 2.0 })(_:, _:);
  v := Foo.x[0] * 10.0;
  fmt.assert(v == 10, "x[0] != 1.0 — entity did not populate Foo's pool\n")();
  fmt.printf("literal_ok\n");
}

#run entry
