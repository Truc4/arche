// The wayland VARIANT of vgfx: merged only under `ARCHE_SELECT=vgfx=wayland`. Defines `open_window`
// (the same surface as x11) but NOT `x11_only` — so a call to `vgfx.x11_only` must fail under this
// backend, in BOTH the compiler and the analyzer. Not a standalone test.
// RUN: true
#import { fmt }
open_window :: proc() {
  fmt.print("wayland window\n")(_:);
}
