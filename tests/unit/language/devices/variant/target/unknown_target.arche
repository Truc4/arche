// Typo guard: an explicitly-requested target that names no `[target.<name>]` table warns on stderr
// (so a typo'd `--target` isn't silent). The build still succeeds here because tsnd resolves from the
// `[select]` base regardless of the active target.
// RUN: %arche build --target bogus -o %t %s 2>&1 | grep -F "[target.bogus] table"
// RUN: %t | grep -qF "tsnd alsa"
#import { tsnd }
entry :: system eff {
  tsnd.beep()(_:);
}

#run entry
