// RUN: %arche -o %t %s && %t

arche Particle {
  pos: (x: float, y: float),
  vel: (x: float, y: float),
}



proc main() {
  insert(Particle, 0.0, 1.0, 0.5, 0.1);
  insert(Particle, 2.0, 3.0, 0.2, 0.3);
  insert(Particle, 4.0, 5.0, 0.1, 0.2);
  Particle.pos = Particle.pos + Particle.vel;
  print(Particle.pos.x[0]);
  print(" ");
  print(Particle.pos.y[0]);
  print(" ");
  print(Particle.pos.x[1]);
  print(" ");
  print(Particle.pos.y[1]);
  print(" ");
  print(Particle.pos.x[2]);
  print(" ");
  print(Particle.pos.y[2]);
  print("\n");
}

