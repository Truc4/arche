// RUN: %arche -o %t %s && %t

arche Particle {
  pos_x: float,
  pos_y: float,
}


proc main() {
  alloc Particle(1);
  insert(Particle, 1.0, 2.0);
  let x = Particle.pos_x[0];
  let y = Particle.pos_y[0];
  let xi = x * 10.0;
  let yi = y * 10.0;
  assert(xi == 10, "x != 1.0\n");
  assert(yi == 20, "y != 2.0\n");
}

