// Early return from a func; the value before the early `return` is what's bound (was a proc out-param).
// RUN: %arche build -o %t %s && %t | grep "a=0 b=10"
#import { fmt }
f :: func(x: int) -> int {
  if (x < 0) {
    return 0;
  }
  return x * 2;
}

entry :: system {
  a := f(-1);
  b := f(5);
  fmt.printf("a=%d b=%d\n", a, b);
}

#run entry
