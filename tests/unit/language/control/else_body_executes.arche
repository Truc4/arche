// Regression: `if/else` else-bodies were once silently dropped (the AST builder and lowerer
// looked for a non-existent SN_ELSE_CLAUSE node; the parser emits then/else flat, split on the
// `else` token). Each else here must actually run: expect B, C, F.
// RUN: %arche build -o %t %s && %t | tr '\n' ' ' | grep -q "B C F"
#import { fmt }
entry :: system eff {
  x := 5;
  if (x == 1) {
    fmt.print("A\n")(_:);
  }
  else {
    fmt.print("B\n")(_:);
  }
  if (x == 5) {
    fmt.print("C\n")(_:);
  }
  else {
    fmt.print("D\n")(_:);
  }
  if (x == 1) {
    fmt.print("E\n")(_:);
  }
  else {
    if (x == 5) {
      fmt.print("F\n")(_:);
    }
    else {
      fmt.print("G\n")(_:);
    }
  }
}

#run entry
