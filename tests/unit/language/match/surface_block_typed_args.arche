// A standalone `{ }` block is a nested scope; name refs inside it must still get their real types. A
// FLOAT and an OPAQUE (resource) value passed to a proc from INSIDE a block — both previously
// defaulted to i32 because semantic didn't analyze block bodies (the block was an empty STMT_EXPR).
// Regression for the `cst_build_stmt` SN_BLOCK desugar. Uses a foreign `resource` opaque.
// RUN: %arche build -o %t --link %S/../extern_type/runtime/test_resource.c %s && %t | grep -q "^x=3.5 r=42$"
#import { fmt }
resource :: opaque
#foreign {
  resource_open :: proc(initial: int)(r: resource)
  resource_get  :: proc(r: resource)(v: int)
  @drop(resource)
  resource_close :: proc(own r: resource)
}
take :: proc(x: float, r: resource)(v: int) {
  resource_get(r)(rv:);
  v = rv;
  fmt.printf("x=%g ", x);
}
main :: proc() {
  ff := 3.5;
  resource_open(42)(h:);
  {
    take(ff, h)(v:);
    fmt.printf("r=%d\n", v);
  }
  resource_close(move h);
}
