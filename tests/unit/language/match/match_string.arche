// match on string literals → if-chain of streq (pure-arche byte compare); `_` is
// the catch-all. The scrutinee is inlined per arm.
// RUN: %arche build -o %t %s && %t | grep "about"
#import { fmt }
route :: proc(path: []char)() {
  match path {
  "/"      : fmt.printf("home\n");
  "/about" : fmt.printf("about\n");
  _        : fmt.printf("404\n");
  }
}

entry :: system {
  route("/about")();
  route("/")();
  route("/xyz")();
}

#run entry
