// `continue` in an `each` skips the rest of the current element's body and advances to the next row — an
// `each` is a sequential per-element fan (the control-flow-allowed sibling of `map`), so `continue` is an
// ordinary loop continue, used here as guard clauses. Rows with v==1/2 take an early path; the rest fall
// through to 99.
// RUN: %arche build -o %t %s && %t | grep -q "^10 20 99 99 $"
#import { fmt }
S :: arche { v :: int, out :: int }
[4]S(4);

seed :: system {
  S.v = { 1, 2, 3, 4 };
}

guard :: map (query { v, out }) eff {
  if (v == 1) {
    out = 10;
    continue;
  }
  if (v == 2) {
    out = 20;
    continue;
  }
  out = 99;
}

show :: map (query { out }) eff {
  fmt.printf("%d ", out);
}

tail :: system eff {
  fmt.printf("\n");
}

#run seq({ seed, guard, show, tail })
