// The explicit longhand `name : type : <callable>` works the same as `::` (was proc types; proc removed).
// RUN: %arche build -o %t %s && %t | grep "code=404 r=-7"
#import { fmt }
handler : type : func() -> int;
unop    : type : func(a: int) -> int;
not_found :: func() -> int {
  return 404;
}
negate :: func(a: int) -> int {
  return -a;
}
h : handler : not_found;
g : unop    : negate;
entry :: system {
  c := h();
  r := g(7);
  fmt.printf("code=%d r=%d\n", c, r);
}
#run entry
