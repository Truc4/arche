// A callable alias binds a name to an existing func value; calls through the alias dispatch to the target.
// RUN: %arche build -o %t %s && %t | grep "code=404 sum=7"
#import { fmt }
not_found :: func() -> int {
  return 404;
}
add :: func(a: int, b: int) -> int {
  return a + b;
}
handler :: not_found;
plus    :: add;
entry   :: system {
  c := handler();
  s := plus(3, 4);
  fmt.printf("code=%d sum=%d\n", c, s);
}
#run entry
