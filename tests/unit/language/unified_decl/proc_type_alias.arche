// A named proc TYPE (`handler :: proc()(...)`, structural) annotating a top-level default binding.
// proc/func type names are lowercase (Uppercase is reserved for archetypes).
// RUN: %arche build -o %t %s && %t | grep "code=404"
#import { fmt }
handler :: proc()(code: int);

not_found :: proc()(code: int) {
  code = 404;
}

h: handler: not_found;

main :: proc() {
  h()(c:);
  fmt.printf("code=%d\n", c);
}