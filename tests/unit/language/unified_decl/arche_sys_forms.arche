// Unified grammar: archetype and sys declared as RHS value forms
// (`Name :: arche { ... }`, `name :: sys(...) { ... }`).
// RUN: %arche build -o %t %s && %t | grep "pos0=3"
pos :: float

Particle :: arche { pos }

static pool<Particle> (10)

bump :: sys (pos) {
  pos = pos + 2.0;
}

main :: proc() {
  insert(Particle, 1.0);
  run bump;
  printf("pos0=%f\n", Particle.pos[0]);
}
