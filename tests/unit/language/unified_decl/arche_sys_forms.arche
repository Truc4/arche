// Unified grammar: archetype and sys declared as RHS value forms
// (`Name :: arche { ... }`, `name :: map (...) { ... }`).
// RUN: %arche build -o %t %s && %t | grep "pos0=3"
#import { fmt }
pos :: float;

Particle :: arche { pos }

[10]Particle;

bump :: map (query { pos }) {
  pos = pos + 2.0;
}

main :: proc() {
  insert(Particle { pos: 1.0 })(_:, _:);
  run bump;
  fmt.printf("pos0=%f\n", Particle.pos[0]);
}
