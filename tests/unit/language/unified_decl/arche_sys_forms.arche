// Unified grammar: archetype and sys declared as RHS value forms
// (`Name :: arche { ... }`, `name :: map (...) { ... }`).
// RUN: %arche build -o %t %s && %t | grep "pos0=3"
#import { fmt }
pos :: float;

Particle :: arche { pos }

[10]Particle ?abort;

bump :: map (query { pos }) (pos) {
  pos = pos + 2.0;
}

seed :: system eff {
  insert(Particle { pos: 1.0 })(_:, _:);
}

verify :: system eff {
  fmt.printf("pos0=%f\n", Particle.pos[0]);
}

#run seq({ seed, bump, verify })
