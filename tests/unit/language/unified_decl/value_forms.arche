// Unified grammar: func value form; what was a proc out-param is now a func return.
// RUN: %arche build -o %t %s && %t | grep "sum=12 d=6"
#import { fmt }
add :: func(a: int, b: int) -> int {
  return a + b;
}
double :: func(x: int) -> int {
  return x + x;
}
entry :: system eff {
  s := add(5, 7);
  d := double(3);
  fmt.printf("sum=%d d=%d\n", s, d);
}
#run entry
