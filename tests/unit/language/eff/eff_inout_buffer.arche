// FEATURE (caller-allocated OUT buffer through func→Eff): an extern whose buffer is written by the callee
// is exposed as a func→Eff whose buffer is the caller-allocated OUT param, NOT an in-arg. The in-list `_`
// is only the C-ABI positional shadow; the out-binding `filled: [8]char` ALLOCATES the buffer the kernel
// fills (the `:` means allocate). The run site binds the written buffer to `filled` — `eff_fill` writes
// "XYZ" into it and returns 3 → r=3 filled=XYZ. (Non-extern shim, so this also proves the mechanism does
// not depend on @syscall — any callee-written extern buffer works.)
// RUN: %arche build -o %t --link %S/runtime/effshim.c %s && %t | grep -qF "r=3 filled=XYZ"
#foreign {
  eff_fill :: proc(s: i64, buf: []char, n: int)(buf: []char, r: int);
}
#import { fmt }

recv :: func(s: i64, n: int) -> Eff([]char, int) {
  return eff_fill(s, _, n); // `_` is the C-ABI in-slot; the buffer is the OUT
}

entry :: system {
  recv(0, 8)(filled: [8]char, r:); // `:` allocates the OUT here; the kernel fills it
  fmt.printf("r=%d filled=%c%c%c\n", r, filled[0], filled[1], filled[2]);
}

#run entry
