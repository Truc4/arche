// FEATURE: an INPUT-buffer wrapper as a `func → Eff`. `sleep_ms` builds the timespec the kernel READS,
// element-by-element (no array literal — that path miscompiles `[N]i64`), then under-applies the
// nanosleep extern. The func→Eff fusion must emit the builder's input-build prelude (the `req[i] = …`
// stores) at the run site, so the kernel reads a REAL duration — not a NULL/uninitialized `req`. We prove
// it actually slept by measuring elapsed monotonic time: a no-op sleep (fusion dropping the prelude)
// returns instantly and fails the lower-bound assert. The `system` consumer path is arche-rpg's `io`.
// RUN: %arche build -o %t %s && %t | grep -qF "slept ok"
#import { fmt os }

#foreign {
  @syscall(35)
  sys_nanosleep :: proc(req: []i64, rem: i64)(r: i64);
}

nanosleep :: func(req: []i64) -> Eff(i64) {
  return sys_nanosleep(req, 0);
}

sleep_ms :: func(ms: int) -> Eff(i64) {
  m := i64(ms);
  if (m < 0) {
    m = 0;
  }
  req: [2]i64;
  req[0] = m / 1000;
  req[1] = (m % 1000) * 1000000;
  return nanosleep(req);
}

entry :: system {
  os.now_ms()(t0:);
  sleep_ms(50)(_:); // run the func→Eff; must actually sleep ~50ms
  os.now_ms()(t1:);
  sleep_ms(-5)(_:); // nonpositive clamps to 0 — a no-op, must not crash
  d := t1 - t0;
  // sleep is a LOWER bound (the kernel never undershoots); a no-op sleep gives d≈0. 40ms margin.
  fmt.assert(d >= 40, "sleep_ms(50) must elapse at least ~50ms (a no-op sleep elapses ~0)\n")();
  fmt.printf("slept ok\n");
}

#run entry
