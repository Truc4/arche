// Regression: a func/proc called ONLY from a system body must NOT be flagged W0013. Systems are
// entry points (invoked by `run`, which records no call edge), so the reachability pass seeds every
// `sys` and walks its body. Before the id-keyed rewrite, `log_step` here was a false positive.
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "W0013 unused_function") -eq 0
#import { fmt }
Particle :: arche { pos :: float, vel :: float }
[10]Particle;
log_step :: proc() {
  fmt.print("step\n")(_:);
}
move_sys :: map (query { pos, vel }) (pos) {
  pos = pos + vel;
  log_step()();
}
seed :: system eff {
  insert(Particle { pos: 1.0, vel: 2.0 })(_:, _:);
}

#run seq({ seed, move_sys })
