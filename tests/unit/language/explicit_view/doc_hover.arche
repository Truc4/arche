// Hover: the analyzer emits a DOC line for each documented declaration, with its
// `///` text following as DOCLINE entries (the editor renders these on hover).
// RUN: %build/arche-analyzer --dump %s | grep -qF "DOC "
// RUN: %build/arche-analyzer --dump %s | grep -qF "DOCLINE Adds two integers."

/// Adds two integers.
func add(a: int, b: int) -> int {
  return a + b;
}
