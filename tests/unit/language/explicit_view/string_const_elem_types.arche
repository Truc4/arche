// A value-array const's inferred inlay type reads the literal's TRUE structure: a string leaf is a
// `[W]char` (its own char dimension), not a scalar. So a 1-D string table is `[R][W]char`, and a
// nested matrix OF strings is `[R][C][W]char` (3-D — the string dimension is NOT collapsed away).
// An int matrix stays `[R][C]i32`. Regression: a string leaf was once mis-typed as `i32`, then as a
// flat `[R][C]char` that dropped the string's `[W]` dimension.
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 10 4 1 1 type [2][2]char"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 12 4 1 1 type [2][3][1]char"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 14 4 1 1 type [2][3]i32"
#import { fmt }
S :: { "ab", "cd" }

M :: { { "1", "2", "3" }, { "4", "5", "6" } }

N :: { { 1, 2, 3 }, { 4, 5, 6 } }

entry :: system {
  fmt.printf("%d%d\n", S[0].length, N[1][2]);
}

#run entry
