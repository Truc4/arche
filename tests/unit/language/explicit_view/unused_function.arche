// W0013: warn on a top-level func never reachable from a root (Rust `dead_code`).
// Roots: the `#run` entry (and what it transitively reaches), externs/#foreign, module decls,
// `_`-prefixed, @allow'd. Reachability handles mutual recursion (an unreachable cycle still warns
// for every member).
//
// Exactly these warn: `dead_func`, `c_only` (c↔d unreachable cycle), `d_only`. That's 3.
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "W0013 unused_function") -eq 3
// RUN: %build/arche-analyzer --dump %s | grep -qF "W0013 unused_function 0 function 'dead_func'"
// RUN: %build/arche-analyzer --dump %s | grep -qF "W0013 unused_function 0 function 'c_only'"
// RUN: %build/arche-analyzer --dump %s | grep -qF "W0013 unused_function 0 function 'd_only'"
// These must NOT warn (reached from the entry, _-prefix, @allow):
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "unused_function 0 function 'reached_func'") -eq 0
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "unused_function 0 function '_scratch'") -eq 0
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "unused_function 0 function 'quiet'") -eq 0
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "unused_function 0 function 'hush'") -eq 0
#import { fmt }

reached_func :: func(a: int) -> int {
  return a + 1;
}

dead_func :: func(a: int) -> int {
  return a + 2;
}
_scratch :: func(a: int) -> int {
  return a + 3;
}
@allow(unused_function)
quiet :: func(a: int) -> int {
  return a + 4;
}
@allow(dead_code)
hush :: func(a: int) -> int {
  return a + 5;
}

// mutually-recursive but unreachable from the entry — both must warn.
c_only :: func(a: int) -> int {
  return d_only(a);
}
d_only :: func(a: int) -> int {
  return c_only(a);
}

entry :: system {
  r := reached_func(2);
  fmt.printf("%d\n", r);
}

#run entry
