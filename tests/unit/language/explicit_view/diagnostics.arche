// Explicit view: semantic errors + lints emerge as DIAG lines with positions translated to user-file
// coordinates. Wire protocol: DIAG <line> <col> <severity> <code> <slug> <note_count> <message>.
// RUN: %build/arche-analyzer --dump %s | grep -qF "error E0001 undefined_symbol 0 Undefined symbol 'unknown_thing'"
// RUN: %build/arche-analyzer --dump %s | grep -qF "proc_not_primitive"
// Error carries the offending expression's position (the name token).
// RUN: %build/arche-analyzer --dump %s 2>/dev/null | grep -qxE "^DIAG 8 [0-9]+ error E0001 undefined_symbol 0 Undefined symbol 'unknown_thing'"
entry :: system {
  x := unknown_thing;
}
noop :: proc() {
}

#run entry
