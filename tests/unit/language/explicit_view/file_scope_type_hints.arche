// Inferred-type inlays are CONSISTENT at file scope: a value const, a static global, and a name-const
// each fill their elided ⟨type⟩ slot exactly like a local `:=`/`::`. A func/proc/sys/arche decl spells
// its type in the form itself, so its inlay is redundant and HIDDEN by default (opt in: full_type_hints).
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 10 8 1 1 type i32"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 11 8 1 1 type i32"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 12 8 1 1 type i32"
// exactly those three — the func and proc decls add no type inlay by default:
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -cF " type ") -eq 3
#import { fmt }
MAX   :: 100
count := 0
total :: MAX
add   :: func(a: int, b: int) -> int {
  return a + b;
}
main :: proc() {
  fmt.print("x\n")();
}
