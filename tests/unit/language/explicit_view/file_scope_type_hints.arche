// Type inlays at file scope: a value const, a static global, and a name-const each fill their elided
// ⟨type⟩ slot exactly like a local `:=`/`::`. By DEFAULT the redundant definition-forms (func/proc/…)
// are HIDDEN by the editor's exception list; they render only when the editor opts into full hints
// (`--full` / `HINTS full`) — a presentation choice, never a compiler one.
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 15 8 1 1 type i32"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 16 8 1 1 type i32"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 17 8 1 1 type i32"
// exactly those three by default — the func and proc decls are redundant forms, hidden:
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -cF " type ") -eq 3
// --full opts out of hiding, so the func and proc decls then show their form types too:
// RUN: %build/arche-analyzer --dump --full %s | grep -qxF "SYN 18 8 1 1 type func(i32, i32) -> i32"
// RUN: %build/arche-analyzer --dump --full %s | grep -qxF "SYN 21 7 1 1 type proc()()"
// RUN: test $(%build/arche-analyzer --dump --full %s 2>/dev/null | grep -cF " type ") -eq 5
#import { fmt }
MAX   :: 100;
count := 0;
total :: MAX;
add   :: func(a: int, b: int) -> int {
  return a + b;
}
main :: proc() {
  fmt.print("x\n")();
}
