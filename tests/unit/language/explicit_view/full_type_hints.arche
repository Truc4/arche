// Form decls (func/proc/sys/policy/arche) carry a type, and with NO redundancy filtering it is SHOWN by
// default — even though the form already spells it — in Arche's own spelling. (`--full` is currently a
// no-op; the thin hide-the-redundant layer comes later.)
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 14 6 1 1 type func(i32, i32) -> i32"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 17 7 1 1 type proc(i32, i32)(i32, i32)"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 25 7 1 1 type sys(pos, vel)"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 23 11 1 1 type archetype"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 28 7 1 1 type proc()()"
// every form spelling is present by default (func/proc/sys/archetype all show):
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -cE "type (func|proc|sys|archetype)") -eq 5
// the pos/vel component aliases also show (an alias denotes the `type` meta):
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 21 11 1 1 type type"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 22 11 1 1 type type"
add :: func(a: int, b: int) -> int {
  return a + b;
}
swap :: proc(a: int, b: int)(x: int, y: int) {
  x = b;
  y = a;
}
pos      :: float
vel      :: float
Particle :: arche { pos, vel }
Particle[2](2)
step :: sys (pos, vel) {
  pos = pos + vel;
}
main :: proc() {
  run step;
}
