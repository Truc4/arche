// Support module for unused_function_module.arche (not a standalone test).
// `make` is exported (public API); `helper` is #module-private but reachable from `make`; `dead_priv`
// is #module-private and unreachable → the only dead code.
// RUN: true
#import { fmt }
make :: proc() {
  helper()();
}
#module
helper :: proc() {
  fmt.print("reachable private\n");
}
dead_priv :: proc() {
  fmt.print("dead private\n");
}
