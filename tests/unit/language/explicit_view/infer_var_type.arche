// Explicit view: inferred variable types appear as inlay hints; user-file coords (core subtracted).
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 8 7 1 1 type proc()()"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 9 10 1 1 type i32"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 10 10 1 1 type char[]"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 11 10 1 1 type float"
// `typed` has a written type → no hint; the proc decl shows its (redundant) form type. 4 SYN lines.
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "^SYN ") -eq 4
main :: proc() {
  count := 5;
  label := "hi";
  ratio := 1.5;
  typed: int = 7;
}
