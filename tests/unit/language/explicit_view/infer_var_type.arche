// Explicit view: inferred variable types appear as inlay hints; user-file coords (core subtracted). The
// enclosing proc decl is a redundant definition-form, HIDDEN by default; --full opts out and shows it.
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 12 10 1 1 type i32"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 13 10 1 1 type char[]"
// RUN: %build/arche-analyzer --dump %s | grep -qxF "SYN 14 10 1 1 type float"
// `typed` has a written type → no hint; the proc is hidden → exactly 3 type inlays by default:
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -cF " type ") -eq 3
// --full also shows the enclosing proc decl's form type:
// RUN: %build/arche-analyzer --dump --full %s | grep -qxF "SYN 11 7 1 1 type proc()()"
// RUN: test $(%build/arche-analyzer --dump --full %s 2>/dev/null | grep -cF " type ") -eq 4
main :: proc() {
  count := 5;
  label := "hi";
  ratio := 1.5;
  typed: int = 7;
}
