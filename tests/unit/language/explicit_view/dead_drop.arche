// Regression: a `@drop` destructor is invoked by the compiler's RAII path at scope exit, never by a
// syntactic call, so it must be a reachability root and never flagged W0013 — even when no value of
// the type is ever dropped in this program.
// RUN: test $(%build/arche-analyzer --dump %s 2>/dev/null | grep -c "W0013 unused_function") -eq 0
#import { fmt }
#foreign {
  free_widget :: proc(own w: widget);
}
widget :: opaque;
@drop(widget)
wfree :: proc(own w: widget) {
  free_widget(move w)();
}
main :: proc() {
  fmt.print("ok\n");
}