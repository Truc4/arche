// RUN: %arche -o %t %s && %t | grep "multi_bind ok"
// Multi-bind statement tests - mixed declaration and assignment

func fill_two(out buf1: char[32], out buf2: char[32]) -> int {
  buf1[0] = 'a';
  buf1[1] = 'b';
  buf1[2] = '\0';

  buf2[0] = 'c';
  buf2[1] = 'd';
  buf2[2] = '\0';

  return 42;
}

proc main() {
  // Test: both new declarations with out params (+ return value)
  (let x:, let y:, let n:) = fill_two(x, y);
  printf("multi_bind ok\n");
}
