// Tier-1 transparent alias: `dist :: alias float` is THE SAME type as float — interchangeable both ways.
// RUN: %arche build -o %t %s && %t | grep "r=3"
#import { fmt }
dist  :: alias float;
entry :: system eff {
  d  : dist  = 3.0;
  f  : float = d;
  d2 : dist  = f;
  fmt.printf("r=%g\n", d2);
}
#run entry
