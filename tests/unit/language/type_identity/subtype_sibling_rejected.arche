// Sibling distinctness: `meters` and `seconds` both back `float` but are DISTINCT tier-2 subtypes,
// so passing a `meters` where a `seconds` is expected is a compile error (distinct-by-default),
// reported as "expected 'seconds'".
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "expected 'seconds'" %t.out
#import { fmt }
meters        :: float;
seconds       :: float;
takes_seconds :: proc(s: seconds) {
  fmt.printf("%g\n", s);
}
main :: proc() {
  d: meters = 5.0;
  takes_seconds(d); // meters where seconds expected -> ERROR
}
