// Sibling distinctness: `meters` and `seconds` both back `float` but are DISTINCT tier-2 subtypes,
// so passing a `meters` where a `seconds` is expected is a compile error. Today this compiles
// SILENTLY (the bug this overhaul fixes) — RED until distinct-by-default lands.
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "expected 'seconds'" %t.out
#import { fmt }
meters :: float
seconds :: float
takes_seconds :: proc(s: seconds) {
  fmt.printf("%g\n", s);
}
main :: proc() {
  d: meters = 5.0;
  takes_seconds(d); // meters where seconds expected -> ERROR
}
