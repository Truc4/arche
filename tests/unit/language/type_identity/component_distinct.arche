// Archetype components are tier-2 subtypes: `mass` and `charge` (both back float) are DISTINCT types,
// yet both are usable-as-float and may be combined (cross-component op result = left operand's
// nominal). This is what makes an archetype "a unique collection of nominal types". Prints e=50.
// (GREEN today; must STAY green — proves distinctness does not block component arithmetic.)
// RUN: %arche build -o %t %s && %t | grep "e=50"
#import { fmt }
Particle :: arche { mass :: float, charge :: float }
Particle[4](4)
main :: proc() {
  Particle.mass[0]   = 10.0;
  Particle.charge[0] = 5.0;
  m := Particle.mass[0]; // type: mass
  c := Particle.charge[0]; // type: charge
  e: float = m * c; // mass * charge (same backing) -> allowed -> 50
  fmt.printf("e=%g\n", e);
}
