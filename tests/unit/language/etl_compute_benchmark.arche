arche Transaction {
  price: float,
  quantity: int,
  revenue: float,
}

static Transaction(10000000, 10000000) {
  price: 0.0,
  quantity: 0,
  revenue: 0.0,
};

proc main() {
  let idx := 0;
  let i := 0;

  for (;i < 10000000;) {
    Transaction.price[i] = 10.5;
    Transaction.quantity[i] = 150;
    i = i + 1;
  }

  Transaction.revenue = Transaction.price * Transaction.quantity;

  let sum1 := 0.0;
  i = 0;
  for (;i < 10000000;) {
    sum1 = sum1 + Transaction.revenue[i];
    i = i + 1;
  }

  let count := 0;
  i = 0;
  for (;i < 10000000;) {
    if (Transaction.quantity[i] > 0) { count = count + 1; }
    i = i + 1;
  }

  let sum2 := 0.0;
  i = 0;
  for (;i < 10000000;) {
    sum2 = sum2 + Transaction.price[i] / 10.0;
    i = i + 1;
  }

  let sum3 := 0.0;
  i = 0;
  for (;i < 10000000;) {
    sum3 = sum3 + Transaction.revenue[i];
    i = i + 1;
  }

  printf("done\n");
}
