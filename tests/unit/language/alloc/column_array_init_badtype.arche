// The column ← array-literal scatter is type-checked element-wise: a mismatched element is still a type
// error (the convenience doesn't punch a hole in checking). Here a string in an int column's array is
// rejected. (Companion to column_array_init.arche, which covers the valid cases incl. int→float widening.)
// RUN: ! %arche build -o %t %s 2>%t.err
// RUN: grep -qF "column element" %t.err
#import { fmt }
x   :: int;
Mob :: arche { x }
[4]Mob(3);
main :: proc() {
  Mob.x = { 1, "two", 3 }; // "two" is not an int → rejected
  fmt.printf("%d\n", Mob.x[0]);
}
