// RUN: %arche build -o %t %s && %t
// Task 1: Static alloc with bulk initialization (top-level only)
#import { fmt }
Counter :: arche { val :: int, score :: float }

Empty :: arche { x :: int }

Counter[5](5) {
  val: 7, score: 2.5,
}

Empty[5]

main :: proc() {
  fmt.assert(Counter.val[0] == 7, "val[0] not 7\n");
  fmt.assert(Counter.score[0] == 2.5, "score[0] not 2.5\n");
  fmt.assert(Counter.val[4] == 7, "val[4] not 7\n");
  fmt.assert(Counter.score[4] == 2.5, "score[4] not 2.5\n");
  fmt.printf("static alloc init ok\n");
}
