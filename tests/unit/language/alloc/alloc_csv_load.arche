// RUN: %arche build -o %t %s && %t
#import io;
arche Transaction {
  price :: float,
  quantity :: int,
}

static pool<Transaction> (5, 5) {
  price: 0.0, quantity: 0,
}
;

proc main() {
  arche_fopen_read("../../../../../tests/fixtures/transactions.csv")(fd:);
  buf: char[256];
  price_str: char[32];
  qty_str: char[32];
  arche_fread(fd, buf, 256)(buf, total_n:);
  arche_fclose(move fd);
  idx := 0;
  pos := 0;
  line_start := 0;
  for (; pos < total_n;) {
    if (buf[pos] == '\n') {
      line_start = pos + 1;
      pos = pos + 1;
      break;
    }
    pos = pos + 1;
  }
  for (; idx < 3;) {
    if (line_start >= total_n) {
      break;
    }
    line_end := line_start;
    for (; line_end < total_n;) {
      if (buf[line_end] == '\n') {
        break;
      }
      line_end = line_end + 1;
    }
    comma_pos := line_start;
    for (; comma_pos < line_end;) {
      if (buf[comma_pos] == ',') {
        break;
      }
      comma_pos = comma_pos + 1;
    }
    j := 0;
    i := line_start;
    for (; i < comma_pos;) {
      price_str[j] = buf[i];
      j = j + 1;
      i = i + 1;
    }
    price_str[j] = 0;
    j = 0;
    i = comma_pos + 1;
    for (; i < line_end;) {
      qty_str[j] = buf[i];
      j = j + 1;
      i = i + 1;
    }
    qty_str[j] = 0;
    Transaction.price[idx] = atof(price_str);
    Transaction.quantity[idx] = atoi(qty_str);
    idx = idx + 1;
    line_start = line_end + 1;
  }
  assert(Transaction.price[0] == 1.0, "price[0] not 1.0\n");
  assert(Transaction.quantity[0] == 10, "qty[0] not 10\n");
  printf("csv load ok\n");
}
