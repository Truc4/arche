// RUN: %arche build -o %t %s && %t | grep "system_ran"
#import { fmt }
Task :: arche { val :: int }

[1]Task(1) {
  val: 5,
}

double_val :: map (query { val }) {
  val = val * 2;
}

verify :: system {
  fmt.printf("system_ran\n");
  fmt.assert(Task.val[0] == 10, "val not 10\n");
}

#run seq({ double_val, verify })
