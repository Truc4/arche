// RUN: %arche build -o %t %s && %t
#import { fmt }
pos      :: float;
vel      :: float;
Particle :: arche { pos, vel }

[1000] Particle;

main :: proc() {
  insert(Particle, 10.0, 1.0)(_:, _:);
  insert(Particle, 20.0, 2.0)(_:, _:);
  insert(Particle, 30.0, 3.0)(_:, _:);
  insert(Particle, 40.0, 4.0)(_:, _:);
  insert(Particle, 50.0, 5.0)(_:, _:);
  insert(Particle, 60.0, 6.0)(_:, _:);
  insert(Particle, 70.0, 7.0)(_:, _:);
  insert(Particle, 80.0, 8.0)(_:, _:);
  Particle.pos = Particle.pos + Particle.vel;
  p0  := Particle.pos[0];
  p7  := Particle.pos[7];
  p0i := p0 * 10.0;
  p7i := p7 * 10.0;
  fmt.assert(p0i == 110.0, "pos[0] != 11.0\n");
  fmt.assert(p7i == 880.0, "pos[7] != 88.0\n");
}
