// RUN: %arche build -o %t %s && %t
#import { fmt }
pos      :: float;
vel      :: float;
Particle :: arche { pos, vel }

[1000]Particle;

entry :: system {
  insert(Particle { pos: 10.0, vel: 1.0 })(_:, _:);
  insert(Particle { pos: 20.0, vel: 2.0 })(_:, _:);
  insert(Particle { pos: 30.0, vel: 3.0 })(_:, _:);
  insert(Particle { pos: 40.0, vel: 4.0 })(_:, _:);
  insert(Particle { pos: 50.0, vel: 5.0 })(_:, _:);
  insert(Particle { pos: 60.0, vel: 6.0 })(_:, _:);
  insert(Particle { pos: 70.0, vel: 7.0 })(_:, _:);
  insert(Particle { pos: 80.0, vel: 8.0 })(_:, _:);
  Particle.pos = Particle.pos + Particle.vel;
  p0  := Particle.pos[0];
  p7  := Particle.pos[7];
  p0i := p0 * 10.0;
  p7i := p7 * 10.0;
  fmt.assert(p0i == 110.0, "pos[0] != 11.0\n");
  fmt.assert(p7i == 880.0, "pos[7] != 88.0\n");
}

#run entry
