// RUN: %arche -o %t %s && %t

arche Particle {
  pos: float,
  vel: float,
}


static Particle(1000);


proc main() {
  insert(Particle, 10.0, 1.0);
  insert(Particle, 20.0, 2.0);
  insert(Particle, 30.0, 3.0);
  insert(Particle, 40.0, 4.0);
  insert(Particle, 50.0, 5.0);
  insert(Particle, 60.0, 6.0);
  insert(Particle, 70.0, 7.0);
  insert(Particle, 80.0, 8.0);
  Particle.pos = Particle.pos + Particle.vel;
  let p0 := Particle.pos[0];
  let p7 := Particle.pos[7];
  let p0i := p0 * 10.0;
  let p7i := p7 * 10.0;
  assert(p0i == 110.0, "pos[0] != 11.0\n");
  assert(p7i == 880.0, "pos[7] != 88.0\n");
}
