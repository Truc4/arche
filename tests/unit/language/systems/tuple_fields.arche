// A system over tuple-typed fields: `pos`/`vel` are tuples (x, y). Lowering
// flattens them to columns pos_x/pos_y/vel_x/vel_y and rewrites the body's
// pos.x/vel.x accesses, so `run` updates every row.
//   pos0 (0,0)+(1,2) -> (1,2);  pos1 (10,10)+(-1,-1) -> (9,9)
// RUN: %arche build -o %t %s && %t | grep "R 1 2 9 9"
#import { fmt }
Body :: arche { pos(x, y) :: int, vel(x, y) :: int }
[2]Body ?abort;
step :: map (query { pos, vel }) {
  pos.x = pos.x + vel.x;
  pos.y = pos.y + vel.y;
}
seed :: system {
  insert(Body { pos: (0, 0), vel: (1, 2) })(_:, _:);
  insert(Body { pos: (10, 10), vel: (-1, -1) })(_:, _:);
}

verify :: system {
  fmt.printf("R %d %d %d %d\n", Body.pos.x[0], Body.pos.y[0], Body.pos.x[1], Body.pos.y[1]);
}

#run seq({ seed, step, verify })
