// RUN: %arche build -o %t %s && %t | grep "system_ran"
#import { fmt }
Counter :: arche { val :: int }

[1]Counter(1) {
  val: 0,
}

increment :: sys (val) {
  fmt.printf("system_ran\n");
  val = val + 1;
}

main :: proc() {
  run increment;
  fmt.assert(Counter.val[0] == 1, "system did not run\n");
}
