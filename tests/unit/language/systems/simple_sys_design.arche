// RUN: %arche build -o %t %s && %t | grep "system_ran"
Counter :: arche {
  val :: int,
}

static pool<Counter> (1, 1) {
  val: 0,
}
;

increment :: sys (val) {
  printf("system_ran\n");
  val = val + 1;
}

main :: proc () {
  run increment;
  assert(Counter.val[0] == 1, "system did not run\n");
}
