// RUN: %arche build -o %t %s && %t
// Task 1: Derived columns (revenue = price * quantity)
Task1 :: arche { price :: float, quantity :: int, revenue :: float }

static pool<Task1> (1, 1) {
  price: 2.0, quantity: 3, revenue: 0.0,
}

task1_compute_revenue :: sys (price, quantity, revenue) {
  printf("sys1_ran\n");
  revenue = price * quantity;
}
// Task 2: Filter invalid (valid flag for quantity > 0)
Task2 :: arche { quantity :: int, valid :: int }

static pool<Task2> (1, 1) {
  quantity: 5, valid: 0,
}

task2_filter_invalid :: sys (quantity, valid) {
  printf("sys2_ran\n");
  valid = quantity > 0;
}
// Task 3: Bucket timestamps (hour_bucket = timestamp rounded down to nearest hour)
Task3 :: arche { timestamp :: int, hour_bucket :: int }

static pool<Task3> (1, 1) {
  timestamp: 7654, hour_bucket: 0,
}

task3_bucket_timestamps :: sys (timestamp, hour_bucket) {
  printf("sys3_ran\n");
  hour_bucket = timestamp / 3600 * 3600;
}
// Task 4: Different shape - OK to init
Task4 :: arche { amount :: float }

static pool<Task4> (1, 1) {
  amount: 100.0,
}

task4_process :: sys (amount) {
  printf("sys4_ran\n");
  amount = amount * 2.0;
}

main :: proc() {
  run task1_compute_revenue;
  run task2_filter_invalid;
  run task3_bucket_timestamps;
  run task4_process;
  printf("ok\n");
}
