// D2 lock: an EXPLICIT index in a sys body uses the literal/expression, NOT the implicit row-loop counter.
// This "gather" — out[i] = Table.val[v[i]] — exercises BOTH halves of the fix at once: the index BASE
// (`Table.val`) must yield the column POINTER (row-loop index suppressed while evaluating the base), while
// the index EXPRESSION (`v`, an iterated column) must still auto-index per row (loop index restored after
// the base). A regression would read Table.val[loop_index] or use a loaded i32 as a pointer (miscompile).
// (Reading a foreign pool from a sys is allowed; writing one is W0024 — here `out` is the iterated column.)
// RUN: %arche build -o %t %s && %t | grep -qF "out=30 10 40"
#import { fmt }
val   :: int;
v     :: int;
out   :: int;
Table :: arche { val }
Ent   :: arche { v, out }
[4]Table;
[3]Ent;

gather :: map (query { v, out }) {
  out = Table.val[v]; // base suppressed → column ptr; index v auto-indexed per row → Table.val[v_i]
}

seed :: system {
  insert(Table { val: 10 })(_:, _:);
  insert(Table { val: 20 })(_:, _:);
  insert(Table { val: 30 })(_:, _:);
  insert(Table { val: 40 })(_:, _:);
  insert(Ent { v: 2, out: 0 })(_:, _:);
  insert(Ent { v: 0, out: 0 })(_:, _:);
  insert(Ent { v: 3, out: 0 })(_:, _:);
}

verify :: system {
  fmt.printf("out=%d %d %d\n", Ent.out[0], Ent.out[1], Ent.out[2]);
  // gather: 30 10 40;
}

#run seq({ seed, gather, verify })
