// RUN: %arche build -o %t %s && %t | grep "system_ran"
#import { fmt }
pos  :: float;
Body :: arche { pos }

[5] Body;

dummy :: sys (pos) {
  fmt.printf("system_ran\n");
  pos = pos;
}

main :: proc() {
  insert(Body, 1.0)(_:, _:);
  insert(Body, 2.0)(_:, _:);
  insert(Body, 3.0)(_:, _:);
  run dummy;
  p0  := Body.pos[0];
  p1  := Body.pos[1];
  p0i := p0 * 10.0;
  p1i := p1 * 10.0;
  fmt.assert(p0i == 10, "pos[0] != 1.0\n");
  fmt.assert(p1i == 20, "pos[1] != 2.0\n");
}
