// RUN: %arche -o %t %s && %t | grep "system_ran"
pos :: float arche Body {
  pos,
}

static pool<Body> (5);

sys dummy(pos) {
  printf("system_ran\n");
  pos = pos;
}

proc main() {
  insert(Body, 1.0);
  insert(Body, 2.0);
  insert(Body, 3.0);
  run dummy;
  p0 := Body.pos[0];
  p1 := Body.pos[1];
  p0i := p0 * 10.0;
  p1i := p1 * 10.0;
  assert(p0i == 10, "pos[0] != 1.0\n");
  assert(p1i == 20, "pos[1] != 2.0\n");
}
