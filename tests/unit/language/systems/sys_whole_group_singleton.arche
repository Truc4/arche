// A whole-group (vector) op in a sys can pull in a SINGLETON group field: `vel -= (pos - Config.center[0])
// / Config.stiffness[0]`. Lowering fans the op out per component AND, for each one, folds the singleton's
// group field `Config.center[0]` to its flattened column `Config.center.x[0]` / `Config.center.y[0]` (a
// scalar singleton field like `Config.stiffness[0]` is shared across both). So the spring is written once
// for the whole vector instead of per axis. Verifies the per-component result matches the hand-expanded
// form exactly.
// RUN: %arche build -o %t %s && %t | grep -qF "v=2 12 p=82 92"
#import { fmt }
pos(x, y)    :: int;
vel(x, y)    :: int;
center(x, y) :: int;
stiffness    :: int;
Mover        :: arche { pos, vel }
Config       :: arche { stiffness, center }
[1]Mover;
[1]Config;
step :: map (query { pos, vel }) {
  vel -= (pos - Config.center[0]) / Config.stiffness[0]; // whole-vector spring toward the singleton center
  pos += vel; // whole-vector integrate
}
main :: proc() {
  insert(Config, 10, 100, 200)(_:, _:); // stiffness=10, center=(100,200)
  insert(Mover, 80, 80, 0, 0)(_:, _:); // pos=(80,80), vel=(0,0)
  run step;
  // vel.x -= (80-100)/10 = +2 ; vel.y -= (80-200)/10 = +12 ; pos += vel → (82,92)
  fmt.printf("v=%d %d p=%d %d\n", Mover.vel.x[0], Mover.vel.y[0], Mover.pos.x[0], Mover.pos.y[0]);
}
