// RUN: %arche build -o %t %s && %t
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)
Particle :: arche {
  pos :: float, vel :: float,
}

Body :: arche {
  pos :: float, vel :: float, mass :: float,
}

static pool<Particle> (10)

static pool<Body> (10)

step :: sys (pos, vel) {
  pos = pos + vel;
}

dampen :: sys (vel) {
  vel = vel * 0.99;
}

main :: proc () {
  insert(Particle, 10.0, 1.0);
  insert(Particle, 20.0, 2.0);
  insert(Particle, 30.0, 3.0);
  insert(Body, 50.0, 5.0, 10.0);
  insert(Body, 60.0, 6.0, 20.0);
  run step;
  run dampen;
  pp := Particle.pos[0];
  bp := Body.vel[0];
  ppi := pp * 10.0;
  bpi := bp * 100.0;
  assert(ppi == 110.0, "Particle.pos != 11.0\n");
  assert(bpi == 495.0, "Body.vel != 4.95\n");
}
