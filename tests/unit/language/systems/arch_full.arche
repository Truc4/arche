// RUN: %arche -o %t %s && %t | grep "DEBUG:"
arche Particle {
  pos: float,
  vel: float,
}


arche Body {
  pos: float,
  vel: float,
  mass: float,
}


static table<Particle>(100);

static table<Body>(50);


sys move(pos, vel) {
  pos = pos + vel;
}


sys dampen(vel) {
  vel = vel * 0.99;
}


proc main() {
  insert(table<Particle>, 10.0, 1.0);
  insert(table<Particle>, 20.0, 2.0);
  insert(table<Particle>, 30.0, 3.0);
  insert(table<Body>, 50.0, 5.0, 10.0);
  insert(table<Body>, 60.0, 6.0, 20.0);
  run move;
  run dampen;
  let pp := Particle.pos[0];
  let bp := Body.vel[0];
  let ppi := pp * 10.0;
  let bpi := bp * 100.0;
  print("DEBUG: checking Particle.pos\n");
  assert(ppi == 110.0, "Particle.pos != 11.0\n");
  assert(bpi == 495.0, "Body.vel != 4.95\n");
}
