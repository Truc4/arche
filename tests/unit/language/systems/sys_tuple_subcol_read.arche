// FEATURE: an indexed tuple-subcolumn read inside a SYSTEM body (`Mover.pos.x[i]`) addresses the pool's
// column. (Scatter in `boot`, read in `show` — both systems now that procs are gone.)
// RUN: %arche build -o %t %s && %t | grep -qF "v=7"
#import { fmt }
pos(x, y) :: int;
Mover     :: arche { pos }
[4]Mover(2);

boot :: system {
  Mover.pos.x = { 7, 9 };
}

show :: system {
  fmt.printf("v=%d\n", Mover.pos.x[0]);
}

#run seq({ boot, show })
