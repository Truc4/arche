// RUN: %arche -o %t %s && %t | grep "p0i"
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)
arche Body {
  position :: float,
  velocity :: float,
}


static pool<Body>(500);


sys step(position, velocity) {
  position = position + velocity;
}


proc main() {
  insert(Body, 10.0, 1.0);
  insert(Body, 20.0, 2.0);
  insert(Body, 30.0, 3.0);
  insert(Body, 40.0, 4.0);
  insert(Body, 50.0, 5.0);
  insert(Body, 60.0, 6.0);
  insert(Body, 70.0, 7.0);
  insert(Body, 80.0, 8.0);
  insert(Body, 90.0, 9.0);
  insert(Body, 100.0, 10.0);
  insert(Body, 110.0, 11.0);
  insert(Body, 120.0, 12.0);
  run step;
  p0 := Body.position[0];
  p11 := Body.position[11];
  p0i := p0 * 10.0;
  p11i := p11 * 10.0;
  print("p0i=");
  print_float(p0i);
  print(" p11i=");
  print_float(p11i);
  print("\n");
  assert(p0i == 110.0, "position[0] != 11.0\n");
  assert(p11i == 1320.0, "position[11] != 132.0\n");
}
