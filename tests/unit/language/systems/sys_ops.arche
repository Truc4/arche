// RUN: %arche build -o %t %s && %t | grep "p0i"
#import { fmt }
Body :: arche { position :: float, velocity :: float }

[500]Body;

step :: sys (position, velocity) {
  position = position + velocity;
}

main :: proc() {
  insert(Body, 10.0, 1.0)(_:, _:);
  insert(Body, 20.0, 2.0)(_:, _:);
  insert(Body, 30.0, 3.0)(_:, _:);
  insert(Body, 40.0, 4.0)(_:, _:);
  insert(Body, 50.0, 5.0)(_:, _:);
  insert(Body, 60.0, 6.0)(_:, _:);
  insert(Body, 70.0, 7.0)(_:, _:);
  insert(Body, 80.0, 8.0)(_:, _:);
  insert(Body, 90.0, 9.0)(_:, _:);
  insert(Body, 100.0, 10.0)(_:, _:);
  insert(Body, 110.0, 11.0)(_:, _:);
  insert(Body, 120.0, 12.0)(_:, _:);
  run step;
  p0   := Body.position[0];
  p11  := Body.position[11];
  p0i  := p0 * 10.0;
  p11i := p11 * 10.0;
  fmt.print("p0i=");
  fmt.print_float(p0i);
  fmt.print(" p11i=");
  fmt.print_float(p11i);
  fmt.print("\n");
  fmt.assert(p0i == 110.0, "position[0] != 11.0\n");
  fmt.assert(p11i == 1320.0, "position[11] != 132.0\n");
}