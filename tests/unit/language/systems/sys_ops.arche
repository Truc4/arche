// RUN: %arche build -o %t %s && %t | grep "p0i"
#import { fmt }
Body :: arche { position :: float, velocity :: float }

[500]Body;

step :: map (query { position, velocity }) {
  position = position + velocity;
}

seed :: system {
  insert(Body { position: 10.0, velocity: 1.0 })(_:, _:);
  insert(Body { position: 20.0, velocity: 2.0 })(_:, _:);
  insert(Body { position: 30.0, velocity: 3.0 })(_:, _:);
  insert(Body { position: 40.0, velocity: 4.0 })(_:, _:);
  insert(Body { position: 50.0, velocity: 5.0 })(_:, _:);
  insert(Body { position: 60.0, velocity: 6.0 })(_:, _:);
  insert(Body { position: 70.0, velocity: 7.0 })(_:, _:);
  insert(Body { position: 80.0, velocity: 8.0 })(_:, _:);
  insert(Body { position: 90.0, velocity: 9.0 })(_:, _:);
  insert(Body { position: 100.0, velocity: 10.0 })(_:, _:);
  insert(Body { position: 110.0, velocity: 11.0 })(_:, _:);
  insert(Body { position: 120.0, velocity: 12.0 })(_:, _:);
}

verify :: system {
  p0   := Body.position[0];
  p11  := Body.position[11];
  p0i  := p0 * 10.0;
  p11i := p11 * 10.0;
  fmt.print("p0i=")(_:);
  fmt.print_float(p0i)();
  fmt.print(" p11i=")(_:);
  fmt.print_float(p11i)();
  fmt.print("\n")(_:);
  fmt.assert(p0i == 110.0, "position[0] != 11.0\n");
  fmt.assert(p11i == 1320.0, "position[11] != 132.0\n");
}

#run seq({ seed, step, verify })
