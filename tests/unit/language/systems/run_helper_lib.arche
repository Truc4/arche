// Support module for module_body_run.arche (not a standalone test). Defines a pool + a map + systems in
// THIS imported (non-entry) compilation unit; the entry's `#run` dispatches them across units. Under
// per-unit codegen the map/system bodies emit in their own unit and the entry references them via the
// cross-unit declare (emit_cross_unit_declares). Mutates + prints pool state so a regressed declare (an
// unresolved symbol / a body that never ran) is caught.
// RUN: true
#import { fmt }
hp  :: int;
Mob :: arche { hp }

[10]Mob;

bump :: map (query { hp }) {
  hp = hp + 1;
}

mob_seed :: system eff {
  insert(Mob { hp: 0 })(_:, _:);
}

mob_report :: system eff {
  fmt.printf("n=%d\n", Mob.hp[0]);
}
