// RUN: %arche build -o %t %s && %t | grep "p0i"
// A sys mutates the column, then the archetype storage is released with `dealloc`.
#import { fmt }
Particle :: arche { pos :: float, vel :: float }

Particle[10]

advance :: sys (pos, vel) {
  pos = pos + vel;
}

main :: proc() {
  insert(Particle, 1.0, 0.1)(_:, _:);
  insert(Particle, 2.0, 0.2)(_:, _:);
  insert(Particle, 3.0, 0.3)(_:, _:);
  run advance;
  p0  := Particle.pos[0];
  p1  := Particle.pos[1];
  p0i := p0 * 10.0;
  p1i := p1 * 10.0;
  fmt.print("p0i=");
  fmt.print_float(p0i);
  fmt.print(" p1i=");
  fmt.print_float(p1i);
  fmt.print("\n");
  fmt.assert(p0i == 11, "pos[0] != 1.1\n");
  fmt.assert(p1i == 22, "pos[1] != 2.2\n");
  dealloc(Particle);
}
