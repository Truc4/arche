// RUN: %arche build -o %t %s && %t | grep "p0i"
// A sys mutates the column, then the archetype storage is released with `dealloc`.
#import { fmt }
Particle :: arche { pos :: float, vel :: float }

[10]Particle ?abort;

advance :: map (query { pos, vel }) {
  pos = pos + vel;
}

seed :: system eff {
  insert(Particle { pos: 1.0, vel: 0.1 })(_:, _:);
  insert(Particle { pos: 2.0, vel: 0.2 })(_:, _:);
  insert(Particle { pos: 3.0, vel: 0.3 })(_:, _:);
}

verify :: system eff {
  p0  := Particle.pos[0];
  p1  := Particle.pos[1];
  p0i := p0 * 10.0;
  p1i := p1 * 10.0;
  fmt.print("p0i=")(_:);
  fmt.print_float(p0i)();
  fmt.print(" p1i=")(_:);
  fmt.print_float(p1i)();
  fmt.print("\n")(_:);
  fmt.assert(p0i == 11, "pos[0] != 1.1\n")();
  fmt.assert(p1i == 22, "pos[1] != 2.2\n")();
  dealloc(Particle);
}

#run seq({ seed, advance, verify })
