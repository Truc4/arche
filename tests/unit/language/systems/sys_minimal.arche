// RUN: %arche build -o %t %s && %t | grep "system_ran"
#import { fmt }
pos      :: float;
Particle :: arche { pos }

[10]Particle ?abort;

dummy :: map (query { pos }) {
  pos = pos;
}

seed :: system eff {
  insert(Particle { pos: 1.0 })(_:, _:);
}

verify :: system eff {
  fmt.printf("system_ran\n");
  // marker lives in the driver, not the kernel;
}

#run seq({ seed, dummy, verify })
