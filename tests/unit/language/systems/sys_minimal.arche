// RUN: %arche build -o %t %s && %t | grep "system_ran"
#import { fmt }
pos      :: float;
Particle :: arche { pos }

[10]Particle;

dummy :: sys (pos) {
  fmt.printf("system_ran\n");
  pos = pos;
}

main :: proc() {
  insert(Particle, 1.0)(_:, _:);
  run dummy;
  fmt.printf("pos[0]=%f\n", Particle.pos[0]);
}
