// RUN: %arche build -o %t %s && %t | grep "system_ran"
#import { fmt }
pos      :: float;
Particle :: arche { pos }

[10]Particle;

dummy :: map (pos) {
  pos = pos;
}

main :: proc() {
  insert(Particle, 1.0)(_:, _:);
  run dummy;
  fmt.printf("system_ran\n"); // marker lives in the driver, not the kernel
}
