// RUN: %arche build -o %t %s && %t
#import { fmt }
Particle :: arche { pos :: float, vel :: float }

Body :: arche { pos, vel, mass :: float }

[5]Particle;

[5]Body;

step :: sys (pos, vel) {
  pos = pos + vel;
}

dampen :: sys (vel) {
  vel = vel * 0.99;
}

main :: proc() {
  insert(Particle, 10.0, 1.0)(_:, _:);
  insert(Body, 20.0, 2.0, 10.0)(_:, _:);
  run step;
  run dampen;
  pp  := Particle.pos[0];
  bp  := Body.vel[0];
  ppi := pp * 10.0;
  bpi := bp * 100.0;
  fmt.assert(ppi == 110.0, "Particle.pos != 11.0\n");
  fmt.assert(bpi == 198.0, "Body.vel != 1.98\n");
}