// RUN: %arche build -o %t %s && %t
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)
arche Particle {
  pos :: float,
  vel :: float,
}

arche Body {
  pos :: float,
  vel :: float,
  mass :: float,
}

static pool<Particle> (5);

static pool<Body> (5);

sys step(pos, vel) {
  pos = pos + vel;
}

sys dampen(vel) {
  vel = vel * 0.99;
}

proc main() {
  insert(Particle, 10.0, 1.0);
  insert(Body, 20.0, 2.0, 10.0);
  run step;
  run dampen;
  pp := Particle.pos[0];
  bp := Body.vel[0];
  ppi := pp * 10.0;
  bpi := bp * 100.0;
  assert(ppi == 110.0, "Particle.pos != 11.0\n");
  assert(bpi == 198.0, "Body.vel != 1.98\n");
}
