// RUN: %arche -o %t %s && %t
// BUG: System operations don't modify fields (see COMPILER_BUG_SYSTEM_OPERATIONS.md)
arche Particle {
  pos: float,
  vel: float,
}


arche Body {
  pos: float,
  vel: float,
  mass: float,
}


static Particle(5);

static Body(5);


sys move(pos, vel) {
  pos = pos + vel;
}


sys dampen(vel) {
  vel = vel * 0.99;
}


proc main() {
  insert(Particle, 10.0, 1.0);
  insert(Body, 20.0, 2.0, 10.0);
  run move;
  run dampen;
  let pp := Particle.pos[0];
  let bp := Body.vel[0];
  let ppi := pp * 10.0;
  let bpi := bp * 100.0;
  assert(ppi == 110.0, "Particle.pos != 11.0\n");
  assert(bpi == 198.0, "Body.vel != 1.98\n");
}
