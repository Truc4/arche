proc main() {
  let fd := arche_fopen_read("tests/unit/language/etl_test_data.csv");
  if (fd > 0) {
    let line: char[256];
    let n := arche_fread_line(fd, line, 256);
    if (n > 0) {
      printf("PASS: read %d chars\n", n);
    } else {
      printf("FAIL: could not read line\n");
    }
    arche_fclose(fd);
  } else {
    printf("FAIL: could not open file\n");
  }
}
