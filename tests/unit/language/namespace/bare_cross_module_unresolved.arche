// Negative: a DEVICE's pure-Arche export is namespaced — you must call `device.name`, not the bare
// name. `assert` is an arche proc in the `fmt` device, so bare `assert` does not resolve (only
// `fmt.assert` does). (Plain/path modules, by contrast, merge FLAT and ARE callable bare — see
// use/cross_module.arche. `#foreign` externs like `fmt.printf` keep their bare C name and are exempt.)
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -q "Undefined symbol 'assert'" %t.out
#import { fmt }
entry :: system {
  assert(1, "x\n"); // bare — assert is a device's arche proc, so this must NOT resolve (needs fmt.assert)
}

#run entry
