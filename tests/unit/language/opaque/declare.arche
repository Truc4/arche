// An archetype may carry an `opaque` component — a pointer-width, C-owned cell that
// Arche never reads, writes, or fabricates. It declares and statically allocates like
// any column (a pointer-width slot); nothing touches the cell here.
// RUN: %arche build -o %t %s && %t | grep "ok"
#import { fmt }
fd   :: opaque;
File :: arche { fd }
[4] File;
main :: proc() {
  fmt.printf("ok opaque_declared\n");
}
