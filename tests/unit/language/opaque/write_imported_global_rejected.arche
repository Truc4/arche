// Overwriting an opaque imported from ANOTHER module (here io's `file`) with `=` must be rejected (E0122).
// Currently RED: the create-once seal only recognizes same-file opaque aliases, so a cross-module opaque
// overwrite is not caught and reaches codegen (LLVM "invalid type for function argument"). This is the
// exact hole the arche-rpg `win: window; win = w;` hack relied on (`window` is the gfx device's opaque).
// RUN: %arche build -o %t %s > %t.out 2>&1 ; grep -qi "assign over opaque" %t.out
#import { io }

@allow(unused_function)
clobber :: proc(src: file) {
  slot = src;
}

#file
slot: file;

main :: proc() {
}
