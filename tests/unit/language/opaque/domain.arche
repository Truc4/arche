// A foreign resource is a nominal opaque-backed type: `file :: opaque`. Other archetypes
// can hold one as a component (here `OpenFiles { file }`). No `opaque<File>` phantom tag —
// `file` is just a distinct nominal type that erases to a pointer-width slot.
// RUN: %arche -o %t %s && %t | grep "ok"
#import io;
file :: opaque
arche OpenFiles {
  file,
}
static pool<OpenFiles> (8);
proc main() {
  printf("ok opaque_domain\n");
}
