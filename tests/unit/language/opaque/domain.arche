// A foreign resource is a nominal opaque-backed type — here `res :: opaque`. Archetypes can hold one
// as a named component (here `OpenFiles { handle :: res }`). No `opaque<File>` phantom tag — `res` is
// a distinct nominal type that erases to a pointer-width slot. Each opaque type is defined once.
// RUN: %arche build -o %t %s && %t | grep "ok"
#import { fmt }
res       :: opaque;
OpenFiles :: arche { handle :: res }
[8]OpenFiles;
entry :: system {
  fmt.printf("ok opaque_domain\n");
}

#run entry
