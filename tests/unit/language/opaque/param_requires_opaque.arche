// The opaque<X> "X must be a foreign archetype" rule applies in function signatures
// too, not just archetype fields: a func param tagged with a pure-data shape (no opaque
// field) is rejected at compile time.
// RUN: %arche -o %t %s > %t.out 2>&1 ; grep -q "no opaque field" %t.out
arche Plain { x: int }
func foo(f: opaque<Plain>) -> int {
  return 0;
}
proc main() {
  printf("unreachable\n");
}
