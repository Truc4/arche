// opaque<File> in a function signature — the real point of the type. A func takes a
// File's foreign cell by value (File is a foreign archetype with an opaque cell). The
// <File> tag is a compile-time phantom, erased to an i64 param at codegen.
// RUN: %arche -o %t %s && %t | grep "ok"
arche File { fd: opaque }
func describe(f: opaque<File>) -> int {
  return 0;
}
proc main() {
  printf("ok opaque_param\n");
}
