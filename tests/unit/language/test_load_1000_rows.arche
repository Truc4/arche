// RUN: %arche -o %t %s && %t | FileCheck %s
// CHECK: Loaded 1000 rows

arche Transaction {
  price: float,
  quantity: int,
}

static Transaction(1000, 1000) {
  price: 0.0,
  quantity: 0
};



proc main() {
  let fd = arche_fopen_read("../../../../tests/fixtures/data.csv");
  let buf: char[50000];
  let price_str: char[32];
  let qty_str: char[32];
  let total_n = arche_fread(fd, buf, 50000);
  arche_fclose(fd);
  let idx = 0;
  let pos = 0;
  let line_start = 0;
  for (; pos < total_n; pos = pos + 1) {
    if (buf[pos] == '\n') {
      line_start = pos + 1;
      break;
    }
  }
  for (; idx < 1000; idx = idx + 1) {
    if (line_start >= total_n) {
      break;
    }
    let line_end = line_start;
    for (; line_end < total_n; line_end = line_end + 1) {
      if (buf[line_end] == '\n') {
        break;
      }
    }
    let c1 = line_start;
    for (; c1 < line_end; c1 = c1 + 1) {
      if (buf[c1] == ',') {
        break;
      }
    }
    let c2 = c1 + 1;
    for (; c2 < line_end; c2 = c2 + 1) {
      if (buf[c2] == ',') {
        break;
      }
    }
    let j = 0;
    let i = c1 + 1;
    for (; i < c2; i = i + 1) {
      price_str[j] = buf[i];
      j = j + 1;
    }
    price_str[j] = 0;
    j = 0;
    i = c2 + 1;
    for (; i < line_end; i = i + 1) {
      qty_str[j] = buf[i];
      j = j + 1;
    }
    qty_str[j] = 0;
    Transaction.price[idx] = atof(price_str);
    Transaction.quantity[idx] = atoi(qty_str);
    line_start = line_end + 1;
  }
  printf("Loaded %d rows\n", idx);
}

