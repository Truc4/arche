// RUN: %arche -o %t %s && %t

arche Transaction {
  price: float,
  quantity: int,
}


static Transaction(5, 5) {
  price: 0.0,
  quantity: 0,
};


proc main() {
  let fd := arche_fopen_read("../../../../tests/fixtures/transactions.csv");
  let buf: char[256];
  let price_str: char[32];
  let qty_str: char[32];
  let total_n := arche_fread(fd, buf, 256);
  arche_fclose(fd);
  let idx := 0;
  let pos := 0;
  let line_start := 0;
  for (;pos < total_n;) {
    if (buf[pos] == '\n') {
      line_start = pos + 1;
      pos = pos + 1;
      break;
    }
    pos = pos + 1;
  }
  for (;idx < 3;) {
    if (line_start >= total_n) {
      break;
    }
    let line_end := line_start;
    for (;line_end < total_n;) {
      if (buf[line_end] == '\n') {
        break;
      }
      line_end = line_end + 1;
    }
    let comma_pos := line_start;
    for (;comma_pos < line_end;) {
      if (buf[comma_pos] == ',') {
        break;
      }
      comma_pos = comma_pos + 1;
    }
    let j := 0;
    let i := line_start;
    for (;i < comma_pos;) {
      price_str[j] = buf[i];
      j = j + 1;
      i = i + 1;
    }
    price_str[j] = 0;
    j = 0;
    i = comma_pos + 1;
    for (;i < line_end;) {
      qty_str[j] = buf[i];
      j = j + 1;
      i = i + 1;
    }
    qty_str[j] = 0;
    Transaction.price[idx] = atof(price_str);
    Transaction.quantity[idx] = atoi(qty_str);
    idx = idx + 1;
    line_start = line_end + 1;
  }
  assert(Transaction.price[0] == 1.0, "price[0] not 1.0\n");
  assert(Transaction.quantity[0] == 10, "qty[0] not 10\n");
  printf("csv load ok\n");
}
