// RUN: %arche -o %t %s && %t

arche Transaction {
  price: float,
  quantity: int,
}

static Transaction(5);



proc main() {
  let fd = open("tests/fixtures/transactions.csv", 0);
  let buf: char[256];
  let price_str: char[32];
  let qty_str: char[32];
  let idx = 0;
  let buf, _ = read(fd, buf, 256);
  for (idx < 3) {
    let buf, n = read(fd, buf, 256);
    if (n == 0) {
      break;
    }
    let comma_pos = 0;
    let i = 0;
    for (i < n) {
      if (buf[i] == ',') {
        comma_pos = i;
        break;
      }
      i = i + 1;
    }
    let j = 0;
    for (j < comma_pos) {
      price_str[j] = buf[j];
      j = j + 1;
    }
    price_str[j] = 0;
    j = 0;
    i = comma_pos + 1;
    for (i < n) {
      if (buf[i] == '\n') {
        break;
      }
      qty_str[j] = buf[i];
      j = j + 1;
      i = i + 1;
    }
    qty_str[j] = 0;
    Transaction.price[idx] = atof(price_str);
    Transaction.quantity[idx] = atoi(qty_str);
    idx = idx + 1;
  }
  close(fd);
  assert(Transaction.price[0] == 1.0, "price[0] not 1.0\n");
  assert(Transaction.quantity[0] == 10, "qty[0] not 10\n");
  printf("csv load ok\n");
}

