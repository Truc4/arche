// RUN: %arche build -o %t %s && %t
#import { fmt }
Particle :: arche { pos :: float, vel :: float }

Body :: arche { pos, vel, mass :: float }

Particle[5]

Body[5]

main :: proc() {
  insert(Particle, 1.0, 0.1);
  insert(Body, 5.0, 0.5, 10.0);
  pp  := Particle.pos[0];
  bp  := Body.pos[0];
  ppi := pp * 10.0;
  bpi := bp * 10.0;
  fmt.assert(ppi == 10, "Particle.pos != 1.0\n");
  fmt.assert(bpi == 50, "Body.pos != 5.0\n");
}
