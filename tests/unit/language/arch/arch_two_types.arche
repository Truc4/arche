// RUN: %arche build -o %t %s && %t
#import { fmt }
Particle :: arche { pos :: float, vel :: float }

Body :: arche { pos, vel, mass :: float }

[5]Particle ?abort;

[5]Body ?abort;

entry :: system eff {
  insert(Particle { pos: 1.0, vel: 0.1 })(_:, _:);
  insert(Body { pos: 2.0, vel: 0.2, mass: 10.0 })(_:, _:);
  pp  := Particle.pos[0];
  bm  := Body.mass[0];
  ppi := pp * 10.0;
  bmi := bm * 1.0;
  fmt.assert(ppi == 10, "Particle.pos != 1.0\n")();
  fmt.assert(bmi == 10, "Body.mass != 10.0\n")();
}

#run entry
