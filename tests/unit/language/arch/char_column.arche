// RUN: %arche build -o %t %s && %t | grep "seg0=users seg1=posts total=10 eq=1"
// A char[N] archetype column: insert string rows, then read each row back as a
// char[] (runtime-indexed in a loop), pass it to strlen/streq. Exercises the
// insert ABI (string pointer + whole-row memcpy), the per-row column stride,
// and the shaped single-index read returning a slice. Regression for the
// i8-vs-ptr insert bug + the under-sized column array.
Node :: arche { seg :: char[32], id :: int }

static pool<Node> (8)

main :: proc() {
  insert(Node, "users", 7);
  insert(Node, "posts", 9);

  r0 := Node.seg[0];
  r1 := Node.seg[1];
  total := 0;
  for (i := 0; i < 2; i = i + 1) {
    row := Node.seg[i];
    total = total + strlen(row);   // 5 + 5
  }
  eq := streq(r0, "users");
  printf("seg0=%s seg1=%s total=%d eq=%d\n", r0, r1, total, eq);
}
