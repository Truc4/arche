// RUN: %arche build -o %t %s && %t | grep "seg0=users seg1=posts total=10 eq=1"
// A char[N] archetype column: insert string rows, then read each row back as a char[] (runtime-
// indexed in a loop). Exercises the insert ABI (string pointer + whole-row memcpy), the per-row
// column stride, and the shaped single-index read returning a slice. The stored words are 5 bytes
// in a zero-initialized 32-wide column, so content is the sub-slice `row[0:5]` (a normal (ptr,len)
// array — no NUL); `%s` displays them via the column's zero padding (a C-printf boundary detail).
#import { str fmt }
Node :: arche { seg :: char[32], id :: int }

Node[8]

main :: proc() {
  insert(Node, "users", 7)(_:, _:);
  insert(Node, "posts", 9)(_:, _:);

  r0    := Node.seg[0];
  r1    := Node.seg[1];
  total := 0;
  for (i := 0; i < 2; i = i + 1) {
    row   := Node.seg[i];
    total = total + str.strlen(row[0: 5]); // content slice → 5 + 5
  }
  eq := streq(r0[0: 5], "users");
  fmt.printf("seg0=%s seg1=%s total=%d eq=%d\n", r0, r1, total, eq);
}
