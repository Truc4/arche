// RUN: %arche -o %t %s && %t | grep "PASS"
use csv;

static buf: char[65536];

proc main() {
  let fd := csv_open("/home/curt/Code/arche/tests/fixtures/data.csv");
  if (fd > 0) {
    let buf, n := csv_read_chunk(fd, buf, 65536);
    csv_close(fd);
    if (n > 0) {
      printf("PASS: read %d bytes\n", n);
    } else {
      printf("FAIL: no bytes read\n");
    }
  } else {
    printf("FAIL: could not open file\n");
  }
}
