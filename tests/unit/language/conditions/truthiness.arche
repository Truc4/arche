// Bare-int truthiness in condition position: any nonzero value is true (NOT the low bit — `if (2)`
// is true). No `== 1` / `== 0` needed. `i1` stays an LLVM detail; arche conditions are just ints.
// RUN: %arche build -o %t %s && %t | grep "two zero notz loop1 loop2"
#import { fmt }
main :: proc() {
  x := 2;
  if (x) {
    fmt.printf("two ");
  }
  z := 0;
  if (z) {
    fmt.printf("BAD ");
  }
  else {
    fmt.printf("zero ");
  }
  if (!z) {
    fmt.printf("notz ");
  }
  for (i := 0; i < 3; i = i + 1) {
    if (i) {
      fmt.printf("loop%d ", i);
    }
  }
  fmt.printf("\n");
}
