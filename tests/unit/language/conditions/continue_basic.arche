// `continue` skips the rest of the loop body and proceeds to the next iteration — the C-style
// `for` increment still runs (so the loop terminates), and in nested loops it affects only the
// innermost loop.
// RUN: %arche build -o %t %s && %t | grep "sum=8 n=4"
#import { fmt }
main :: proc() {
  sum := 0;
  for (i := 0; i < 5; i = i + 1) {
    if (i == 2) {
      continue;
    } // skip 2 -> 0+1+3+4 = 8
    sum = sum + i;
  }
  n := 0;
  for (a := 0; a < 2; a = a + 1) {
    for (b := 0; b < 3; b = b + 1) {
      if (b == 1) {
        continue;
      } // inner only: counts b=0,2 -> 2 per outer
      n = n + 1;
    }
  }
  fmt.printf("sum=%d n=%d\n", sum, n);
}
