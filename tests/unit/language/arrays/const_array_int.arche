// `XS :: { 1, 2, 3 }` infers a fixed-size `[3]int` (no type written). Indexing and `.length`
// (== 3, read from the type). (RED until {..} literals + array consts land.)
// RUN: %arche build -o %t %s && %t | grep -x "2 3"
#import { fmt }
XS :: { 1, 2, 3 }

entry :: system eff {
  fmt.printf("%d %d\n", XS[1], XS.length);
}

#run entry
