// Non-char array filled via an `own` func buffer (was a proc multi-out; proc removed — a `func` has a
// single return, so the count is a plain local now).
// RUN: %arche build -o %t %s && %t | grep -q "out 9 7 c=2"
#import { fmt }
fill :: func(own buf: [8]int, n: int) -> [8]int {
  buf[0] = 9;
  buf[1] = 7;
  return buf;
}
entry :: system eff {
  b: [8]int;
  r := fill(move b, 8);
  c := 2;
  fmt.printf("out %d %d c=%d\n", r[0], r[1], c);
}

#run entry
