// A `T[]` slice param is a fat pointer `(ptr, len)`: the length is carried at RUNTIME, not baked into
// the signature. A sized `int[N]` decays to a slice at the call (len = N), and the callee reads that
// length back via `.length` and indexes within it. Proves the two-arg slice ABI + runtime len.
// RUN: %arche build -o %t %s && %t | grep -q "len=4 sum=100"
#import { fmt }
sum :: func(xs: int[]) -> int {
  total := 0;
  i := 0;
  for (i = 0; i < xs.length; i = i + 1) {
    total = total + xs[i];
  }
  return total;
}

main :: proc() {
  a: int[4];
  a[0] = 10;
  a[1] = 20;
  a[2] = 30;
  a[3] = 40;
  fmt.printf("len=%d sum=%d\n", a.length, sum(a));
}
