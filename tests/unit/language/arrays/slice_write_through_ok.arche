// The boundary of the no-repoint rule: a slice's ELEMENTS are writable (`s[i] = x` mutates the viewed
// data, not the pointer). Only repointing the slice itself is banned — write-through must keep working.
// RUN: %arche build -o %t %s && %t | grep -q "^42$"
#import { fmt }

poke :: system {
  buf: [8]int;
  s := buf[0: 4];
  s[0] = 42;
  fmt.printf("%d\n", s[0]);
}

#run seq({ poke })
