// A `float` array const must store 64-bit doubles (arche `float` == LLVM `double` everywhere). An
// earlier bug emitted the backing global as `[N x float]` (32-bit) while every read path used
// `double`, so the bytes were reinterpreted and reads returned garbage. Covers all three float
// array-const access paths: direct indexing `F[i]`, slice decay `sum(F)`, and a matrix row
// `sum(M[r])`. F is {1.5,2.5,3.0} (sum 7.0, F[1]==2.5); M row 1 is {3.0,4.0} (sum 7.0).
// RUN: %arche build -o %t %s && %t | grep -x "F1=2.500000 sumF=7.000000 sumM=7.000000"
#import { fmt }
sum :: func(xs: []float) -> float {
  s := 0.0;
  i := 0;
  for (i = 0; i < xs.length; i = i + 1) {
    s = s + xs[i];
  }
  return s;
}

F :: { 1.5, 2.5, 3.0 };
M :: { {1.5, 2.5}, {3.0, 4.0} };

main :: proc() {
  fmt.printf("F1=%f sumF=%f sumM=%f\n", F[1], sum(F), sum(M[1]));
}
