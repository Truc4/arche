// Threading a bounded buffer through an `own` param and returning it BY REFERENCE — the ownership
// idiom (the caller's storage flows in via `move`, the same storage flows back out). The non-char
// element type must NOT byte-truncate: 300 round-trips as 300, not 44. Returning a fresh local array
// is still rejected (it would dangle / needs copy-out) — see errors/array_local_return_rejected.
// RUN: %arche build -o %t %s && %t | grep -q "owned 300 9"
#import { fmt }
step :: func(own a: [8]int, i: int, v: int) -> [8]int {
  if (i >= 0 && i < a.length) {
    a[i] = v;
  }
  return a;
}

entry :: system eff {
  a: [8]int;
  a := step(move a, 0, 300);
  a := step(move a, 1, 9);
  fmt.printf("owned %d %d\n", a[0], a[1]);
}

#run entry
