// 2-D rectangular literal: `M :: { {1,2}, {3,4} }` infers `[2][2]int` (nested bare braces for inner
// dims). `M[1, 0]` == 3. (RED until N-D {..} literals + array consts land.)
// RUN: %arche build -o %t %s && %t | grep -x "3"
#import { fmt }
M :: { {1, 2}, {3, 4} };
main :: proc() {
  fmt.printf("%d\n", M[1, 0]);
}
