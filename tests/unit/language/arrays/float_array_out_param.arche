// float array filled via an `own` buffer (was a proc out param; proc removed).
// RUN: %arche build -o %t %s && %t | grep -q "fout=3.25"
#import { fmt }
fill :: func(own buf: [4]float) -> [4]float {
  buf[0] = 3.25;
  return buf;
}
entry :: system eff {
  f: [4]float;
  r := fill(move f);
  fmt.printf("fout=%g\n", r[0]);
}

#run entry
