// i64 array filled via an `own` buffer threaded through a func (was a proc out-param; proc removed).
// RUN: %arche build -o %t %s && %t | grep -q "o=5000000000"
#import { fmt }
fill :: func(own buf: [4]i64) -> [4]i64 {
  buf[0] = 5000000000;
  return buf;
}
entry :: system eff {
  a: [4]i64;
  r := fill(move a);
  fmt.printf("o=%lld\n", r[0]);
}

#run entry
