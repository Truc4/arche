// A sub-slice is bounds-checked: 0 <= lo <= hi <= length. An out-of-range slice (hi past the end)
// aborts at runtime rather than silently over-reading. Runtime check (the `!` expects nonzero exit).
// RUN: %arche build -o %t %s && ! %t
#import { fmt }
sum :: func(xs: []int) -> int {
  total := 0;
  i     := 0;
  for (i = 0; i < xs.length; i = i + 1) {
    total += xs[i];
  }
  return total;
}

entry :: system eff {
  a: [8]int;
  fmt.printf("%d\n", sum(a[2: 10])); // hi=10 > length 8 -> abort
}

#run entry
