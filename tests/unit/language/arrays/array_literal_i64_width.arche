// A non-char `[N]T` array literal (`{1000, 2}` typed `[2]i64`/`[N]int`) must store its elements at the
// DECLARED element width. It used to be misclassified as a char string and built as a `[N x i8]` constant
// global, then copied byte-wise into the array — truncating/garbling every element (`1000` → an i8; values
// > 255 prove the width). Fixed by typed element scatter into the array's storage in both the bind-with-init
// (`b: [3]i64 = {…}`) and decl-then-assign (`a: [2]i64; a = {…}`) paths, mirroring the pool-column scatter.
// RUN: %arche build -o %t %s && %t | grep -qF "a=1000 2 b=300 400 500 c=70000 8"
#import { fmt }

entry :: system {
  a: [2]i64;
  a = { 1000, 2 };                  // decl-then-assign
  b: [3]i64 = { 300, 400, 500 };    // bind-with-init
  c: [2]int = { 70000, 8 };         // non-char i32 element, value > i16 to prove width
  fmt.printf("a=%d %d b=%d %d %d c=%d %d\n", a[0], a[1], b[0], b[1], b[2], c[0], c[1]);
}

#run entry
