// A matrix row also materialises through a TYPED slot `x : []int = M[i]` — the explicit `[]int`
// drives the local and the row is borrowed as a (ptr, len) slice. x.length == row width, x[2] reads.
// RUN: %arche build -o %t %s && %t | grep -x "n=3 v=6"
#import { fmt }
M :: { { 1, 2, 3 }, { 4, 5, 6 } }

main :: proc() {
  x: []int = M[1];
  fmt.printf("n=%d v=%d\n", x.length, x[2]);
}
