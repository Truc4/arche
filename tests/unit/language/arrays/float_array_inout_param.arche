// float array round-tripped through an `own` buffer (was a proc in-out param; proc removed).
// RUN: %arche build -o %t %s && %t | grep -q "f=1.5,2.5"
#import { fmt }
fill :: func(own buf: [4]float, n: int) -> [4]float {
  buf[0] = 1.5;
  buf[1] = 2.5;
  return buf;
}
entry :: system {
  b: [4]float;
  r := fill(move b, 4);
  fmt.printf("f=%g,%g\n", r[0], r[1]);
}

#run entry
