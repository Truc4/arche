// Reading a `::` const array inside a pure `func` is PURE — the backing global is immutable
// (read-only `constant`), exactly like a scalar or string const. It was previously mis-flagged
// "reads a mutable global", which wrongly rejected even a scalar element read from a func.
// RUN: %arche build -o %t %s && %t | grep -x "20"
#import { fmt }
XS :: { 10, 20, 30 };
nth :: func(i: int) -> int { return XS[i]; }
main :: proc() {
  fmt.printf("%d\n", nth(1));
}
