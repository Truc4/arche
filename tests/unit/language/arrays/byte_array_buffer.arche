// `[N]byte` buffers: allocation, element store (literal, byte→byte, truncated int), and reading
// elements back into int arithmetic. Regression for a chain of `byte`(=u8, i8 storage) codegen bugs:
//   - `[N]byte` lowered its element type as a nominal `%struct.byte` (unsized) → couldn't allocate;
//   - a byte element load widened to i32 but kept resolved width 8 → emit_int_convert re-widened it;
//   - a byte element STORE wrote the raw i32 RHS into the i8 slot without truncating.
// All fixed: a byte element behaves like u8 (i8 storage, promotes to i32 in int context, truncs on
// store), the same model as `char`. Plus integer promotion: an implicit `direct := b[0] + b[1]` binds
// an `int` (sub-int operands promote), not a too-narrow byte — so it prints correctly via `%d`.
// RUN: %arche build -o %t %s && %t | grep "sum=198 last=65 wrapped=1 direct=131"
#import { fmt }
entry :: system {
  b: [4]byte;
  b[0] = 65;
  b[1] = 66;
  b[2] = 67;
  b[3] = 256 + 1; // int RHS truncates into the i8 slot → 1

  // read elements back into int arithmetic (accumulate)
  sum := 0;
  i   := 0;
  for (; i < 3;) {
    sum = sum + b[i];
    i   = i + 1;
  }

  // byte -> byte store, then read into an int
  b[2] = b[0];
  last := 0;
  last = b[2];

  wrapped := 0;
  wrapped = b[3]; // the truncated 257 -> 1

  direct := b[0] + b[1]; // integer promotion: infers `int` (65+66=131), not byte

  fmt.printf("sum=%d last=%d wrapped=%d direct=%d\n", sum, last, wrapped, direct);
}

#run entry
