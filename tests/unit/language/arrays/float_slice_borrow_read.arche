// A borrowed `float[]` slice: read-only view over a caller's float buffer, no copy, no size in the
// signature. The element type flows through the fat pointer so `xs[i]` loads doubles (not the default
// i32) and the runtime `.length` bounds the read. Guards element-typing of the slice ABI beyond int.
// RUN: %arche build -o %t %s && %t | grep -q "flen=3 fsum=4"
fsum :: func(xs: float[]) -> float {
  total := 0.0;
  i := 0;
  for (i = 0; i < xs.length; i = i + 1) {
    total = total + xs[i];
  }
  return total;
}

main :: proc() {
  a: float[3];
  a[0] = 1.5;
  a[1] = 2.25;
  a[2] = 0.25;
  printf("flen=%d fsum=%g\n", a.length, fsum(a));
}
