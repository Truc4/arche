// Same ownership-threading idiom as int_array_own_thread, but a float[] element type: the buffer is
// moved in through an `own` param and returned by reference, and the values come back as doubles (no
// int coercion). Guards the element-type generalization of the array-return path beyond int/char.
// RUN: %arche build -o %t %s && %t | grep -q "owned 9.5 2.25"
#import { fmt }
step :: func(own a: [4]float, i: int, v: float) -> [4]float {
  if (i >= 0 && i < a.length) {
    a[i] = v;
  }
  return a;
}

main :: proc() {
  a: [4]float;
  a := step(move a, 0, 9.5);
  a := step(move a, 1, 2.25);
  fmt.printf("owned %g %g\n", a[0], a[1]);
}