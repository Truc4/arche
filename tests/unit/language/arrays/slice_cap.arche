// Every array carries length AND capacity (the heapless `{ptr, len, cap}` model). A sub-slice
// `a[lo:hi]` has length `hi-lo` and capacity `backing_cap - lo` (room from the slice start to the
// end of the backing storage); a fixed `T[N]` has length N and cap N. `.cap`/`.capacity` is distinct
// from `.length`. Works the same for char and numeric element types.
// RUN: %arche build -o %t %s && %t | grep "slen=3 scap=6 tlen=4 tcap=7 bufcap=8 ibcap=10"
#import { fmt }
main :: proc() {
  buf: char[8];
  s := buf[2: 5]; // length 3, cap 8-2=6
  ib: int[10];
  t := ib[3: 7]; // length 4, cap 10-3=7
  fmt.printf(
    "slen=%d scap=%d tlen=%d tcap=%d bufcap=%d ibcap=%d\n",
    s.length,
    s.cap,
    t.length,
    t.cap,
    buf.cap,
    ib.cap,
  );
}
