// END-TO-END (build + run) for value-array const access patterns — the existing const/slice tests
// only run the analyzer (`--dump`), so the actual codegen of these binds was never exercised. Covers:
// a direct const index (`XS[0]`), a matrix ROW bind + index (`row := M[1]; row[2]`), a runtime SLICE
// bind + index (`view := buf[1:4]; view[0]`), a chained matrix index (`M[0][1]`), and `.length` on a
// string-literal bind (`label := "hi"`). (A whole 1-D const bind `whole := XS` is covered by
// whole_array_const_bind.arche.)
// RUN: %arche build -o %t %s && %t | grep -x "10 6 7 2 2"
#import { fmt }
XS   :: { 10, 20, 30 }
M    :: { { 1, 2, 3 }, { 4, 5, 6 } }
entry :: system {
  row := M[1]; // a [3]i32 row alias
  buf: [5]int;
  buf[1] = 7;
  view  := buf[1: 4]; // a []i32 slice view
  label := "hi"; // a []char string
  fmt.printf("%d %d %d %d %d\n", XS[0], row[2], view[0], label.length, M[0][1]);
}

#run entry
