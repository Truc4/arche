// Non-char array threaded through an `own` func param (was a proc in-out param; proc removed).
// RUN: %arche build -o %t %s && %t | grep -q "9 7 12"
#import { fmt }
fill :: func(own buf: [8]int, n: int) -> [8]int {
  buf[0] = 9;
  buf[1] = 7;
  buf[2] = buf[0] + 3;
  return buf;
}
entry :: system eff {
  b: [8]int;
  r := fill(move b, 8);
  fmt.printf("%d %d %d\n", r[0], r[1], r[2]);
}

#run entry
