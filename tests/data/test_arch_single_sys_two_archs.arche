arche Particle {
  pos: float,
  vel: float
}

arche Body {
  pos: float,
  vel: float,
  mass: float
}

sys move(pos, vel) {
  pos = pos + vel;
}

proc main() {
  let particles = alloc Particle(5);
  let bodies = alloc Body(5);
  insert(particles, 1.0, 0.1);
  insert(bodies, 2.0, 0.2);
  run move;
  print({109, 117, 108, 116, 105, 45, 97, 114, 99, 104, 101, 116, 121, 112, 101, 32, 100, 105, 115, 112, 97, 116, 99, 104, 32, 119, 111, 114, 107, 115, 10});
}

