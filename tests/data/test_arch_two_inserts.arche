arche Particle {
  pos: float,
  vel: float
}

arche Body {
  pos: float,
  vel: float,
  mass: float
}

proc main() {
  let particles = alloc Particle(100);
  let bodies = alloc Body(50);
  insert(particles, 1.0, 0.1);
  insert(bodies, 5.0, 0.5, 10.0);
  print({105, 110, 115, 101, 114, 116, 101, 100, 10});
}

